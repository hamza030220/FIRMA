{% extends 'user/base.html.twig' %}

{% block page_title %}Paiement — Équipements{% endblock %}

{% block user_content %}
<div class="um-pay-page" data-stripe-key="{{ stripe_public_key }}" data-client-secret="{{ client_secret }}" data-cancel-url="{{ path('user_marketplace_paiement_cancel') }}" data-marketplace-url="{{ path('user_marketplace') }}" data-payment-type="equipement">

    <a href="{{ path('user_marketplace') }}" class="um-pay-back">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Retour au marketplace
    </a>

    <div class="um-pay-header">
        <h1 class="um-pay-title">Finaliser votre commande</h1>
        <div class="um-pay-timer" id="umPayTimer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span id="umPayTimerText">03:00</span>
        </div>
    </div>

    <div class="um-pay-layout">

        {# ── Left: Invoice ── #}
        <div class="um-pay-invoice">
            <h2>Récapitulatif</h2>
            <div class="um-pay-items">
                {% for id, item in cart %}
                <div class="um-pay-item">
                    <div class="um-pay-item-info">
                        <strong>{{ item.nom }}</strong>
                        <span>{{ item.qty }} × {{ item.prix|number_format(2, ',', ' ') }} TND</span>
                    </div>
                    <span class="um-pay-item-sub">{{ (item.prix * item.qty)|number_format(2, ',', ' ') }} TND</span>
                </div>
                {% endfor %}
            </div>
            <div class="um-pay-divider"></div>
            <div class="um-pay-total-row">
                <span>Total à payer</span>
                <strong>{{ total|number_format(2, ',', ' ') }} TND</strong>
            </div>
        </div>

        {# ── Right: Card Form ── #}
        <div class="um-pay-form-wrap">
            <h2>Informations de paiement</h2>
            <form method="post" action="{{ path('user_marketplace_paiement_process') }}" class="um-pay-form" id="umPayForm">
                <input type="hidden" name="_token" value="{{ csrf_token('paiement_equipements') }}">

                <div class="um-pay-section-title">Adresse de livraison</div>
                <div class="um-pay-field">
                    <label for="payAdresse">Adresse</label>
                    <div class="firma-field-with-map">
                        <input type="text" id="payAdresse" name="adresse" required placeholder="123 Rue de la Ferme" style="flex:1;">
                        <button type="button" class="firma-map-btn" title="Choisir sur la carte" onclick="firmaMapPicker({adresseFieldId:'payAdresse',villeFieldId:'payVille'})">
                            <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        </button>
                    </div>
                </div>
                <div class="um-pay-field">
                    <label for="payVille">Ville</label>
                    <input type="text" id="payVille" name="ville" required placeholder="Tunis">
                </div>

                <div class="um-pay-section-title">Carte bancaire</div>

                {# Stripe Elements container #}
                <div class="um-pay-field">
                    <label>Numéro de carte</label>
                    <div id="stripe-card-element" class="um-stripe-element"></div>
                </div>

                {# Error display #}
                <div id="stripe-card-errors" class="um-stripe-error" style="display:none;"></div>

                <button type="submit" class="um-pay-submit" id="umPaySubmit">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    <span id="umPayBtnText">Payer {{ total|number_format(2, ',', ' ') }} TND</span>
                    <span id="umPaySpinner" class="um-pay-spinner" style="display:none;"></span>
                </button>

                <div class="um-pay-divider-or">
                    <span>ou</span>
                </div>

                <button type="button" class="um-pay-livraison" id="umPayLivraison">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                    Payer à la livraison
                </button>
            </form>

            <form method="post" action="{{ path('user_marketplace_paiement_livraison') }}" id="umPayLivraisonForm" style="display:none;">
                <input type="hidden" name="_token" value="{{ csrf_token('paiement_equipements') }}">
                <input type="hidden" name="adresse" id="umLivAdresse">
                <input type="hidden" name="ville" id="umLivVille">
            </form>
        </div>
    </div>
</div>

<script src="https://js.stripe.com/v3/"></script>
{% endblock %}
