{% extends 'user/base.html.twig' %}

{% block page_title %}Maladies des plantes{% endblock %}

{% block user_content %}

<div class="mal-page">

    {# ===== HERO ===== #}
    <div class="mal-hero">
        <div class="mal-hero-badge">Bibliothèque phytosanitaire</div>
        <h1 class="mal-hero-title">Maladies des plantes</h1>
        <p class="mal-hero-sub">Identifiez, comprenez et traitez les maladies qui menacent vos cultures.</p>

        {# Stats rapides #}
        <div class="mal-hero-stats">
            <div class="mal-stat">
                <span class="mal-stat-num">{{ maladies|length }}</span>
                <span class="mal-stat-label">maladies répertoriées</span>
            </div>
            <div class="mal-stat-sep"></div>
            <div class="mal-stat">
                {% set totalTraitements = 0 %}
                {% for m in maladies %}{% set totalTraitements = totalTraitements + m.solutionTraitements|length %}{% endfor %}
                <span class="mal-stat-num">{{ totalTraitements }}</span>
                <span class="mal-stat-label">traitements disponibles</span>
            </div>
            <div class="mal-stat-sep"></div>
            <div class="mal-stat">
                {% set totalUsages = 0 %}
                {% for m in maladies %}{% for s in m.solutionTraitements %}{% set totalUsages = totalUsages + s.usageCount %}{% endfor %}{% endfor %}
                <span class="mal-stat-num">{{ totalUsages }}</span>
                <span class="mal-stat-label">utilisations enregistrées</span>
            </div>
        </div>
    </div>

    {# ===== BARRE RECHERCHE + FILTRES ===== #}
    <form method="get" action="{{ path('user_maladie') }}" class="mal-search-form" data-auto-search data-auto-search-min="2">
        <div class="mal-search-wrap">
            <div class="mal-search-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            </div>
            <input
                type="text"
                name="q"
                value="{{ keyword }}"
                placeholder="Rechercher une maladie, symptôme, description…"
                class="mal-search-input"
                autocomplete="off"
            >
            {% if keyword or gravite %}
            <a href="{{ path('user_maladie') }}" class="mal-clear-btn" title="Réinitialiser">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </a>
            {% endif %}
        </div>

        <div class="mal-filters">
            <select name="gravite" class="mal-select">
                <option value="">Toutes les gravités</option>
                <option value="faible"   {% if gravite == 'faible'   %}selected{% endif %}>Faible</option>
                <option value="moyen"    {% if gravite == 'moyen'    %}selected{% endif %}>Moyen</option>
                <option value="eleve"    {% if gravite == 'eleve'    %}selected{% endif %}>Élevé</option>
                <option value="critique" {% if gravite == 'critique' %}selected{% endif %}>Critique</option>
            </select>

            <select name="tri" class="mal-select">
                <option value="nom"     {% if tri == 'nom'     %}selected{% endif %}>Trier par nom</option>
                <option value="gravite" {% if tri == 'gravite' %}selected{% endif %}>Trier par gravité</option>
                <option value="saison"  {% if tri == 'saison'  %}selected{% endif %}>Trier par saison</option>
            </select>

            <button type="submit" class="mal-btn-search">Rechercher</button>
        </div>
    </form>

    {# Résumé résultats #}
    <div class="mal-results-bar">
        <span class="mal-results-count">
            <strong>{{ maladies|length }}</strong> maladie{% if maladies|length > 1 %}s{% endif %}
            {% if keyword %} pour <em>"{{ keyword }}"</em>{% endif %}
            {% if gravite %} · gravité <strong>{{ gravite }}</strong>{% endif %}
        </span>
        {% if tri %}
        <span class="mal-results-tri">Trié par {{ tri }}</span>
        {% endif %}
    </div>

    {# ===== GRILLE DES MALADIES ===== #}
    {% if maladies is not empty %}
    <div class="mal-grid">
        {% for maladie in maladies %}
        <a href="{{ path('user_maladie_show', {'id': maladie.id}) }}" class="mal-card">

            {# Image ou placeholder #}
            <div class="mal-card-img">
                {% if maladie.imageUrl %}
                    <img src="{{ asset('uploads/maladies/' ~ maladie.imageUrl) }}" alt="{{ maladie.nom }}">
                {% else %}
                    <div class="mal-card-img-placeholder">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" opacity="0.4"><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2z"/><path d="M12 6v6l4 2"/></svg>
                    </div>
                {% endif %}
                <div class="mal-card-gravite mal-grav-{{ maladie.niveauGravite }}">
                    {{ maladie.niveauGravite|capitalize }}
                </div>
            </div>

            {# Contenu #}
            <div class="mal-card-body">
                <h3 class="mal-card-title">{{ maladie.nom }}</h3>
                {% if maladie.nomScientifique %}
                    <p class="mal-card-sci">{{ maladie.nomScientifique }}</p>
                {% endif %}
                {% if maladie.description %}
                    <p class="mal-card-desc">{{ maladie.description|slice(0, 100) }}…</p>
                {% endif %}

                {# Meta #}
                <div class="mal-card-meta">
                    {% if maladie.saisonFrequente %}
                    <span class="mal-meta-item">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        {{ maladie.saisonFrequente }}
                    </span>
                    {% endif %}
                    <span class="mal-meta-item">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/></svg>
                        {{ maladie.solutionTraitements|length }} traitement{% if maladie.solutionTraitements|length > 1 %}s{% endif %}
                    </span>
                    {% set cardUsages = 0 %}
                    {% for s in maladie.solutionTraitements %}{% set cardUsages = cardUsages + s.usageCount %}{% endfor %}
                    {% if cardUsages > 0 %}
                    <span class="mal-meta-item">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        {{ cardUsages }} utilisation{% if cardUsages > 1 %}s{% endif %}
                    </span>
                    {% endif %}
                </div>
            </div>

            {# Flèche #}
            <div class="mal-card-arrow">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>

        </a>
        {% endfor %}
    </div>

    {% else %}
    <div class="mal-empty">
        <div class="mal-empty-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </div>
        <h3>Aucun résultat</h3>
        <p>Aucune maladie ne correspond à votre recherche{% if keyword %} "<strong>{{ keyword }}</strong>"{% endif %}.</p>
        <a href="{{ path('user_maladie') }}" class="mal-btn-reset">Voir toutes les maladies</a>
    </div>
    {% endif %}

</div>

<style>
/* ===== BASE ===== */
.mal-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
}

/* ===== HERO ===== */
.mal-hero {
    text-align: center;
    padding: 3rem 1rem 2.5rem;
    position: relative;
}
.mal-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(15, 92, 47, 0.06) 0%, transparent 70%);
    pointer-events: none;
    border-radius: 24px;
}
.mal-hero-badge {
    display: inline-block;
    background: #e8f5e9;
    color: #0f5c2f;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.9rem;
    border-radius: 20px;
    margin-bottom: 1rem;
    border: 1px solid rgba(15, 92, 47, 0.15);
}
.mal-hero-title {
    font-family: 'Playfair Display', serif;
    font-size: 2.6rem;
    font-weight: 700;
    color: #1a2e1a;
    margin: 0 0 0.6rem;
    line-height: 1.15;
}
.mal-hero-sub {
    color: #5a7a5a;
    font-size: 1rem;
    max-width: 500px;
    margin: 0 auto 2rem;
    line-height: 1.6;
}
.mal-hero-stats {
    display: inline-flex;
    align-items: center;
    gap: 0;
    background: white;
    border: 1px solid #e0ebe0;
    border-radius: 14px;
    padding: 0.8rem 1.5rem;
    box-shadow: 0 2px 12px rgba(15,92,47,0.06);
}
.mal-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 1.2rem;
}
.mal-stat-num {
    font-size: 1.5rem;
    font-weight: 700;
    color: #0f5c2f;
    font-family: 'Playfair Display', serif;
    line-height: 1;
}
.mal-stat-label {
    font-size: 0.72rem;
    color: #7a9a7a;
    margin-top: 0.2rem;
    white-space: nowrap;
}
.mal-stat-sep {
    width: 1px;
    height: 36px;
    background: #e0ebe0;
}

/* ===== RECHERCHE ===== */
.mal-search-form {
    margin: 0 0 1rem;
}
.mal-search-wrap {
    position: relative;
    margin-bottom: 0.75rem;
}
.mal-search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: #7a9a7a;
    display: flex;
}
.mal-search-input {
    width: 100%;
    box-sizing: border-box;
    padding: 0.85rem 1rem 0.85rem 2.8rem;
    border: 1.5px solid #d4e6d4;
    border-radius: 12px;
    font-size: 0.95rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
    background: white;
    color: #1a2e1a;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
}
.mal-search-input:focus {
    border-color: #0f5c2f;
    box-shadow: 0 0 0 3px rgba(15,92,47,0.08);
}
.mal-search-input::placeholder { color: #a0b8a0; }
.mal-clear-btn {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: #a0b8a0;
    display: flex;
    padding: 4px;
    border-radius: 6px;
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
}
.mal-clear-btn:hover { color: #0f5c2f; background: #e8f5e9; }

.mal-filters {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
}
.mal-select {
    flex: 1;
    min-width: 150px;
    padding: 0.65rem 1rem;
    border: 1.5px solid #d4e6d4;
    border-radius: 10px;
    font-size: 0.875rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
    background: white;
    color: #1a2e1a;
    cursor: pointer;
    outline: none;
    transition: border-color 0.2s;
}
.mal-select:focus { border-color: #0f5c2f; }
.mal-btn-search {
    padding: 0.65rem 1.6rem;
    background: #0f5c2f;
    color: white;
    border: none;
    border-radius: 10px;
    font-size: 0.875rem;
    font-weight: 600;
    font-family: 'Plus Jakarta Sans', sans-serif;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
    white-space: nowrap;
}
.mal-btn-search:hover { background: #0a3d1f; }
.mal-btn-search:active { transform: scale(0.98); }

/* ===== RÉSUMÉ ===== */
.mal-results-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 0.2rem;
    margin-bottom: 1.2rem;
    font-size: 0.85rem;
    color: #7a9a7a;
}
.mal-results-count strong { color: #0f5c2f; }
.mal-results-count em { font-style: normal; color: #1a2e1a; }
.mal-results-tri { font-size: 0.8rem; color: #a0b8a0; }

/* ===== GRILLE ===== */
.mal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
}

/* ===== CARD ===== */
.mal-card {
    display: flex;
    flex-direction: column;
    background: white;
    border: 1.5px solid #e0ebe0;
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    position: relative;
}
.mal-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 38px rgba(15,92,47,0.16), 0 6px 16px rgba(15,92,47,0.10);
    border-color: #b8d4b8;
}

.mal-card-img {
    height: 140px;
    position: relative;
    background: #f0f7f0;
    overflow: hidden;
}
.mal-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
}
.mal-card:hover .mal-card-img img { transform: scale(1.04); }
.mal-card-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #a0b8a0;
    background: linear-gradient(135deg, #f0f7f0 0%, #e8f5e9 100%);
}

/* Badge gravité sur l'image */
.mal-card-gravite {
    position: absolute;
    top: 10px;
    right: 10px;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.25rem 0.65rem;
    border-radius: 20px;
    backdrop-filter: blur(4px);
}
.mal-grav-faible   { background: rgba(232,245,233,0.95); color: #2e7d32; border: 1px solid rgba(46,125,50,0.2); }
.mal-grav-moyen    { background: rgba(227,242,253,0.95); color: #1565c0; border: 1px solid rgba(21,101,192,0.2); }
.mal-grav-eleve    { background: rgba(255,243,224,0.95); color: #e65100; border: 1px solid rgba(230,81,0,0.2); }
.mal-grav-critique { background: rgba(253,235,234,0.95); color: #c62828; border: 1px solid rgba(198,40,40,0.2); }

.mal-card-body {
    padding: 1rem 1rem 0.8rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
}
.mal-card-title {
    font-size: 1rem;
    font-weight: 700;
    color: #1a2e1a;
    margin: 0;
    font-family: 'Playfair Display', serif;
}
.mal-card-sci {
    font-size: 0.78rem;
    color: #a0b8a0;
    font-style: italic;
    margin: 0;
}
.mal-card-desc {
    font-size: 0.83rem;
    color: #5a7a5a;
    margin: 0.2rem 0 0;
    line-height: 1.5;
    flex: 1;
}

.mal-card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.6rem;
    padding-top: 0.6rem;
    border-top: 1px solid #f0f7f0;
}
.mal-meta-item {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    color: #7a9a7a;
}
.mal-meta-item svg { flex-shrink: 0; }

.mal-card-arrow {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    color: #c0d8c0;
    transition: color 0.2s, transform 0.2s;
}
.mal-card:hover .mal-card-arrow {
    color: #0f5c2f;
    transform: translateX(3px);
}

/* ===== EMPTY STATE ===== */
.mal-empty {
    text-align: center;
    padding: 4rem 2rem;
    color: #7a9a7a;
}
.mal-empty-icon {
    width: 72px;
    height: 72px;
    background: #f0f7f0;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.2rem;
    color: #a0b8a0;
}
.mal-empty h3 {
    font-family: 'Playfair Display', serif;
    color: #1a2e1a;
    margin: 0 0 0.4rem;
}
.mal-empty p { font-size: 0.9rem; margin: 0 0 1.2rem; }
.mal-btn-reset {
    display: inline-block;
    padding: 0.6rem 1.4rem;
    background: #0f5c2f;
    color: white;
    border-radius: 10px;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 600;
    transition: background 0.2s;
}
.mal-btn-reset:hover { background: #0a3d1f; }

/* ===== RESPONSIVE ===== */
@media (max-width: 600px) {
    .mal-hero-title { font-size: 1.8rem; }
    .mal-hero-stats { flex-direction: column; gap: 0.8rem; padding: 1rem; }
    .mal-stat-sep { width: 60px; height: 1px; }
    .mal-grid { grid-template-columns: 1fr; }
    .mal-filters { flex-direction: column; }
    .mal-btn-search { width: 100%; }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const form = document.querySelector('.mal-search-form');
    if (!form) return;

    form.querySelectorAll('select[name="gravite"], select[name="tri"]').forEach((select) => {
        select.addEventListener('change', () => {
            if (typeof form.requestSubmit === 'function') {
                form.requestSubmit();
            } else {
                form.submit();
            }
        });
    });
});
</script>

{% endblock %}
