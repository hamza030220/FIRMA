{# templates/user/suggestions.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Suggestions - Maladies trouvées{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-warning text-dark text-center rounded-top-4">
                    <h3 class="mb-0">
                        <i class="fas fa-question-circle me-2"></i>
                        Plusieurs maladies correspondent
                    </h3>
                </div>
                <div class="card-body p-4">
                    
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        Votre recherche : <strong>"{{ recherche }}"</strong>
                        <br>
                        Nous avons trouvé <strong>{{ maladies|length }}</strong> maladie(s) qui pourraient correspondre.
                    </div>
                    
                    <h5 class="mb-3"><i class="fas fa-list me-2 text-warning"></i> Sélectionnez la maladie qui correspond le mieux :</h5>
                    
                    <div class="row">
                        {% for maladie in maladies %}
                            <div class="col-md-6 mb-3">
                                <div class="card h-100 border-0 shadow-sm">
                                    <div class="card-body">
                                        <div class="d-flex">
                                            {% if maladie.imageUrl %}
                                                <div class="flex-shrink-0">
                                                    <img src="{{ asset('uploads/maladies/' ~ maladie.imageUrl) }}" 
                                                         alt="{{ maladie.nom }}"
                                                         style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px;">
                                                </div>
                                            {% endif %}
                                            <div class="flex-grow-1 ms-3">
                                                <h5 class="card-title text-success">{{ maladie.nom }}</h5>
                                                <p class="card-text small text-muted">
                                                    {{ maladie.description|slice(0, 100) }}...
                                                </p>
                                                <span class="badge 
                                                    {% if maladie.niveauGravite == 'critique' %}bg-danger
                                                    {% elseif maladie.niveauGravite == 'eleve' %}bg-warning
                                                    {% elseif maladie.niveauGravite == 'moyen' %}bg-info
                                                    {% else %}bg-success{% endif %}">
                                                    {% if maladie.niveauGravite == 'critique' %}Critique
                                                    {% elseif maladie.niveauGravite == 'eleve' %}Élevé
                                                    {% elseif maladie.niveauGravite == 'moyen' %}Moyen
                                                    {% else %}Faible{% endif %}
                                                </span>
                                                <div class="mt-2">
                                                    <a href="{{ path('user_resultat', {'id': maladie.id}) }}" 
                                                       class="btn btn-sm btn-success">
                                                        <i class="fas fa-eye me-1"></i> Voir traitement
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                    
                    <hr class="my-4">
                    
                    <div class="text-center">
                        <p class="text-muted">
                            <i class="fas fa-lightbulb me-2"></i>
                            Aucune de ces maladies ne correspond ?
                        </p>
                        <a href="{{ path('user_diagnostiquer') }}" class="btn btn-outline-secondary">
                            <i class="fas fa-redo me-2"></i> Faire une nouvelle recherche
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}