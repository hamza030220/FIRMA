{# templates/user/diagnostiquer.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Diagnostiquer ma plante - FIRMA{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-success text-white text-center rounded-top-4">
                    <h2 class="mb-0">
                        <i class="fas fa-leaf me-2"></i>
                        Diagnostic de votre plante
                    </h2>
                </div>
                <div class="card-body p-4">
                    
                    {# Messages flash #}
                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger alert-dismissible fade show">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}
                    
                    {% for message in app.flashes('warning') %}
                        <div class="alert alert-warning alert-dismissible fade show">
                            <i class="fas fa-info-circle me-2"></i>
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}
                    
                    <form method="post" action="{{ path('user_rechercher') }}">
                        <div class="mb-4">
                            <label class="form-label fw-bold">
                                <i class="fas fa-pen-alt me-2 text-success"></i>
                                Décrivez les symptômes de votre plante :
                            </label>
                            <textarea 
                                name="description" 
                                class="form-control form-control-lg" 
                                rows="6" 
                                placeholder="Exemple : 
- Mes tomates ont des taches brunes sur les feuilles
- Il y a un duvet blanc en dessous des feuilles
- Les fruits commencent à noircir
- La plante semble dépérir rapidement"
                                required
                            ></textarea>
                            <div class="form-text text-muted mt-2">
                                <i class="fas fa-lightbulb me-1"></i>
                                Plus vous donnez de détails, plus le diagnostic sera précis !
                            </div>
                        </div>
                        
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="fas fa-search me-2"></i>
                                Diagnostiquer ma plante
                            </button>
                        </div>
                    </form>
                    
                    <hr class="my-4">
                    
                    <div class="text-center">
                        <h5><i class="fas fa-tips me-2 text-info"></i> Conseils pour un bon diagnostic :</h5>
                        <div class="row mt-3">
                            <div class="col-md-4">
                                <div class="small text-muted">
                                    <i class="fas fa-leaf text-success"></i> Décrivez la plante
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="small text-muted">
                                    <i class="fas fa-eye text-success"></i> Couleur des feuilles
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="small text-muted">
                                    <i class="fas fa-cloud-rain text-success"></i> Conditions météo
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# Section des maladies récentes #}
{% if maladiesRecentes is defined and maladiesRecentes|length > 0 %}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0"><i class="fas fa-history me-2"></i> Maladies fréquentes</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        {% for maladie in maladiesRecentes %}
                        <div class="col-md-4 mb-2">
                            <a href="{{ path('user_resultat', {'id': maladie.id}) }}" class="text-decoration-none">
                                <div class="badge bg-secondary p-2">
                                    <i class="fas fa-seedling me-1"></i> {{ maladie.nom }}
                                </div>
                            </a>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endif %}
{% endblock %}