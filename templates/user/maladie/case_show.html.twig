{% extends 'user/base.html.twig' %}

{% block page_title %}Suivi - {{ case.maladie.nom }}{% endblock %}

{% block user_content %}
{% set errors = errors|default({}) %}
{% set formData = formData|default({}) %}
{% set isOwner = app.user and case.utilisateur and app.user.id == case.utilisateur.id %}
<div class="case-page">
    <div class="case-head">
        <h1>{{ case.maladie.nom }}</h1>
        <a class="case-link" href="{{ path('user_maladie_case_index') }}">Retour</a>
    </div>

    <div class="case-card">
        <div><strong>Culture:</strong> {{ case.culture ?: 'Non precisee' }}</div>
        <div><strong>Parcelle:</strong> {{ case.parcelle ?: 'Non precisee' }}</div>
        <div><strong>Statut:</strong> {{ case.statut }}</div>
        <div><strong>Symptomes:</strong> {{ case.symptomes }}</div>
    </div>

    <div class="case-grid">
        <div class="case-updates">
            <h2>Historique</h2>
            {% if case.updates is empty %}
                <div class="case-empty">Aucun suivi pour le moment.</div>
            {% else %}
                {% for u in case.updates %}
                    <div class="case-update">
                        <div><strong>Resultat:</strong> {{ u.resultat }}</div>
                        {% if u.solutionTraitement %}
                            <div><strong>Traitement:</strong> {{ u.solutionTraitement.titre }}</div>
                        {% endif %}
                        {% if u.commentaire %}
                            <div>{{ u.commentaire }}</div>
                        {% endif %}
                        {% if u.photos is not empty %}
                            <div class="case-photos">
                                {% for p in u.photos %}
                                    <img src="{{ asset('uploads/maladies/cases/' ~ p.filename) }}" alt="Photo cas">
                                {% endfor %}
                            </div>
                        {% endif %}
                        <div class="case-date">{{ u.createdAt|date('d/m/Y H:i') }}</div>
                    </div>
                {% endfor %}
            {% endif %}
        </div>

        <div class="case-form-wrap">
            <h2>Ajouter un suivi</h2>
            {% if not isOwner %}
                <div class="case-readonly">Seul l'auteur de ce cas peut ajouter un suivi.</div>
            {% else %}
                {% if errors is not empty %}
                    <div class="case-errors">
                        {% for error in errors %}
                            <div class="case-error">{{ error }}</div>
                        {% endfor %}
                    </div>
                {% endif %}
                <form method="post" action="{{ path('user_maladie_case_update', {'id': case.id}) }}" class="case-form" enctype="multipart/form-data">
                    <div class="case-field">
                        <label>Traitement applique</label>
                        <select name="solution_id">
                            <option value="">Choisir un traitement</option>
                            {% for s in solutions %}
                                <option value="{{ s.id }}" {% if formData.solution_id is defined and formData.solution_id == s.id %}selected{% endif %}>{{ s.titre }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="case-field">
                        <label>Resultat *</label>
                        <select name="resultat" required>
                            <option value="">Choisir</option>
                            <option value="succes" {% if formData.resultat is defined and formData.resultat == 'succes' %}selected{% endif %}>Succes</option>
                            <option value="amelioration" {% if formData.resultat is defined and formData.resultat == 'amelioration' %}selected{% endif %}>Amelioration</option>
                            <option value="stable" {% if formData.resultat is defined and formData.resultat == 'stable' %}selected{% endif %}>Stable</option>
                            <option value="echec" {% if formData.resultat is defined and formData.resultat == 'echec' %}selected{% endif %}>Echec</option>
                        </select>
                    </div>
                    <div class="case-field">
                        <label>Commentaire</label>
                        <textarea name="commentaire" rows="3">{{ formData.commentaire is defined ? formData.commentaire : '' }}</textarea>
                    </div>
                    <div class="case-field">
                        <label>Photos</label>
                        <input id="casePhotos" type="file" name="photos[]" accept="image/*" multiple>
                        <div class="case-photo-preview" id="casePhotosPreview" aria-hidden="true">
                            <div class="case-photo-preview-label">Apercu</div>
                            <div class="case-photo-preview-grid" id="casePhotosPreviewGrid"></div>
                        </div>
                    </div>
                    <button type="submit" class="case-btn">Enregistrer</button>
                </form>
            {% endif %}
        </div>
    </div>
</div>

<style>
.case-page { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem 4rem; font-family: 'Plus Jakarta Sans', sans-serif; }
.case-head { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 1.5rem; }
.case-link { text-decoration: none; color: #0f5c2f; font-weight: 700; }
.case-card { background: #fff; border: 1px solid #e0ebe0; border-radius: 14px; padding: 1rem; margin-bottom: 1.5rem; }
.case-grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(280px, 360px); gap: 1.5rem; align-items: start; }
.case-updates { margin-bottom: 1.5rem; }
.case-update { background: #fff; border: 1px solid #e0ebe0; border-radius: 12px; padding: 0.8rem; margin-bottom: 0.7rem; }
.case-photos { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem; }
.case-photos img { width: 120px; height: 90px; object-fit: cover; border-radius: 8px; border: 1px solid #e0ebe0; }
.case-date { font-size: 0.8rem; color: #6b7f74; margin-top: 0.4rem; }
.case-empty { padding: 0.8rem; background: #f6f9f7; border: 1px dashed #cfe0d2; border-radius: 10px; color: #6b7f74; }
.case-form-wrap { background: #fff; border: 1px solid #e0ebe0; border-radius: 14px; padding: 1.2rem; position: sticky; top: 1.2rem; }
.case-readonly { background: #f6f9f7; border: 1px dashed #cfe0d2; border-radius: 10px; padding: 0.8rem; color: #5f7468; font-size: 0.9rem; }
.case-errors { margin-bottom: 0.8rem; }
.case-error { background: #fdeaea; border: 1px solid #f2b8b8; color: #b42318; padding: 0.5rem 0.7rem; border-radius: 10px; margin-bottom: 0.4rem; }
.case-form { margin-top: 0.6rem; }
.case-field { margin-bottom: 0.9rem; }
.case-field label { display: block; font-weight: 700; margin-bottom: 0.4rem; }
.case-field input, .case-field select, .case-field textarea { width: 100%; border: 1px solid #d6e2d6; border-radius: 10px; padding: 0.65rem 0.8rem; font-family: inherit; }
.case-photo-preview { margin-top: 0.6rem; border-radius: 12px; padding: 0.7rem; border: 1px dashed #cfe0d2; background: #f8fbf8; display: none; }
.case-photo-preview.is-visible { display: block; }
.case-photo-preview-label { font-size: 0.72rem; color: #5a7a5a; margin-bottom: 0.5rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; }
.case-photo-preview-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 0.5rem; }
.case-photo-preview-grid img { width: 100%; height: 90px; object-fit: cover; border-radius: 8px; border: 1px solid #d9eadc; background: #fff; }
.case-btn { background: #0f5c2f; color: #fff; border: none; border-radius: 10px; padding: 0.6rem 1.2rem; font-weight: 700; cursor: pointer; }

@media (max-width: 900px) {
    .case-grid { grid-template-columns: 1fr; }
    .case-form-wrap { position: static; }
}
</style>
{% endblock %}
