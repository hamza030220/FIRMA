{% extends 'user/base.html.twig' %}

{% block page_title %}Carnet de suivi{% endblock %}

{% block user_content %}
<div class="case-page">
    <div class="case-head">
        <h1>Carnet de suivi maladies</h1>
        <a class="case-btn" href="{{ path('user_maladie_case_new') }}">Nouveau cas</a>
    </div>

    {% if cases is empty %}
        <div class="case-empty">Aucun cas public pour le moment.</div>
    {% else %}
        <div class="case-grid">
            {% for c in cases %}
                <a class="case-card" href="{{ path('user_maladie_case_show', {'id': c.id}) }}">
                    <div class="case-title">{{ c.maladie.nom }}</div>
                    <div class="case-meta">{{ c.culture ?: 'Culture non precisee' }} · {{ c.parcelle ?: 'Parcelle non precisee' }}</div>
                    <div class="case-status">Statut: {{ c.statut }}</div>
                    <div class="case-date">{{ c.createdAt|date('d/m/Y') }}</div>
                </a>
            {% endfor %}
        </div>
    {% endif %}
</div>

<style>
.case-page { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem 4rem; font-family: 'Plus Jakarta Sans', sans-serif; }
.case-head { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
.case-btn { background: #0f5c2f; color: #fff; border-radius: 10px; padding: 0.5rem 1rem; text-decoration: none; font-weight: 700; }
.case-grid { margin-top: 1.5rem; display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
.case-card { background: #fff; border: 1px solid #e0ebe0; border-radius: 14px; padding: 1rem; text-decoration: none; color: inherit; box-shadow: 0 8px 18px rgba(15,92,47,0.08); }
.case-title { font-weight: 700; margin-bottom: 0.4rem; }
.case-meta { color: #5f7468; font-size: 0.85rem; }
.case-status { margin-top: 0.5rem; font-size: 0.85rem; }
.case-date { margin-top: 0.5rem; font-size: 0.8rem; color: #6b7f74; }
.case-empty { margin-top: 1.5rem; padding: 1rem; background: #f6f9f7; border: 1px dashed #cfe0d2; border-radius: 12px; color: #6b7f74; }
</style>
{% endblock %}
