{% extends 'user/base.html.twig' %}

{% block page_title %}Nouveau cas{% endblock %}

{% block user_content %}
<div class="case-page">
    <div class="case-head">
        <h1>Nouveau cas maladie</h1>
        <a class="case-link" href="{{ path('user_maladie_case_index') }}">Retour</a>
    </div>

    <form method="post" class="case-form">
        <div class="case-field">
            <label>Maladie *</label>
            <select name="maladie_id" required>
                <option value="">Choisir une maladie</option>
                {% for m in maladies %}
                    <option value="{{ m.id }}">{{ m.nom }}</option>
                {% endfor %}
            </select>
            {% if errors.maladie is defined %}<div class="case-error">{{ errors.maladie }}</div>{% endif %}
        </div>
        <div class="case-field">
            <label>Culture</label>
            <input type="text" name="culture" placeholder="Ex: tomate, vigne">
        </div>
        <div class="case-field">
            <label>Parcelle</label>
            <input type="text" name="parcelle" placeholder="Ex: Serre A">
        </div>
        <div class="case-field">
            <label>Symptomes *</label>
            <textarea name="symptomes" rows="4" placeholder="Decrivez les symptomes"></textarea>
            {% if errors.symptomes is defined %}<div class="case-error">{{ errors.symptomes }}</div>{% endif %}
        </div>
        <div class="case-field">
            <label><input type="checkbox" name="is_public" value="1" checked> Rendre ce cas public</label>
        </div>
        <button type="submit" class="case-btn">Creer le cas</button>
    </form>
</div>

<style>
.case-page { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem 4rem; font-family: 'Plus Jakarta Sans', sans-serif; }
.case-head { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 1.5rem; }
.case-link { text-decoration: none; color: #0f5c2f; font-weight: 700; }
.case-form { background: #fff; border: 1px solid #e0ebe0; border-radius: 14px; padding: 1.5rem; box-shadow: 0 12px 26px rgba(15,92,47,0.08); }
.case-field { margin-bottom: 1rem; }
.case-field label { display: block; font-weight: 700; margin-bottom: 0.4rem; }
.case-field input, .case-field select, .case-field textarea { width: 100%; border: 1px solid #d6e2d6; border-radius: 10px; padding: 0.65rem 0.8rem; font-family: inherit; }
.case-error { margin-top: 0.4rem; color: #b42318; font-size: 0.85rem; }
.case-btn { background: #0f5c2f; color: #fff; border: none; border-radius: 10px; padding: 0.6rem 1.2rem; font-weight: 700; cursor: pointer; }
</style>
{% endblock %}
