{% extends 'user/base.html.twig' %}

{% block page_title %}Tableau de bord{% endblock %}

{% block user_content %}
<div class="placeholder-page">
    <div class="placeholder-hero">
        <div class="placeholder-icon">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        </div>
        <h2>Bienvenue, {{ app.user.prenom }} !</h2>
        <p>Votre espace personnel FIRMA. Explorez le marketplace, participez au forum, consultez les maladies et découvrez les événements.</p>
    </div>
    <div class="placeholder-cards">
        <a href="{{ path('user_marketplace') }}" class="placeholder-card">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            <h3>Marketplace</h3>
            <p>Acheter & vendre des produits agricoles</p>
        </a>
        <a href="{{ path('user_forum') }}" class="placeholder-card">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            <h3>Forum</h3>
            <p>Discuter avec la communauté</p>
        </a>
        <a href="{{ path('user_maladie') }}" class="placeholder-card">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 20A7 7 0 0 1 4 13C4 7 10 3 20 4c-1 10-5 16-11 16z"/><path d="M2 21c3-2 5-4 7-7"/></svg>
            <h3>Maladies</h3>
            <p>Consultez la liste des maladies agricoles</p>
        </a>
        <a href="{{ path('user_evenements') }}" class="placeholder-card">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <h3>Événements</h3>
            <p>Découvrir les événements agricoles</p>
        </a>
    </div>
</div>
{% endblock %}
