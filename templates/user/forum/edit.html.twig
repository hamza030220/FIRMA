{% extends 'user/base.html.twig' %}

{% block page_title %}Modifier {{ post.titre }}{% endblock %}

{% block user_content %}
<section class="forum-shell">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="forum-flash forum-flash-{{ label == 'error' ? 'error' : 'success' }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <a href="{{ path('user_forum_show', {id: post.id}) }}#post-detail" class="forum-back-link">Retour au post</a>

    <section class="forum-panel">
        <div class="forum-toolbar">
            <h1>Modifier le post</h1>
            <span>{{ post.dateCreation|date('H:i', 'Africa/Lagos') }}</span>
        </div>

        <form id="edit-post-form" method="post" action="{{ path('user_forum_edit', {id: post.id}) }}" class="forum-form" novalidate>
            <input type="hidden" name="_token" value="{{ csrf_token('forum_edit_' ~ post.id) }}">

            <label for="titre">Titre</label>
            <input id="titre" name="titre" type="text" value="{{ form_data.titre }}">
            {% if form_errors.titre is defined %}
                <div class="forum-flash forum-flash-error">{{ form_errors.titre }}</div>
            {% endif %}

            <label for="categorie">Categorie</label>
            <select id="categorie" name="categorie" required>
                <option value="">Choisir une categorie</option>
                {% for categorie in categories %}
                    <option value="{{ categorie }}" {% if form_data.categorie == categorie %}selected{% endif %}>{{ categorie }}</option>
                {% endfor %}
            </select>
            {% if form_errors.categorie is defined %}
                <div class="forum-flash forum-flash-error">{{ form_errors.categorie }}</div>
            {% endif %}

            <label for="contenu">Contenu</label>
            <textarea id="contenu" name="contenu" rows="8">{{ form_data.contenu }}</textarea>
            {% if form_errors.contenu is defined %}
                <div class="forum-flash forum-flash-error">{{ form_errors.contenu }}</div>
            {% endif %}

            <div class="forum-actions">
                <button type="submit" class="forum-button">Enregistrer</button>
                <a href="{{ path('user_forum_show', {id: post.id}) }}#post-detail" class="forum-button forum-button-secondary">Annuler</a>
            </div>
        </form>
    </section>
</section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const form = document.getElementById('edit-post-form');
            if (!(form instanceof HTMLFormElement)) {
                return;
            }

            let isConfirmed = false;
            let pendingSubmit = false;

            const setEditSuccessToast = () => {
                sessionStorage.setItem('forumPostEditedToast', JSON.stringify({
                    message: 'Votre post a ete modifie avec succes.',
                    type: 'success',
                    duration: 10000
                }));
            };

            const modal = document.getElementById('appConfirmModal');
            const modalTitle = document.getElementById('appConfirmTitle');
            const modalMessage = document.getElementById('appConfirmMessage');
            const modalSubmit = document.getElementById('appConfirmSubmit');

            if (modal && modalTitle && modalMessage && modalSubmit && !modalSubmit.dataset.editPostBound) {
                modalSubmit.dataset.editPostBound = 'true';
                modalSubmit.addEventListener('click', () => {
                    if (!pendingSubmit) {
                        return;
                    }

                    pendingSubmit = false;
                    isConfirmed = true;
                    setEditSuccessToast();
                    form.submit();
                });
            }

            form.addEventListener('submit', (event) => {
                if (isConfirmed) {
                    return;
                }

                event.preventDefault();

                const title = 'Enregistrer les modifications';
                const message = 'Voulez-vous vraiment enregistrer les modifications de ce post ?';

                if (typeof window.firmaOpenConfirmModal === 'function') {
                    pendingSubmit = true;
                    window.firmaOpenConfirmModal('edit-post-form', title, message, 'Enregistrer', 'primary');
                    return;
                }

                isConfirmed = true;
                setEditSuccessToast();
                form.submit();
            });
        });
    </script>
{% endblock %}
