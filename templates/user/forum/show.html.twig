{% extends 'user/base.html.twig' %}

{% set displayedPost = translated_post is defined and translated_post ? translated_post : null %}

{% block page_title %}{{ displayedPost.title|default(post.titre) }}{% endblock %}

{% block user_content %}
<section class="forum-shell">
    {% include 'shared/forum/_language_switcher.html.twig' %}
    {% set forumUnreadNotifications = user_notifications_count() %}
    {% if forumUnreadNotifications > 0 %}
        <div class="forum-warning-banner" role="alert" aria-live="polite">
            <div class="forum-warning-banner-copy">
                <span class="forum-warning-banner-icon" aria-hidden="true">?</span>
                <div>
                    <strong>{{ 'forum.warning.title'|trans({}, 'forum') }}</strong>
                    <p>{{ 'forum.warning.message'|trans({}, 'forum') }}</p>
                </div>
            </div>
            <div class="forum-warning-banner-actions">
                <span class="forum-warning-banner-count" aria-label="{{ forumUnreadNotifications }} notifications">{{ forumUnreadNotifications }}</span>
                <a href="{{ path('user_notifications') }}" class="forum-warning-banner-link">
                    {{ 'forum.warning.cta'|trans({}, 'forum') }}
                </a>
            </div>
        </div>
    {% endif %}
    <nav class="forum-bookmark-tabs" aria-label="Bibliotheque du forum">
        <a href="{{ path('user_forum') }}" class="forum-bookmark-tab{% if forum_active_section|default('feed') == 'feed' %} is-active{% endif %}">Toutes les discussions</a>
        <a href="{{ path('user_forum_favorites') }}" class="forum-bookmark-tab{% if forum_active_section|default('feed') == 'favorites' %} is-active{% endif %}">Mes favoris</a>
        <a href="{{ path('user_forum_saved') }}" class="forum-bookmark-tab{% if forum_active_section|default('feed') == 'saved' %} is-active{% endif %}">A lire plus tard</a>
    </nav>
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="forum-flash forum-flash-{{ label in ['error', 'danger'] ? 'error' : 'success' }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <a href="{{ path('user_forum') }}" class="forum-back-link">{{ 'forum.common.back_to_discussions'|trans({}, 'forum') }}</a>

    <article id="post-detail" class="forum-panel forum-detail">
        <div class="forum-detail-header">
            <div class="forum-card-meta">
                <span>{{ translated_category is defined and translated_category is not empty ? translated_category : (post.categorie ?: ('forum.common.no_category'|trans({}, 'forum'))) }}</span>
                <span>{{ post.dateCreation|date('H:i', 'Africa/Lagos') }}</span>
            </div>
            <div class="forum-mood-widget forum-mood-widget-detail" data-forum-mood-widget data-post-id="{{ post.id }}" data-mood-url="{{ path('user_forum_mood_analyze') }}" data-forum-mood-autoload="true">
                <span class="forum-mood-result" data-forum-mood-result>{{ 'forum.mood.pending'|trans({}, 'forum') }}</span>
            </div>
            <div class="forum-detail-stats">
                <span>{{ post.commentaires|length }} {{ 'forum.common.comment'|trans({}, 'forum') }}{{ post.commentaires|length > 1 ? 's' : '' }}</span>
                <span>{{ 'forum.common.author'|trans({}, 'forum') }} : {{ post.utilisateur.fullName }}</span>
            </div>
        </div>
        <h1>{{ displayedPost.title|default(post.titre) }}</h1>
        <p class="forum-detail-author">{{ 'forum.common.by'|trans({}, 'forum') }} {{ post.utilisateur.fullName }}</p>
        <div class="forum-detail-content">{{ displayedPost.content|default(post.contenu)|nl2br }}</div>
        <div class="forum-bookmark-actions forum-bookmark-actions-detail">
            <form method="post" action="{{ path('user_forum_bookmark_toggle', {id: post.id, type: 'favorite'}) }}" class="forum-bookmark-form" data-forum-preserve-scroll="true">
                <input type="hidden" name="_token" value="{{ csrf_token('forum_bookmark_' ~ post.id ~ '_favorite') }}">
                <input type="hidden" name="return_to" value="{{ path('user_forum_show', {id: post.id}) }}">
                <button
                    type="submit"
                    class="forum-icon-action forum-icon-action-only{% if favorite_bookmarked_ids[post.id] is defined %} is-active{% endif %}"
                    title="{{ favorite_bookmarked_ids[post.id] is defined ? 'Retirer des favoris' : 'Ajouter aux favoris' }}"
                    aria-label="{{ favorite_bookmarked_ids[post.id] is defined ? 'Retirer des favoris' : 'Ajouter aux favoris' }}"
                >
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M12 17.3 6.82 20l.99-5.82L3.6 9.93l5.86-.85L12 3.78l2.54 5.3 5.86.85-4.2 4.25L17.18 20z"/>
                    </svg>
                </button>
            </form>
            <form method="post" action="{{ path('user_forum_bookmark_toggle', {id: post.id, type: 'saved'}) }}" class="forum-bookmark-form" data-forum-preserve-scroll="true">
                <input type="hidden" name="_token" value="{{ csrf_token('forum_bookmark_' ~ post.id ~ '_saved') }}">
                <input type="hidden" name="return_to" value="{{ path('user_forum_show', {id: post.id}) }}">
                <button
                    type="submit"
                    class="forum-icon-action forum-icon-action-only{% if saved_bookmarked_ids[post.id] is defined %} is-active{% endif %}"
                    title="{{ saved_bookmarked_ids[post.id] is defined ? 'Retirer de la sauvegarde' : 'Sauvegarder pour plus tard' }}"
                    aria-label="{{ saved_bookmarked_ids[post.id] is defined ? 'Retirer de la sauvegarde' : 'Sauvegarder pour plus tard' }}"
                >
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M6 3h12v18l-6-4-6 4z"/>
                    </svg>
                </button>
            </form>
        </div>
        {% include 'shared/forum/_reaction_bar.html.twig' with {
            post: post,
            reactionUser: app.user,
            reactionCompact: true,
            reactionEditable: true,
            reactionReturnTo: path('user_forum_show', {id: post.id}) ~ '#post-detail'
        } only %}
        {% if app.user and post.utilisateur and app.user.id == post.utilisateur.id %}
            <div class="forum-actions">
                <a
                    href="{{ path('user_forum_edit', {id: post.id}) }}"
                    class="forum-icon-action forum-icon-action-only"
                    title="{{ 'forum.index.edit_post'|trans({}, 'forum') }}"
                    aria-label="{{ 'forum.index.edit_post'|trans({}, 'forum') }}"
                    data-firma-confirm-link="true"
                    data-firma-confirm-title="{{ 'forum.index.edit_title'|trans({}, 'forum') }}"
                    data-firma-confirm-message="{{ 'forum.index.edit_message'|trans({}, 'forum') }}"
                    data-firma-confirm-submit="{{ 'forum.common.save'|trans({}, 'forum') }}"
                    data-firma-confirm-variant="primary"
                >
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M12 20h9"/>
                        <path d="M16.5 3.5a2.12 2.12 0 1 1 3 3L7 19l-4 1 1-4Z"/>
                    </svg>
                </a>
                <form id="delete-post-{{ post.id }}" method="post" action="{{ path('user_forum_delete', {id: post.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('forum_delete_' ~ post.id) }}">
                    <button type="button" class="forum-icon-action forum-icon-action-danger forum-icon-action-only" title="{{ 'forum.index.delete_post'|trans({}, 'forum') }}" aria-label="{{ 'forum.index.delete_post'|trans({}, 'forum') }}" onclick="window.firmaOpenConfirmModal('delete-post-{{ post.id }}', '{{ 'forum.index.delete_post'|trans({}, 'forum')|e('js') }}', '{{ 'forum.index.delete_message'|trans({}, 'forum')|e('js') }}');">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M3 6h18"/>
                            <path d="M8 6V4h8v2"/>
                            <path d="M19 6l-1 14H6L5 6"/>
                            <path d="M10 11v6"/>
                            <path d="M14 11v6"/>
                        </svg>
                    </button>
                </form>
            </div>
        {% endif %}
        <section id="post-comments" class="forum-comments-block">
            <div class="forum-toolbar">
                <h2>{{ 'forum.show.comments'|trans({}, 'forum') }}</h2>
                <span>{{ post.commentaires|length }} {{ 'forum.common.comment_total'|trans({}, 'forum') }}</span>
            </div>

            <form method="post" action="{{ path('user_forum_comment', {id: post.id}) }}" class="forum-form forum-comment-form" enctype="multipart/form-data">
                <input type="hidden" name="_token" value="{{ csrf_token('forum_comment_' ~ post.id) }}">
                <label for="commentaire">{{ 'forum.show.add_comment'|trans({}, 'forum') }}</label>
                <textarea id="commentaire" name="contenu" rows="4" maxlength="1000" placeholder="{{ 'forum.show.comment_placeholder'|trans({}, 'forum') }}" data-comment-input data-comment-min-length="2" data-comment-max-length="1000" data-comment-error-id="comment-text-error" data-comment-counter-id="comment-text-counter">{{ edit_comment_id is defined and edit_comment_id ? '' : comment_form_data.contenu|default('') }}</textarea>
                <div id="comment-text-counter" class="forum-input-help">0 / 1000 {{ 'forum.common.characters'|trans({}, 'forum') }}</div>
                <div id="comment-text-error" class="forum-flash forum-flash-error forum-inline-error" data-bad-words-error hidden></div>
                {% if edit_comment_id is not defined or not edit_comment_id %}
                    {% if comment_form_errors.contenu is defined %}
                        <div class="forum-flash forum-flash-error">{{ comment_form_errors.contenu }}</div>
                    {% endif %}
                    <label for="comment-image">{{ 'forum.show.image_label'|trans({}, 'forum') }}</label>
                    <input id="comment-image" name="image" type="file" accept=".jpg,.jpeg,.png,.webp,.gif,image/png,image/jpeg,image/webp,image/gif" data-image-preview-input="comment-image-preview" data-image-allowed-extensions="jpg,jpeg,png,webp,gif" data-image-min-width="200" data-image-min-height="200" data-image-max-width="6000" data-image-max-height="6000" data-image-max-bytes="5242880">
                    <div class="forum-flash forum-flash-error forum-inline-error" data-image-format-error hidden>{{ 'forum.show.image_format_error'|trans({}, 'forum') }}</div>
                    <div class="forum-flash forum-flash-error forum-inline-error" data-image-size-error hidden></div>
                    <div class="forum-flash forum-flash-error forum-inline-error" data-image-dimension-error hidden></div>
                    <div id="comment-image-preview" class="forum-image-preview" hidden>
                        <p>{{ 'forum.show.image_preview'|trans({}, 'forum') }}</p>
                        <img src="" alt="{{ 'forum.show.image_preview_alt'|trans({}, 'forum') }}" class="forum-comment-image">
                    </div>
                    {% if comment_form_errors.image is defined %}
                        <div class="forum-flash forum-flash-error">{{ comment_form_errors.image }}</div>
                    {% endif %}
                {% endif %}
                <button type="submit" class="forum-button">{{ 'forum.common.publish_comment'|trans({}, 'forum') }}</button>
            </form>

            <div class="forum-comments">
            {% for commentaire in post.commentaires %}
                {% set translatedComment = translated_comments[commentaire.id] ?? null %}
                {% set moderatedAlert = alerts_by_comment[commentaire.id]|default([])|first|default(null) %}
                <article class="forum-comment">
                        <div class="forum-card-footer">
                            <strong>{{ commentaire.utilisateur.fullName }}</strong>
                            <span>{{ commentaire.dateCreation|date('H:i', 'Africa/Lagos') }}</span>
                        </div>
                        {% if edit_comment_id is defined and edit_comment_id == commentaire.id %}
                            <form method="post" action="{{ path('user_forum_comment_edit', {id: commentaire.id}) }}" class="forum-form forum-comment-form" enctype="multipart/form-data" novalidate>
                                <input type="hidden" name="_token" value="{{ csrf_token('forum_comment_edit_' ~ commentaire.id) }}">
                                <label for="comment-edit-{{ commentaire.id }}">{{ 'forum.show.edit_comment'|trans({}, 'forum') }}</label>
                                <textarea id="comment-edit-{{ commentaire.id }}" name="contenu" rows="4" maxlength="1000" data-comment-input data-comment-min-length="2" data-comment-max-length="1000" data-comment-error-id="comment-edit-error-{{ commentaire.id }}" data-comment-counter-id="comment-edit-counter-{{ commentaire.id }}">{{ comment_form_data.contenu|default(commentaire.contenu) }}</textarea>
                                <div id="comment-edit-counter-{{ commentaire.id }}" class="forum-input-help">0 / 1000 {{ 'forum.common.characters'|trans({}, 'forum') }}</div>
                                <div id="comment-edit-error-{{ commentaire.id }}" class="forum-flash forum-flash-error forum-inline-error" data-bad-words-error hidden></div>
                                {% if comment_form_errors.contenu is defined %}
                                    <div class="forum-flash forum-flash-error">{{ comment_form_errors.contenu }}</div>
                                {% endif %}
                                <label for="comment-image-edit-{{ commentaire.id }}">{{ 'forum.show.image_edit_label'|trans({}, 'forum') }}</label>
                                <input id="comment-image-edit-{{ commentaire.id }}" name="image" type="file" accept=".jpg,.jpeg,.png,.webp,.gif,image/png,image/jpeg,image/webp,image/gif" data-image-preview-input="comment-image-edit-preview-{{ commentaire.id }}" data-image-allowed-extensions="jpg,jpeg,png,webp,gif" data-image-min-width="200" data-image-min-height="200" data-image-max-width="6000" data-image-max-height="6000" data-image-max-bytes="5242880">
                                <div class="forum-flash forum-flash-error forum-inline-error" data-image-format-error hidden>{{ 'forum.show.image_format_error'|trans({}, 'forum') }}</div>
                                <div class="forum-flash forum-flash-error forum-inline-error" data-image-size-error hidden></div>
                                <div class="forum-flash forum-flash-error forum-inline-error" data-image-dimension-error hidden></div>
                                <div id="comment-image-edit-preview-{{ commentaire.id }}" class="forum-image-preview" hidden>
                                    <p>{{ 'forum.show.image_preview'|trans({}, 'forum') }}</p>
                                    <img src="" alt="{{ 'forum.show.image_preview_alt'|trans({}, 'forum') }}" class="forum-comment-image">
                                </div>
                                {% if commentaire.imagePath %}
                                    <label class="forum-checkbox">
                                        <input type="checkbox" name="remove_image" value="1">
                                        <span>{{ 'forum.show.remove_current_image'|trans({}, 'forum') }}</span>
                                    </label>
                                {% endif %}
                                <input type="hidden" name="replace_image" value="1">
                                {% if comment_form_errors.image is defined %}
                                    <div class="forum-flash forum-flash-error">{{ comment_form_errors.image }}</div>
                                {% endif %}
                                <div class="forum-actions">
                                    <button type="submit" class="forum-button">{{ 'forum.show.save'|trans({}, 'forum') }}</button>
                                    <a href="{{ path('user_forum_show', {id: post.id}) }}#post-comments" class="forum-button forum-button-secondary">{{ 'forum.show.cancel'|trans({}, 'forum') }}</a>
                                </div>
                            </form>
                    {% else %}
                        <p>{{ (moderatedAlert ? moderatedAlert.maskedContent : translatedComment.content|default(commentaire.contenu))|nl2br }}</p>
                        {% if commentaire.imagePath %}
                            <img src="{{ asset(commentaire.imagePath) }}" alt="{{ 'forum.show.image_preview_alt'|trans({}, 'forum') }}" class="forum-comment-image">
                        {% endif %}
                    {% endif %}
                        {% if app.user and commentaire.utilisateur and app.user.id == commentaire.utilisateur.id %}
                            <div class="forum-actions">
                                <a
                                    href="{{ path('user_forum_show', {id: post.id, editComment: commentaire.id}) }}#post-comments"
                                    class="forum-icon-action forum-icon-action-only"
                                    title="{{ 'forum.show.edit_comment_title'|trans({}, 'forum') }}"
                                    aria-label="{{ 'forum.show.edit_comment_title'|trans({}, 'forum') }}"
                                    data-firma-confirm-link="true"
                                    data-firma-confirm-title="{{ 'forum.show.edit_comment_title'|trans({}, 'forum') }}"
                                    data-firma-confirm-message="{{ 'forum.show.edit_comment_message'|trans({}, 'forum') }}"
                                    data-firma-confirm-submit="{{ 'forum.common.save'|trans({}, 'forum') }}"
                                    data-firma-confirm-variant="primary"
                                >
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M12 20h9"/>
                                        <path d="M16.5 3.5a2.12 2.12 0 1 1 3 3L7 19l-4 1 1-4Z"/>
                                    </svg>
                                </a>
                                <form id="delete-comment-{{ commentaire.id }}" method="post" action="{{ path('user_forum_comment_delete', {id: commentaire.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('forum_comment_delete_' ~ commentaire.id) }}">
                                    <button type="button" class="forum-icon-action forum-icon-action-danger forum-icon-action-only" title="{{ 'forum.show.delete_comment_title'|trans({}, 'forum') }}" aria-label="{{ 'forum.show.delete_comment_title'|trans({}, 'forum') }}" onclick="window.firmaOpenConfirmModal('delete-comment-{{ commentaire.id }}', '{{ 'forum.show.delete_comment_title'|trans({}, 'forum')|e('js') }}', '{{ 'forum.show.delete_comment_message'|trans({}, 'forum')|e('js') }}');">
                                        <svg viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M3 6h18"/>
                                            <path d="M8 6V4h8v2"/>
                                            <path d="M19 6l-1 14H6L5 6"/>
                                            <path d="M10 11v6"/>
                                            <path d="M14 11v6"/>
                                        </svg>
                                    </button>
                                </form>
                            </div>
                        {% endif %}
                    </article>
                {% else %}
                    <div class="forum-empty">
                        <h3>{{ 'forum.show.no_comments_title'|trans({}, 'forum') }}</h3>
                        <p>{{ 'forum.show.no_comments_text'|trans({}, 'forum') }}</p>
                    </div>
                {% endfor %}
            </div>
        </section>
    </article>
</section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const badWordsEndpoint = '{{ path('user_forum_bad_words_check')|e('js') }}';
            const moodWidgets = document.querySelectorAll('[data-forum-mood-widget]');
            const storedScroll = sessionStorage.getItem('forumRestoreScrollY');
            if (storedScroll !== null) {
                const y = Number.parseInt(storedScroll, 10);
                if (Number.isFinite(y) && y >= 0) {
                    window.scrollTo({ top: y, behavior: 'auto' });
                }
                sessionStorage.removeItem('forumRestoreScrollY');
            }

            const successToast = {{ forum_success_toast is defined and forum_success_toast ? {
                message: forum_success_toast.message|default(''),
                type: forum_success_toast.type|default('success'),
                duration: forum_success_toast.duration|default(10000)
            }|json_encode|raw : 'null' }};

            if (successToast && successToast.message) {
                const showToast = (message, type = 'success', duration = 10000) => {
                    if (typeof window.firmaToast === 'function') {
                        window.firmaToast(message, type, duration);
                        return;
                    }

                    const toast = document.createElement('div');
                    toast.className = 'forum-flash forum-flash-' + (type === 'danger' ? 'error' : 'success');
                    toast.style.cssText = 'position:fixed;top:18px;right:18px;z-index:99999;max-width:420px;padding:12px 14px;border-radius:12px;box-shadow:0 14px 30px rgba(0,0,0,.14);background:' + (type === 'danger' ? '#fdeaea' : '#eaf3de') + ';color:' + (type === 'danger' ? '#a32d2d' : '#27500a') + ';border:1px solid ' + (type === 'danger' ? '#f5c5c0' : '#c0dd97') + ';';
                    toast.textContent = message;
                    document.body.appendChild(toast);
                    window.setTimeout(() => toast.remove(), duration);
                };

                showToast(successToast.message, successToast.type || 'success', Number.parseInt(successToast.duration || 10000, 10));
            }

            document.querySelectorAll('form[data-forum-preserve-scroll="true"]').forEach((scrollForm) => {
                if (!(scrollForm instanceof HTMLFormElement) || scrollForm.dataset.forumScrollBound === 'true') {
                    return;
                }

                scrollForm.dataset.forumScrollBound = 'true';
                scrollForm.addEventListener('submit', () => {
                    sessionStorage.setItem('forumRestoreScrollY', String(window.scrollY));
                });
            });

            document.querySelectorAll('a[data-firma-confirm-link="true"]').forEach((link) => {
                if (!(link instanceof HTMLAnchorElement) || link.dataset.forumConfirmBound === 'true') {
                    return;
                }

                link.dataset.forumConfirmBound = 'true';
                link.addEventListener('click', (event) => {
                    const href = link.getAttribute('href');
                    if (!href || href === '#') {
                        return;
                    }

                    event.preventDefault();

                    const title = link.getAttribute('data-firma-confirm-title') || 'Modifier';
                    const message = link.getAttribute('data-firma-confirm-message') || 'Voulez-vous confirmer cette action ?';
                    const submitLabel = link.getAttribute('data-firma-confirm-submit') || 'Modifier';

                    if (typeof window.firmaConfirm === 'function') {
                        window.firmaConfirm(title, message, submitLabel, 'primary').then((ok) => {
                            if (!ok) {
                                return;
                            }

                            window.location.href = href;
                        });
                        return;
                    }

                    window.location.href = href;
                });
            });

            const getMoodLabel = (mood) => {
                switch ((mood || '').toLowerCase()) {
                    case 'positif':
                        return 'Positif';
                    case 'negatif':
                        return 'Négatif';
                    default:
                        return 'Neutre';
                }
            };

            const getMoodEmoji = (mood) => {
                switch ((mood || '').toLowerCase()) {
                    case 'positif':
                        return '😊';
                    case 'negatif':
                        return '😞';
                    default:
                        return '😐';
                }
            };

            const getLocalizedMoodLabel = (mood) => {
                const labels = {
                    positif: '{{ "forum.mood.positive"|trans({}, "forum")|e("js") }}',
                    negatif: '{{ "forum.mood.negative"|trans({}, "forum")|e("js") }}',
                    neutre: '{{ "forum.mood.neutral"|trans({}, "forum")|e("js") }}',
                };

                return labels[(mood || '').toLowerCase()] || labels.neutre;
            };

            const getMoodClass = (mood) => {
                switch ((mood || '').toLowerCase()) {
                    case 'positif':
                        return 'is-positive';
                    case 'negatif':
                        return 'is-negative';
                    default:
                        return 'is-neutral';
                }
            };

            const analyzeMood = async (widget) => {
                if (!(widget instanceof HTMLElement) || widget.dataset.forumMoodLoaded === 'true' || widget.dataset.forumMoodLoaded === 'loading') {
                    return;
                }

                const result = widget.querySelector('[data-forum-mood-result]');
                const postId = Number.parseInt(widget.dataset.postId || '0', 10);
                const moodUrl = widget.dataset.moodUrl || '';

                if (!Number.isFinite(postId) || postId <= 0 || !moodUrl || !(result instanceof HTMLElement)) {
                    return;
                }

                widget.dataset.forumMoodLoaded = 'loading';
                result.textContent = '...';
                widget.classList.add('is-loading');

                try {
                    const response = await fetch(moodUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json',
                        },
                        body: JSON.stringify({ postId }),
                    });

                    const payload = await response.json();
                    if (!response.ok || !payload || payload.ok !== true || !payload.data) {
                        throw new Error((payload && payload.error) ? payload.error : 'Analyse indisponible.');
                    }

                    const mood = payload.data.mood || 'neutre';
                    const score = typeof payload.data.score === 'number' ? Math.round(payload.data.score * 100) : null;

                    widget.classList.remove('is-loading', 'is-positive', 'is-negative', 'is-neutral', 'is-error');
                    widget.classList.add(getMoodClass(mood));
                    result.textContent = score !== null ? `${getMoodEmoji(mood)} ${getLocalizedMoodLabel(mood)} · ${score}%` : `${getMoodEmoji(mood)} ${getLocalizedMoodLabel(mood)}`;
                    widget.dataset.forumMoodLoaded = 'true';
                } catch (error) {
                    widget.classList.remove('is-loading', 'is-positive', 'is-negative', 'is-neutral');
                    widget.classList.add('is-error');
                    result.textContent = 'Erreur';
                    widget.dataset.forumMoodLoaded = '';
                    if (window.console && typeof window.console.warn === 'function') {
                        window.console.warn(error);
                    }
                }
            };

            moodWidgets.forEach((widget) => {
                if (!(widget instanceof HTMLElement)) {
                    return;
                }

                if (widget.dataset.forumMoodAutoload === 'true') {
                    analyzeMood(widget);
                }
            });

            const clearBadWordsError = (form) => {
                if (!(form instanceof HTMLFormElement)) {
                    return;
                }

                const errorNode = form.querySelector('[data-bad-words-error]');
                if (errorNode instanceof HTMLElement) {
                    errorNode.hidden = true;
                    errorNode.textContent = '';
                }
            };

            const showBadWordsError = (form, message) => {
                if (!(form instanceof HTMLFormElement)) {
                    return;
                }

                const errorNode = form.querySelector('[data-bad-words-error]');
                if (errorNode instanceof HTMLElement) {
                    errorNode.textContent = message;
                    errorNode.hidden = false;
                }
            };

            const checkBadWords = async (text) => {
                const response = await fetch(badWordsEndpoint, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json',
                    },
                    body: JSON.stringify({ text }),
                    credentials: 'same-origin',
                });

                return response.json();
            };

            document.querySelectorAll('form.forum-comment-form').forEach((form) => {
                if (!(form instanceof HTMLFormElement) || form.dataset.badWordsBound === 'true') {
                    return;
                }

                form.dataset.badWordsBound = 'true';

                const textarea = form.querySelector('textarea[name="contenu"]');
                if (!(textarea instanceof HTMLTextAreaElement)) {
                    return;
                }

                textarea.addEventListener('input', () => {
                    clearBadWordsError(form);
                });

                form.addEventListener('submit', async (event) => {
                    if (form.dataset.badWordsConfirmed === 'true') {
                        return;
                    }

                    if (typeof fetch !== 'function') {
                        return;
                    }

                    event.preventDefault();
                    clearBadWordsError(form);

                    const text = (textarea.value || '').trim();
                    if (text === '') {
                        form.dataset.badWordsConfirmed = 'true';
                        form.submit();
                        return;
                    }

                    try {
                        const payload = await checkBadWords(text);
                        const data = payload && payload.data ? payload.data : null;

                        if (data && data.blocked) {
                            showBadWordsError(form, data.reason || 'Le commentaire contient un mot interdit.');
                            textarea.focus();
                            return;
                        }

                        form.dataset.badWordsConfirmed = 'true';
                        form.submit();
                    } catch (error) {
                        form.dataset.badWordsConfirmed = 'true';
                        form.submit();
                    }
                });
            });
        });
    </script>
{% endblock %}
