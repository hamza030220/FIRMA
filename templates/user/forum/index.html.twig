{% extends 'user/base.html.twig' %}

{% block page_title %}Forum{% endblock %}

{% block user_content %}
<section class="forum-shell">
    <div class="forum-hero">
        <div>
            <p class="forum-kicker">Communaute FIRMA</p>
            <h1>Echangez avec la communaute FIRMA</h1>
            <p class="forum-lead">Partagez vos questions, vos conseils et vos experiences avec les utilisateurs de la plateforme dans un espace d'echange clair et professionnel.</p>
        </div>
        <div class="forum-stats">
            <div>
                <strong>{{ posts|length }}</strong>
                <span>posts visibles</span>
            </div>
            <div>
                <strong>{{ app.user.fullName }}</strong>
                <span>connecte</span>
            </div>
        </div>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="forum-flash forum-flash-{{ label == 'error' ? 'error' : 'success' }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    {% if form_errors is not empty %}
        <div class="forum-flash forum-flash-error">Le formulaire contient des erreurs. Verifiez les champs ci-dessous.</div>
    {% endif %}

    <div class="forum-grid">
        <aside class="forum-panel">
            <h2>Nouveau post</h2>
            <form id="create-post-form" method="post" action="{{ path('user_forum_create') }}" class="forum-form" novalidate>
                <input type="hidden" name="_token" value="{{ csrf_token('forum_create') }}">

                <label for="titre">Titre</label>
                <input id="titre" name="titre" type="text" value="{{ form_data.titre }}" placeholder="Exemple : conseil pour l'irrigation">
                {% if form_errors.titre is defined %}
                    <div class="forum-flash forum-flash-error">{{ form_errors.titre }}</div>
                {% endif %}

                <label for="categorie">Categorie</label>
                <select id="categorie" name="categorie" required>
                    <option value="">Choisir une categorie</option>
                    {% for categorie in categories %}
                        <option value="{{ categorie }}" {% if form_data.categorie == categorie %}selected{% endif %}>{{ categorie }}</option>
                    {% endfor %}
                </select>
                {% if form_errors.categorie is defined %}
                    <div class="forum-flash forum-flash-error">{{ form_errors.categorie }}</div>
                {% endif %}

                <label for="contenu">Contenu</label>
                <textarea id="contenu" name="contenu" rows="6" placeholder="Decrivez votre besoin ou partagez votre experience...">{{ form_data.contenu }}</textarea>
                {% if form_errors.contenu is defined %}
                    <div class="forum-flash forum-flash-error">{{ form_errors.contenu }}</div>
                {% endif %}

                <button
                    type="button"
                    class="forum-button"
                    onclick="window.firmaOpenConfirmModal('create-post-form', 'Publier ce post', 'Voulez-vous vraiment publier ce post ?', 'Publier', 'primary');"
                >
                    Publier
                </button>
            </form>
        </aside>

        <div class="forum-panel">
            <div class="forum-toolbar">
                <h2>Discussions</h2>
                <form method="get" action="{{ path('user_forum') }}" class="forum-search forum-search-inline" id="user-forum-search-form">
                    <input type="search" name="q" value="{{ search }}" placeholder="Rechercher un post par titre" minlength="3" id="user-forum-search-input">
                    <label for="user-forum-sort" class="forum-sort-pill">
                        <span>Trier</span>
                        <select id="user-forum-sort" name="sort" class="forum-sort-select" aria-label="Trier les discussions" onchange="this.form.submit()">
                            <option value="recent" {% if sort|default('recent') == 'recent' %}selected{% endif %}>Plus recents</option>
                            <option value="oldest" {% if sort|default('recent') == 'oldest' %}selected{% endif %}>Plus anciens</option>
                            <option value="title_asc" {% if sort|default('recent') == 'title_asc' %}selected{% endif %}>Titre A-Z</option>
                            <option value="title_desc" {% if sort|default('recent') == 'title_desc' %}selected{% endif %}>Titre Z-A</option>
                        </select>
                    </label>
                    <button type="submit">Chercher</button>
                    {% if search is not empty %}
                        <a href="{{ path('user_forum', {sort: sort|default('recent')}) }}" class="forum-search-reset">Reinitialiser</a>
                    {% endif %}
                </form>
            </div>
            {% if search is not empty %}
                <p class="forum-search-info">
                    {{ posts|length }} resultat{{ posts|length > 1 ? 's' : '' }} pour "<strong>{{ search }}</strong>"
                </p>
            {% endif %}

            <div class="forum-list" style="margin-top: 1rem;">
                {% for post in posts %}
                    <article class="forum-card">
                        <a href="{{ path('user_forum_show', {id: post.id}) }}" class="forum-card-link" aria-label="Ouvrir le post {{ post.titre }}">
                            <div class="forum-card-meta">
                                <span>{{ post.categorie ?: 'Sans categorie' }}</span>
                                <span>{{ post.dateCreation|date('H:i', 'Africa/Lagos') }}</span>
                            </div>
                            <h3>{{ post.titre }}</h3>
                            <p>{{ post.contenu|length > 190 ? post.contenu|slice(0, 190) ~ '...' : post.contenu }}</p>
                            <span class="forum-card-cta">Voir tout le post</span>
                        </a>
                        <div class="forum-card-footer">
                            <span>Par {{ post.utilisateur.fullName }}</span>
                            <div class="forum-inline-actions">
                                <span>{{ post.commentaires|length }} commentaire{{ post.commentaires|length > 1 ? 's' : '' }}</span>
                                {% if app.user and post.utilisateur and app.user.id == post.utilisateur.id %}
                                    <div class="forum-post-actions">
                                        <a href="{{ path('user_forum_edit', {id: post.id}) }}" class="forum-icon-action" title="Modifier le post" aria-label="Modifier le post">
                                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                                <path d="M12 20h9"/>
                                                <path d="M16.5 3.5a2.12 2.12 0 1 1 3 3L7 19l-4 1 1-4Z"/>
                                            </svg>
                                            <span>Modifier</span>
                                        </a>
                                        <form id="delete-post-{{ post.id }}" method="post" action="{{ path('user_forum_delete', {id: post.id}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('forum_delete_' ~ post.id) }}">
                                            <button type="button" class="forum-icon-action forum-icon-action-danger" title="Supprimer le post" aria-label="Supprimer le post" onclick="window.firmaOpenConfirmModal('delete-post-{{ post.id }}', 'Supprimer ce post', 'Voulez-vous vraiment supprimer ce post ? Cette action est irreversible.');">
                                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                                    <path d="M3 6h18"/>
                                                    <path d="M8 6V4h8v2"/>
                                                    <path d="M19 6l-1 14H6L5 6"/>
                                                    <path d="M10 11v6"/>
                                                    <path d="M14 11v6"/>
                                                </svg>
                                                <span>Supprimer</span>
                                            </button>
                                        </form>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </article>
                {% else %}
                    <div class="forum-empty">
                        <h3>Aucune discussion trouvee</h3>
                        {% if search is not empty %}
                            <p>Aucun resultat ne correspond a votre recherche. Essayez avec un autre mot-cle.</p>
                        {% else %}
                            <p>Commencez par publier le premier sujet du forum dans la version Symfony.</p>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
            {% include 'shared/_pagination.html.twig' with {
                currentPage: currentPage,
                totalPages: totalPages,
                route: 'user_forum',
                routeParams: { q: search, sort: sort }
            } %}
        </div>
    </div>
</section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const editToast = sessionStorage.getItem('forumPostEditedToast');
            if (editToast) {
                try {
                    const data = JSON.parse(editToast);
                    if (typeof window.firmaToast === 'function') {
                        window.firmaToast(
                            data.message || 'Votre post a ete modifie avec succes.',
                            data.type || 'success',
                            Number.isFinite(data.duration) ? data.duration : 10000
                        );
                    } else {
                        const flash = document.createElement('div');
                        flash.className = 'forum-flash forum-flash-success';
                        flash.textContent = data.message || 'Votre post a ete modifie avec succes.';
                        const shell = document.querySelector('.forum-shell');
                        if (shell) {
                            shell.insertBefore(flash, shell.firstChild);
                            window.setTimeout(() => flash.remove(), 10000);
                        }
                    }
                } catch (e) {
                    if (typeof window.firmaToast === 'function') {
                        window.firmaToast('Votre post a ete modifie avec succes.', 'success', 10000);
                    }
                }
                sessionStorage.removeItem('forumPostEditedToast');
            }

            const form = document.getElementById('user-forum-search-form');
            const input = document.getElementById('user-forum-search-input');

            if (!(form instanceof HTMLFormElement) || !(input instanceof HTMLInputElement)) {
                return;
            }

            const minLength = Number.parseInt(input.getAttribute('minlength') || '3', 10);
            let lastSubmitted = (input.value || '').trim();
            let debounceTimer = null;

            const submitIfNeeded = () => {
                const value = (input.value || '').trim();
                const hasEnoughChars = value.length >= minLength;
                const isReset = value.length === 0;

                if ((!hasEnoughChars && !isReset) || value === lastSubmitted) {
                    return;
                }

                lastSubmitted = value;
                form.submit();
            };

            input.addEventListener('input', () => {
                if (debounceTimer) {
                    window.clearTimeout(debounceTimer);
                }

                debounceTimer = window.setTimeout(submitIfNeeded, 250);
            });

            input.addEventListener('search', submitIfNeeded);
        });
    </script>
{% endblock %}
