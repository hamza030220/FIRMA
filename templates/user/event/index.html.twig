    window.showTickets = function(part) {
        var content = document.getElementById('ticketContent');
        content.innerHTML = '';

        var evt = part.evenement;

        // Main participant ticket
        var mainCard = buildTicketCard(evt, part.userName, 'Participant principal', part.code, 'Participant');
        content.appendChild(mainCard);

        // Accompagnant tickets
        if (part.accompagnantsList && part.accompagnantsList.length) {
            var title = document.createElement('h3');
            title.className = 'tkt-section-title';
            title.textContent = 'Tickets accompagnants (' + part.accompagnantsList.length + ')';
            content.appendChild(title);

            part.accompagnantsList.forEach(function(acc, i) {
                var accCode = acc.code || ('ACC-' + part.code);
                var accCard = buildTicketCard(evt, acc.prenom + ' ' + acc.nom, 'Accompagnant #' + (i + 1), accCode, 'Accompagnant');
                content.appendChild(accCard);
            });
        }

        // Generate QR codes
        content.querySelectorAll('[data-qr]').forEach(function(el) {
            generateQR(el, el.getAttribute('data-qr'), 120);
        });

        // Show modal
        closeModal(document.getElementById('evtMesParticipModal'));
        openModal(ticketModal);
    };

