    window.annulerParticipation = function(participId) {
        firmaConfirm(
            'Annuler la participation',
            'Êtes-vous sûr de vouloir annuler cette participation ?',
            'Oui, annuler',
            'danger'
        ).then(function(ok) {
            if (!ok) return;

            fetch('{{ path("user_evenements") }}/participation/' + participId + '/annuler', {
                method: 'POST'
            })
            .then(function(r){ return r.json(); })
            .then(function(d) {
                if (d.success) {
                    location.reload();
                } else {
                    firmaToast(typeof d.error === 'string' ? d.error : 'Erreur lors de l\'annulation', 'error');
                }
            })
            .catch(function() {
                firmaToast('Erreur lors de l\'annulation', 'error');
            });
        });
    };

