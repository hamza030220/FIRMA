    function generateQR(container, text, size) {
        try {
            new QRCode(container, {
                text: text,
                width: size,
                height: size,
                colorDark: '#1a3a24',
                colorLight: '#ffffff',
                correctLevel: QRCode.CorrectLevel.M
            });
        } catch(e) {
            container.innerHTML = '<div style="width:'+size+'px;height:'+size+'px;background:#f4f8f5;display:flex;align-items:center;justify-content:center;border-radius:8px;font-size:11px;color:#8a9a8e;text-align:center">QR indisponible</div>';
        }
    }

    function getTicketUrl(code) {
        return '{{ lanBaseUrl }}' + '/ticket/' + encodeURIComponent(code);
    }

    function buildTicketCard(evt, personName, personLabel, code, ticketType) {
        var card = document.createElement('div');
        card.className = 'tkt-card';
        card.innerHTML =
            '<div class="tkt-header">' +
                '<div class="tkt-event-info">' +
                    '<h3 class="tkt-event-name">' + evt.titre + '</h3>' +
                    (evt.organisateur ? '<p class="tkt-event-org">Par ' + evt.organisateur + '</p>' : '') +
                '</div>' +
                '<span class="tkt-badge">' + ticketType + '</span>' +
            '</div>' +
            '<div class="tkt-body">' +
                '<div class="tkt-details">' +
                    '<p class="tkt-person-label">' + personLabel + '</p>' +
                    '<p class="tkt-person" style="font-size:18px;font-weight:600;margin-bottom:12px">' + personName + '</p>' +
                    '<div class="tkt-detail-row"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> ' + (evt.dateDebut || '') + (evt.dateFin && evt.dateFin !== evt.dateDebut ? ' — ' + evt.dateFin : '') + '</div>' +
                    '<div class="tkt-detail-row"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> ' + (evt.horaireDebut || '') + ' — ' + (evt.horaireFin || '') + '</div>' +
                    '<div class="tkt-detail-row"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg> ' + (evt.lieu || '') + (evt.adresse ? ' — ' + evt.adresse : '') + '</div>' +
                '</div>' +
                '<div class="tkt-qr-box" data-qr="' + getTicketUrl(code) + '"></div>' +
            '</div>' +
            '<div class="tkt-code-box">' +
                '<p class="tkt-code-label">Code ' + ticketType + '</p>' +
                '<p class="tkt-code">' + code + '</p>' +
            '</div>' +
            '<hr class="tkt-divider">' +
            '<div class="tkt-footer">' +
                '<span>FIRMA — Événements & Salons</span>' +
                '<span>Présentez ce ticket à l\'entrée</span>' +
            '</div>';

        return card;
