{% extends 'user/base.html.twig' %}

{% block page_title %}Événements{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/user/evenements.css') }}">
    <style>
    /* ── Ticket styles ── */
    .tkt-page{padding:16px 0}
    .tkt-card{background:#fff;border:2px dashed #1a3a24;border-radius:16px;padding:28px 24px 24px;margin-bottom:20px;position:relative;overflow:hidden}
    .tkt-card::before{content:'';position:absolute;top:0;left:0;right:0;height:8px;background:linear-gradient(90deg,#1a3a24,#2d6b3f,#3e8a52);border-radius:14px 14px 0 0}
    .tkt-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px;gap:16px}
    .tkt-event-info{flex:1}
    .tkt-event-name{font-family:'Playfair Display',Georgia,serif;font-size:20px;font-weight:700;color:#1a3a24;margin:0 0 4px}
    .tkt-event-org{font-size:13px;color:#5a6e5f;margin:0}
    .tkt-badge{background:#1a3a24;color:#fffade;font-size:11px;font-weight:700;padding:4px 12px;border-radius:20px;text-transform:uppercase;letter-spacing:1px;white-space:nowrap}
    .tkt-body{display:flex;gap:24px;align-items:flex-start}
    .tkt-details{flex:1}
    .tkt-detail-row{display:flex;align-items:center;gap:8px;padding:6px 0;font-size:14px;color:#2d2d2d}
    .tkt-detail-row svg{flex-shrink:0;color:#5a6e5f}
    .tkt-detail-label{color:#5a6e5f;min-width:50px}
    .tkt-qr-box{text-align:center;flex-shrink:0}
    .tkt-qr-box canvas{border:3px solid #1a3a24;border-radius:8px;padding:4px;background:#fff}
    .tkt-code-box{margin-top:16px;background:#f4f8f5;border-radius:12px;padding:14px;text-align:center}
    .tkt-code-label{font-size:12px;color:#5a6e5f;text-transform:uppercase;letter-spacing:1px;margin:0 0 4px}
    .tkt-code{font-family:'Courier New',monospace;font-size:24px;font-weight:700;color:#1a3a24;letter-spacing:3px;margin:0}
    .tkt-person{font-size:14px;color:#2d2d2d;margin:0 0 2px}
    .tkt-person-label{font-size:11px;color:#8a9a8e;text-transform:uppercase;letter-spacing:.5px;margin:0 0 4px}
    .tkt-divider{border:none;border-top:1px dashed #c8d6cb;margin:16px 0}
    .tkt-footer{display:flex;justify-content:space-between;align-items:center;font-size:12px;color:#8a9a8e}
    .tkt-section-title{font-size:16px;font-weight:700;color:#1a3a24;margin:24px 0 12px;padding-bottom:8px;border-bottom:2px solid #e8ede9}
    @media print{.tkt-card{break-inside:avoid;page-break-inside:avoid}}

    /* ── Calendar styles ── */
    .cal-toggle{display:flex;background:#f4f8f5;border-radius:10px;padding:3px;gap:2px;width:fit-content}
    .cal-toggle button{border:none;background:transparent;padding:8px 18px;border-radius:8px;font-size:13px;font-weight:600;color:#5a6e5f;cursor:pointer;display:inline-flex;align-items:center;gap:6px;transition:all .2s}
    .cal-toggle button.active{background:#1a3a24;color:#fff;box-shadow:0 2px 8px rgba(26,58,36,.2)}
    .cal-toggle button:not(.active):hover{background:#e8ede9;color:#1a3a24}

    #calendarWrapper{display:none;background:#fff;border-radius:16px;box-shadow:0 4px 20px rgba(26,58,36,.08);padding:24px;margin-top:0}
    #calendarWrapper.visible{display:block}

    /* FullCalendar theme overrides */
    .fc{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif}
    .fc .fc-toolbar-title{font-family:'Playfair Display',Georgia,serif;font-size:22px;font-weight:700;color:#1a3a24}
    .fc .fc-button-primary{background:#1a3a24;border-color:#1a3a24;font-size:13px;font-weight:600;border-radius:8px;padding:6px 14px;text-transform:capitalize}
    .fc .fc-button-primary:hover{background:#2d5a3a;border-color:#2d5a3a}
    .fc .fc-button-primary:disabled{background:#c8d6cb;border-color:#c8d6cb}
    .fc .fc-button-primary:not(:disabled).fc-button-active,
    .fc .fc-button-primary:not(:disabled):active{background:#0d1f14;border-color:#0d1f14;box-shadow:none}
    .fc .fc-daygrid-day.fc-day-today{background:rgba(26,58,36,.06)}
    .fc .fc-daygrid-day-number{color:#2d2d2d;font-weight:500;padding:8px}
    .fc .fc-col-header-cell{background:#f4f8f5;border-color:#e8ede9}
    .fc .fc-col-header-cell-cushion{color:#1a3a24;font-weight:700;font-size:12px;text-transform:uppercase;letter-spacing:.5px;padding:10px 4px}
    .fc .fc-scrollgrid{border-color:#e8ede9;border-radius:12px;overflow:hidden}
    .fc td,.fc th{border-color:#e8ede9}
    .fc .fc-daygrid-event{border-radius:6px;padding:2px 6px;font-size:12px;font-weight:600;border:none;cursor:pointer;transition:transform .15s,box-shadow .15s}
    .fc .fc-daygrid-event:hover{transform:translateY(-1px);box-shadow:0 3px 10px rgba(26,58,36,.2)}
    .fc .fc-event{background:linear-gradient(135deg,#1a3a24,#2d6b3f);color:#fff;border:none}
    .fc .fc-daygrid-dot-event .fc-event-title{font-weight:600}
    .fc .fc-popover{border-radius:12px;box-shadow:0 8px 30px rgba(26,58,36,.15);border:1px solid #e8ede9}
    .fc .fc-popover-header{background:#1a3a24;color:#fff;border-radius:12px 12px 0 0;padding:10px 14px;font-weight:700}
    .fc .fc-more-link{color:#1a3a24;font-weight:700;font-size:12px}
    .fc .fc-daygrid-more-link:hover{background:#f4f8f5;border-radius:4px}

    /* Calendar event tooltip */
    .cal-tooltip{position:absolute;z-index:3000;background:#fff;border-radius:12px;box-shadow:0 8px 30px rgba(26,58,36,.18);padding:16px;min-width:240px;pointer-events:none;animation:calTipIn .15s ease}
    .cal-tooltip__title{font-family:'Playfair Display',Georgia,serif;font-size:16px;font-weight:700;color:#1a3a24;margin:0 0 8px}
    .cal-tooltip__row{display:flex;align-items:center;gap:6px;font-size:13px;color:#5a6e5f;padding:3px 0}
    .cal-tooltip__row svg{flex-shrink:0;width:14px;height:14px}
    .cal-tooltip__code{background:#f4f8f5;border-radius:8px;padding:6px 10px;margin-top:8px;font-family:'Courier New',monospace;font-size:14px;font-weight:700;color:#1a3a24;text-align:center;letter-spacing:2px}
    @keyframes calTipIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}

    /* ── Weather styles ── */
    .evt-weather{padding:.4rem 0;font-size:.85rem;color:#444}
    .evt-weather-loading{display:flex;align-items:center;gap:.5rem;color:#888;font-size:.85rem}
    .evt-weather-spinner{display:inline-block;width:16px;height:16px;border:2px solid #e0e0e0;border-top-color:#1a3a24;border-radius:50%;animation:evtSpin .7s linear infinite}
    @keyframes evtSpin{to{transform:rotate(360deg)}}
    .evt-weather-card{display:flex;align-items:center;gap:1rem;background:#f4f8f5;border:1px solid rgba(26,58,36,.1);border-radius:12px;padding:14px 18px}
    .evt-weather-emoji{font-size:2.2rem;line-height:1}
    .evt-weather-info{flex:1}
    .evt-weather-temp{font-size:1.3rem;font-weight:700;color:#1a3a24;margin:0}
    .evt-weather-desc{font-size:.88rem;color:#555;margin:2px 0 0}
    .evt-weather-range{font-size:.8rem;color:#888;margin:2px 0 0}
    .evt-weather-reliability{font-size:.75rem;color:#aaa;margin-top:4px;font-style:italic}
    .evt-weather-error{color:#888;font-size:.85rem;font-style:italic}
    </style>
{% endblock %}

{% block user_content %}
<div class="evt-page">
    {# ── Header + Search ── #}
    <div class="evt-header">
        <h2>Événements</h2>
        <p>Découvrez les salons, foires et rencontres à venir.</p>
    </div>

    <div class="evt-toolbar">
        <form class="evt-search" method="get" action="{{ path('user_evenements') }}">
            <input type="text" name="q" value="{{ search }}" placeholder="Rechercher par titre, lieu, organisateur…">
            <button type="submit">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </button>
        </form>

        <div class="evt-toolbar-right">
            <button type="button" class="evt-btn evt-btn--outline" id="btnMesParticipations">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                Mes participations
            </button>
            <div class="evt-sort">
                <label>Trier :</label>
                <select onchange="window.location.href='{{ path('user_evenements') }}?q={{ search }}&sort='+this.value">
                    <option value="date_asc" {% if sort == 'date_asc' %}selected{% endif %}>Date ↑</option>
                    <option value="date_desc" {% if sort == 'date_desc' %}selected{% endif %}>Date ↓</option>
                    <option value="titre_asc" {% if sort == 'titre_asc' %}selected{% endif %}>Titre A-Z</option>
                    <option value="places" {% if sort == 'places' %}selected{% endif %}>Places disponibles</option>
                </select>
            </div>
        </div>
    </div>

    {# ── View toggle: Liste / Calendrier ── #}
    <div style="display:flex;align-items:center;justify-content:space-between;margin:16px 0">
        <div class="cal-toggle">
            <button type="button" id="viewList" class="active" onclick="switchView('list')">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                Liste
            </button>
            <button type="button" id="viewCal" onclick="switchView('calendar')">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                Calendrier
            </button>
            <button type="button" id="viewMap" onclick="switchView('map')">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                Carte
            </button>
        </div>
    </div>

    {# ── Flash messages ── #}
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="evt-flash evt-flash--{{ type }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    {# ── Event Cards Grid ── #}
    {% if evenements is empty %}
        <div class="evt-empty">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <p>Aucun événement trouvé.</p>
        </div>
    {% else %}
        <div class="evt-grid">
            {% for evt in evenements %}
                {% include 'user/event/_card.html.twig' with {
                    evt: evt,
                    isParticipating: userParticipations[evt.idEvenement] ?? false
                } %}
            {% endfor %}
        </div>
        {% include 'shared/_pagination.html.twig' with {
            currentPage: currentPage,
            totalPages: totalPages,
            route: 'user_evenements',
            routeParams: { q: search, sort: sort }
        } %}
    {% endif %}

    {# ── Calendar view ── #}
    <div id="calendarWrapper">
        <div id="firmaCalendar"></div>
    </div>

    {# ── Map view ── #}
    <div id="mapWrapper" style="display:none">
        <div class="evt-map-toolbar">
            <button type="button" class="evt-btn evt-btn--outline evt-btn--sm" id="mapLocateMe">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/><line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/><line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/></svg>
                Me localiser
            </button>
            <button type="button" class="evt-btn evt-btn--outline evt-btn--sm" id="mapSortProximity" style="display:none">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 21 12 17.27 5.82 21 7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                Trier par proximité
            </button>
            <div class="evt-map-progress" id="mapProgress" style="display:none">
                <span class="evt-weather-spinner"></span>
                <span id="mapProgressText">Géocodage...</span>
            </div>
        </div>
        <div id="firmaMap" style="height:550px;border-radius:12px;z-index:1"></div>
        <div id="mapEventsList" class="evt-map-events-list"></div>
    </div>
</div>

{# ═══════════════════════════════════════════════
   MODAL — EVENT DETAIL
   ═══════════════════════════════════════════════ #}
<div class="evt-modal-overlay" id="evtDetailModal" style="display:none">
    <div class="evt-modal evt-modal--lg">
        <button type="button" class="evt-modal__close" id="evtDetailClose">&times;</button>

        {# Hero #}
        <div class="evt-modal__hero">
            <div class="evt-modal__hero-img" id="mdImg"></div>
            <div class="evt-modal__hero-info">
                <div class="evt-modal__badges">
                    <span class="evt-badge" id="mdStatut"></span>
                    <span class="evt-type" id="mdType"></span>
                </div>
                <h2 id="mdTitre"></h2>
                <p class="evt-modal__org" id="mdOrg"></p>
            </div>
        </div>

        {# Body #}
        <div class="evt-modal__body">
            <div class="evt-modal__grid">
                {# Left — Description + Sponsors #}
                <div class="evt-modal__main">
                    <div class="evt-modal__section" id="mdDescWrap">
                        <h3>Description</h3>
                        <p id="mdDesc"></p>
                    </div>
                    <div class="evt-modal__section" id="mdSponsorsWrap" style="display:none">
                        <h3>Sponsors</h3>
                        <div class="evt-sponsors" id="mdSponsors"></div>
                    </div>
                    <div class="evt-modal__section" id="mdWeatherCard">
                        <h3>
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:text-bottom;margin-right:6px"><path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/><circle cx="12" cy="12" r="5"/></svg>Météo de l'événement
                        </h3>
                        <div class="evt-weather" id="mdWeather">
                            <div class="evt-weather-loading">
                                <span class="evt-weather-spinner"></span> Chargement de la météo…
                            </div>
                        </div>
                    </div>
                </div>

                {# Right — Info cards #}
                <div class="evt-modal__sidebar">
                    <div class="evt-info-card">
                        <h4>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                            Date & Horaire
                        </h4>
                        <p id="mdDate"></p>
                        <p id="mdHoraire"></p>
                    </div>
                    <div class="evt-info-card" id="mdLieuCard" style="display:none">
                        <h4>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            Lieu
                        </h4>
                        <p id="mdLieu"></p>
                        <p id="mdAdresse" class="evt-text-muted"></p>
                        <a href="#" id="mdMapsLink" class="evt-link" target="_blank" rel="noopener" style="display:none">Voir sur Google Maps →</a>
                    </div>
                    <div class="evt-info-card">
                        <h4>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                            Places
                        </h4>
                        <div class="evt-gauge-bar" style="margin-bottom:.5rem">
                            <div class="evt-gauge-fill" id="mdGauge" style="width:0%"></div>
                        </div>
                        <p id="mdPlaces"></p>
                        <p class="evt-text-muted" id="mdConfirmed"></p>
                    </div>
                    <div class="evt-info-card" id="mdContactCard" style="display:none">
                        <h4>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                            Contact
                        </h4>
                        <p id="mdEmail"></p>
                        <p id="mdTel"></p>
                    </div>

                    {# Participation status or participate button #}
                    <div id="mdParticipWrap"></div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ═══════════════════════════════════════════════
   MODAL — PARTICIPER
   ═══════════════════════════════════════════════ #}
<div class="evt-modal-overlay" id="evtParticipModal" style="display:none">
    <div class="evt-modal evt-modal--sm">
        <button type="button" class="evt-modal__close" id="evtParticipClose">&times;</button>
        <h2 class="evt-modal__title">Participer à l'événement</h2>
        <p class="evt-modal__subtitle" id="participEvtTitre"></p>

        <form id="participForm" class="evt-form" novalidate>
            <input type="hidden" id="participEvtId">
            <input type="hidden" id="participMode" value="create">
            <input type="hidden" id="participId">
            <div class="evt-form__row" style="display:flex;gap:12px">
                <div class="evt-form__group" style="flex:1">
                    <label>Prénom</label>
                    <input type="text" id="participPrenom" class="evt-form__input" value="{{ app.user.prenom }}" readonly style="background:#f4f8f5;color:#5a6e5f">
                </div>
                <div class="evt-form__group" style="flex:1">
                    <label>Nom</label>
                    <input type="text" id="participNom" class="evt-form__input" value="{{ app.user.nom }}" readonly style="background:#f4f8f5;color:#5a6e5f">
                </div>
            </div>
            <div class="evt-form__group">
                <label>Nombre d'accompagnants</label>
                <input type="text" id="participNbAccomp" value="0" class="evt-form__input">
            </div>

            {# Dynamic accompagnant name fields #}
            <div id="accompFields" class="evt-accomp-fields"></div>

            <div class="evt-form__group">
                <label>Commentaire (optionnel)</label>
                <textarea id="participComment" rows="3" class="evt-form__input" placeholder="Un message pour l'organisateur…"></textarea>
            </div>
            <div id="participMsg" class="evt-form__msg" style="display:none"></div>
            <div class="evt-form__actions">
                <button type="button" class="evt-btn evt-btn--outline" id="participCancel">Annuler</button>
                <button type="submit" class="evt-btn evt-btn--success" id="participSubmit">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    Confirmer l'inscription
                </button>
            </div>
        </form>
    </div>
</div>

{# ═══════════════════════════════════════════════
   MODAL — MES PARTICIPATIONS
   ═══════════════════════════════════════════════ #}
<div class="evt-modal-overlay" id="evtMesParticipModal" style="display:none">
    <div class="evt-modal evt-modal--lg">
        <button type="button" class="evt-modal__close" id="mesParticipClose">&times;</button>
        <h2 class="evt-modal__title">Mes participations</h2>
        <div id="mesParticipContent" class="evt-particip-list">
            <div class="evt-loading">Chargement…</div>
        </div>
    </div>
</div>

{# ═══════════════════════════════════════════════
   MODAL — TICKETS
   ═══════════════════════════════════════════════ #}
<div class="evt-modal-overlay" id="evtTicketModal" style="display:none">
    <div class="evt-modal evt-modal--lg" style="display:flex;flex-direction:column">
        {# ── Sticky header bar ── #}
        <div style="position:sticky;top:0;z-index:10;background:#fff;border-bottom:2px solid #e8ede9;border-radius:16px 16px 0 0;padding:16px 24px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-shrink:0">
            <h2 style="margin:0;font-family:'Playfair Display',Georgia,serif;font-size:22px;font-weight:700;color:#1a3a24">Mes tickets</h2>
            <div style="display:flex;align-items:center;gap:10px">
                <button type="button" id="ticketExportPdf" style="display:inline-flex;align-items:center;gap:8px;background:linear-gradient(135deg,#1a3a24,#2d5a3a);color:#fff;border:none;padding:10px 20px;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;transition:opacity .2s;box-shadow:0 2px 8px rgba(26,58,36,.25)">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    Exporter en PDF
                </button>
                <button type="button" id="ticketModalClose" style="background:#f4f8f5;border:1px solid #d4ddd6;width:36px;height:36px;border-radius:50%;font-size:1.3rem;color:#1a3a24;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .15s">&times;</button>
            </div>
        </div>
        {# ── Scrollable ticket content ── #}
        <div id="ticketContent" style="padding:24px;overflow-y:auto;flex:1"></div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@fullcalendar/core@6.1.11/locales/fr.global.min.js"></script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script>
document.addEventListener('DOMContentLoaded', function() {

    // ═══════════════════════════════
    // Helper: open / close modal
    // ═══════════════════════════════
    function openModal(el)  { el.style.display = 'flex'; document.body.style.overflow = 'hidden'; }
    function closeModal(el) { el.style.display = 'none'; document.body.style.overflow = ''; }

    // Close modals on overlay click
    document.querySelectorAll('.evt-modal-overlay').forEach(function(ov) {
        ov.addEventListener('click', function(e) {
            if (e.target === ov) closeModal(ov);
        });
    });

    // ═══════════════════════════════
    // EVENT DETAIL MODAL
    // ═══════════════════════════════
    var detailModal = document.getElementById('evtDetailModal');
    document.getElementById('evtDetailClose').addEventListener('click', function(){ closeModal(detailModal); });

    var currentEvtData = null;

    // ═══════════════════════════════
    // Weather (Open-Meteo)
    // ═══════════════════════════════
    var WMO_DESC = {0:'Ciel dégagé',1:'Peu nuageux',2:'Partiellement nuageux',3:'Couvert',45:'Brouillard',48:'Brouillard givrant',51:'Bruine légère',53:'Bruine',55:'Bruine forte',56:'Bruine verglaçante légère',57:'Bruine verglaçante',61:'Pluie légère',63:'Pluie modérée',65:'Pluie forte',66:'Pluie verglaçante légère',67:'Pluie verglaçante forte',71:'Neige légère',73:'Neige modérée',75:'Neige forte',77:'Grains de neige',80:'Averses légères',81:'Averses modérées',82:'Averses violentes',85:'Averses de neige légères',86:'Averses de neige fortes',95:'Orage',96:'Orage avec grêle légère',99:'Orage avec grêle forte'};
    var WMO_EMOJI = {0:'☀️',1:'🌤️',2:'⛅',3:'☁️',45:'🌫️',48:'🌫️',51:'🌦️',53:'🌦️',55:'🌧️',56:'🌧️',57:'🌧️',61:'🌧️',63:'🌧️',65:'🌧️',66:'🧊',67:'🧊',71:'🌨️',73:'🌨️',75:'❄️',77:'❄️',80:'🌦️',81:'🌧️',82:'⛈️',85:'🌨️',86:'❄️',95:'⛈️',96:'⛈️',99:'⛈️'};

    function extractCity(lieu, adresse) {
        // Prefer adresse (structured: "..., 2015 Tunis") then lieu
        var sources = [adresse, lieu];
        for (var i = 0; i < sources.length; i++) {
            if (!sources[i]) continue;
            var parts = sources[i].split(',');
            var last = parts[parts.length - 1].trim();
            // Strip postal code (4-5 digits) e.g. "2015 Tunis" → "Tunis"
            var cleaned = last.replace(/^\d{4,5}\s*/, '').trim();
            if (cleaned.length >= 2) return cleaned;
        }
        return null;
    }

    function getReliabilityText(daysAhead) {
        if (daysAhead <= 2)  return 'Prévision très fiable';
        if (daysAhead <= 5)  return 'Prévision fiable';
        if (daysAhead <= 10) return 'Prévision indicative';
        return 'Tendance générale';
    }

    function buildWeatherCard(code, tMin, tMax, label, cityName) {
        var emoji = WMO_EMOJI[code] || '🌡️';
        var desc  = WMO_DESC[code]  || 'Données météo';
        return '<div class="evt-weather-card">'
            + '<div class="evt-weather-emoji">' + emoji + '</div>'
            + '<div class="evt-weather-info">'
            + '<p class="evt-weather-temp">' + Math.round(tMin) + '° / ' + Math.round(tMax) + '°C</p>'
            + '<p class="evt-weather-desc">' + desc + '</p>'
            + '<p class="evt-weather-range">' + (cityName ? cityName + ' — ' : '') + label + '</p>'
            + '</div></div>';
    }

    function loadWeatherForecast(lat, lon, cityName, dateStr, el) {
        fetch('https://api.open-meteo.com/v1/forecast?latitude='+lat+'&longitude='+lon+'&daily=weathercode,temperature_2m_max,temperature_2m_min&timezone=auto&start_date='+dateStr+'&end_date='+dateStr)
        .then(function(r){return r.json()}).then(function(j){
            if (!j.daily || !j.daily.weathercode) { el.innerHTML='<span class="evt-weather-error">Pas de données météo.</span>'; return; }
            var diff = Math.round((new Date(dateStr)-new Date())/(864e5));
            el.innerHTML = buildWeatherCard(j.daily.weathercode[0], j.daily.temperature_2m_min[0], j.daily.temperature_2m_max[0], getReliabilityText(diff), cityName);
        }).catch(function(){ el.innerHTML='<span class="evt-weather-error">Météo indisponible.</span>'; });
    }

    function loadWeatherArchive(lat, lon, cityName, dateStr, el) {
        fetch('https://archive-api.open-meteo.com/v1/archive?latitude='+lat+'&longitude='+lon+'&daily=weathercode,temperature_2m_max,temperature_2m_min&timezone=auto&start_date='+dateStr+'&end_date='+dateStr)
        .then(function(r){return r.json()}).then(function(j){
            if (!j.daily || !j.daily.weathercode) { el.innerHTML='<span class="evt-weather-error">Pas de données météo.</span>'; return; }
            el.innerHTML = buildWeatherCard(j.daily.weathercode[0], j.daily.temperature_2m_min[0], j.daily.temperature_2m_max[0], 'Météo enregistrée', cityName);
        }).catch(function(){ el.innerHTML='<span class="evt-weather-error">Météo indisponible.</span>'; });
    }

    function loadWeatherHistoricalAvg(lat, lon, cityName, dateStr, el) {
        var d = new Date(dateStr);
        var lastYear = (d.getFullYear()-1)+'-'+(('0'+(d.getMonth()+1)).slice(-2))+'-'+(('0'+d.getDate()).slice(-2));
        fetch('https://archive-api.open-meteo.com/v1/archive?latitude='+lat+'&longitude='+lon+'&daily=weathercode,temperature_2m_max,temperature_2m_min&timezone=auto&start_date='+lastYear+'&end_date='+lastYear)
        .then(function(r){return r.json()}).then(function(j){
            if (!j.daily || !j.daily.weathercode) { el.innerHTML='<span class="evt-weather-error">Pas de données météo.</span>'; return; }
            el.innerHTML = buildWeatherCard(j.daily.weathercode[0], j.daily.temperature_2m_min[0], j.daily.temperature_2m_max[0], 'Moyenne historique (même date l\'an dernier)', cityName)
                + '<p class="evt-weather-reliability">Estimation basée sur l\'historique</p>';
        }).catch(function(){ el.innerHTML='<span class="evt-weather-error">Météo indisponible.</span>'; });
    }

    function loadWeather(lieu, adresse, dateDebutRaw) {
        var el = document.getElementById('mdWeather');
        if (!el) return;
        el.innerHTML = '<div class="evt-weather-loading"><span class="evt-weather-spinner"></span> Chargement de la météo…</div>';
        var city = extractCity(lieu, adresse);
        if (!city || !dateDebutRaw) { el.innerHTML = '<span class="evt-weather-error">Lieu ou date manquant.</span>'; return; }
        fetch('https://geocoding-api.open-meteo.com/v1/search?name='+encodeURIComponent(city)+'&count=1&language=fr')
        .then(function(r){return r.json()}).then(function(geo){
            if (!geo.results || !geo.results.length) { el.innerHTML='<span class="evt-weather-error">Ville introuvable pour la météo.</span>'; return; }
            var lat = geo.results[0].latitude, lon = geo.results[0].longitude;
            var cityName = geo.results[0].name;
            var diff = Math.round((new Date(dateDebutRaw) - new Date()) / 864e5);
            if (diff < 0) { loadWeatherArchive(lat, lon, cityName, dateDebutRaw, el); }
            else if (diff <= 15) { loadWeatherForecast(lat, lon, cityName, dateDebutRaw, el); }
            else { loadWeatherHistoricalAvg(lat, lon, cityName, dateDebutRaw, el); }
        }).catch(function(){ el.innerHTML='<span class="evt-weather-error">Météo indisponible.</span>'; });
    }

    // Reusable: load event detail by ID and show modal
    window.openEventDetail = function(id) {
        openModal(detailModal);
        document.getElementById('mdImg').style.backgroundImage = '';
        document.getElementById('mdTitre').textContent = 'Chargement…';
        document.getElementById('mdDesc').textContent = '';
        document.getElementById('mdParticipWrap').innerHTML = '';

        fetch('{{ path("user_evenements") }}/' + id + '/json')
            .then(function(r){ return r.json(); })
            .then(function(d){
                currentEvtData = d;

                    // Hero
                    if (d.imageUrl) {
                        document.getElementById('mdImg').style.backgroundImage = 'url(' + d.imageUrl + ')';
                    } else {
                        document.getElementById('mdImg').style.backgroundImage = '';
                    }
                    document.getElementById('mdTitre').textContent = d.titre;
                    document.getElementById('mdOrg').textContent = 'Par ' + (d.organisateur || '—');

                    var badgeEl = document.getElementById('mdStatut');
                    badgeEl.textContent = d.statut || '';
                    badgeEl.className = 'evt-badge ' + (d.statutBadge || '');

                    var typeEl = document.getElementById('mdType');
                    typeEl.textContent = d.type || '';
                    typeEl.style.display = d.type ? '' : 'none';

                    // Description
                    var descWrap = document.getElementById('mdDescWrap');
                    if (d.description) {
                        document.getElementById('mdDesc').innerHTML = d.description.replace(/\n/g, '<br>');
                        descWrap.style.display = '';
                    } else {
                        descWrap.style.display = 'none';
                    }

                    // Sponsors
                    var spWrap = document.getElementById('mdSponsorsWrap');
                    var spContainer = document.getElementById('mdSponsors');
                    spContainer.innerHTML = '';
                    if (d.sponsors && d.sponsors.length) {
                        d.sponsors.forEach(function(s) {
                            var div = document.createElement('div');
                            div.className = 'evt-sponsor';
                            var imgHtml = s.logoUrl
                                ? '<img src="' + s.logoUrl + '" alt="' + s.nom + '">'
                                : '<div class="evt-sponsor__icon">' + s.nom.charAt(0) + '</div>';
                            div.innerHTML = imgHtml + '<div><strong>' + s.nom + '</strong>'
                                + (s.secteur ? '<small>' + s.secteur + '</small>' : '') + '</div>';
                            spContainer.appendChild(div);
                        });
                        spWrap.style.display = '';
                    } else {
                        spWrap.style.display = 'none';
                    }

                    // Date
                    var dateText = d.dateDebut || '';
                    if (d.dateFin && d.dateFin !== d.dateDebut) dateText += ' – ' + d.dateFin;
                    document.getElementById('mdDate').textContent = dateText;
                    document.getElementById('mdHoraire').textContent = (d.horaireDebut || '') + ' – ' + (d.horaireFin || '');

                    // Lieu
                    var lieuCard = document.getElementById('mdLieuCard');
                    if (d.lieu || d.adresse) {
                        document.getElementById('mdLieu').textContent = d.lieu || '';
                        document.getElementById('mdAdresse').textContent = d.adresse || '';
                        var mapsLink = document.getElementById('mdMapsLink');
                        if (d.googleMapsUrl) { mapsLink.href = d.googleMapsUrl; mapsLink.style.display = ''; }
                        else { mapsLink.style.display = 'none'; }
                        lieuCard.style.display = '';
                    } else {
                        lieuCard.style.display = 'none';
                    }

                    // Places
                    var gauge = document.getElementById('mdGauge');
                    gauge.style.width = d.pctRemplissage + '%';
                    gauge.className = 'evt-gauge-fill' +
                        (d.pctRemplissage >= 90 ? ' gauge-danger' : d.pctRemplissage >= 70 ? ' gauge-warning' : '');
                    document.getElementById('mdPlaces').textContent = d.placesDisponibles + ' places disponibles sur ' + d.capaciteMax;
                    document.getElementById('mdConfirmed').textContent = d.confirmedCount + ' participant' + (d.confirmedCount > 1 ? 's' : '') + ' confirmé' + (d.confirmedCount > 1 ? 's' : '');

                    // Contact
                    var contactCard = document.getElementById('mdContactCard');
                    if (d.contactEmail || d.contactTel) {
                        document.getElementById('mdEmail').innerHTML = d.contactEmail ? '<a href="mailto:' + d.contactEmail + '">' + d.contactEmail + '</a>' : '';
                        document.getElementById('mdTel').textContent = d.contactTel || '';
                        contactCard.style.display = '';
                    } else {
                        contactCard.style.display = 'none';
                    }

                    // Weather
                    loadWeather(d.lieu, d.adresse, d.dateDebutRaw);

                    // Participation status or button
                    var pw = document.getElementById('mdParticipWrap');
                    pw.innerHTML = '';
                    if (d.participation) {
                        var accHtml = '';
                        if (d.participation.accompagnantsList && d.participation.accompagnantsList.length) {
                            accHtml = '<div style="margin-top:.4rem"><p class="evt-text-muted" style="margin-bottom:.25rem"><strong>Accompagnants :</strong></p>';
                            d.participation.accompagnantsList.forEach(function(a, i) {
                                accHtml += '<p class="evt-text-muted" style="padding-left:.5rem">' + (i+1) + '. ' + a.prenom + ' ' + a.nom + '</p>';
                            });
                            accHtml += '</div>';
                        } else {
                            accHtml = '<p class="evt-text-muted">Accompagnants : ' + d.participation.accompagnants + '</p>';
                        }

                        var statutLabel = d.participation.statut === 'confirme'
                            ? '<span class="evt-badge badge-success" style="font-size:13px">✅ Confirmé</span>'
                            : '<span class="evt-badge badge-warning" style="font-size:13px">⏳ En attente de confirmation</span>';

                        var codeHtml = d.participation.code
                            ? '<p class="evt-text-muted">Code : <strong>' + d.participation.code + '</strong></p>'
                            : '<p class="evt-text-muted" style="font-style:italic;color:#b58a00">📧 Vérifiez vos emails pour confirmer et recevoir votre code</p>';

                        pw.innerHTML = '<div class="evt-info-card evt-info-card--enrolled">'
                            + '<p><strong>Vous êtes inscrit(e)</strong></p>'
                            + statutLabel
                            + codeHtml
                            + accHtml
                            + '<button type="button" class="evt-btn evt-btn--danger evt-btn--sm" style="margin-top:.5rem" onclick="annulerParticipation(' + d.participation.id + ')">Annuler ma participation</button>'
                            + '</div>';
                    } else if (d.placesDisponibles > 0 && d.statutRaw === 'actif') {
                        pw.innerHTML = '<button type="button" class="evt-btn evt-btn--success evt-btn--full" onclick="ouvrirParticipForm(' + d.id + ', \'' + d.titre.replace(/'/g, "\\'") + '\')">Participer</button>';
                    } else if (d.placesDisponibles <= 0) {
                        pw.innerHTML = '<div class="evt-info-card" style="text-align:center;color:#c0392b"><strong>Complet</strong></div>';
                    }
                });
    };

    // Bind card buttons to openEventDetail
    document.querySelectorAll('.evt-detail-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            window.openEventDetail(this.getAttribute('data-id'));
        });
    });

    // ═══════════════════════════════
    // PARTICIPER MODAL
    // ═══════════════════════════════
    var participModal = document.getElementById('evtParticipModal');
    document.getElementById('evtParticipClose').addEventListener('click', function(){ closeModal(participModal); });
    document.getElementById('participCancel').addEventListener('click', function(){ closeModal(participModal); });

    // Build accompagnant fields dynamically — preserves existing values
    function renderAccompFields(n) {
        var container = document.getElementById('accompFields');
        var existing = container.querySelectorAll('.evt-accomp-row');

        // Collect current values
        var saved = [];
        existing.forEach(function(row) {
            var inputs = row.querySelectorAll('input');
            saved.push({ prenom: inputs[0].value, nom: inputs[1].value });
        });

        // Remove extra rows if n < current count
        while (existing.length > n) {
            container.removeChild(existing[existing.length - 1]);
            existing = container.querySelectorAll('.evt-accomp-row');
        }

        // Add missing rows if n > current count
        for (var i = existing.length; i < n; i++) {
            var row = document.createElement('div');
            row.className = 'evt-accomp-row';
            row.innerHTML =
                '<span class="evt-accomp-label">Accompagnant ' + (i + 1) + '</span>' +
                '<div class="evt-accomp-inputs">' +
                    '<input type="text" name="accomp_prenom[]" placeholder="Prénom" class="evt-form__input">' +
                    '<input type="text" name="accomp_nom[]" placeholder="Nom" class="evt-form__input">' +
                '</div>';
            // Restore saved value if it existed at this index
            if (saved[i]) {
                var inputs = row.querySelectorAll('input');
                inputs[0].value = saved[i].prenom;
                inputs[1].value = saved[i].nom;
            }
            container.appendChild(row);
        }
    }

    document.getElementById('participNbAccomp').addEventListener('input', function() {
        renderAccompFields(parseInt(this.value) || 0);
    });

    window.ouvrirParticipForm = function(evtId, titre) {
        closeModal(detailModal);
        document.getElementById('participEvtId').value = evtId;
        document.getElementById('participEvtTitre').textContent = titre;
        document.getElementById('participMode').value = 'create';
        document.getElementById('participId').value = '';
        document.getElementById('participNbAccomp').value = 0;
        document.getElementById('participComment').value = '';
        document.getElementById('participMsg').style.display = 'none';
        document.getElementById('accompFields').innerHTML = '';
        document.getElementById('participSubmit').innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Confirmer l\'inscription';
        openModal(participModal);
    };

    window.ouvrirModifierForm = function(participId, titre, nbAccomp, accompListJson, commentaire) {
        closeModal(mesParticipModal);
        document.getElementById('participEvtId').value = '';
        document.getElementById('participEvtTitre').textContent = titre;
        document.getElementById('participMode').value = 'edit';
        document.getElementById('participId').value = participId;
        document.getElementById('participNbAccomp').value = nbAccomp;
        document.getElementById('participComment').value = commentaire || '';
        document.getElementById('participMsg').style.display = 'none';
        document.getElementById('participSubmit').innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Enregistrer les modifications';
        renderAccompFields(nbAccomp);
        try {
            var accompList = JSON.parse(accompListJson);
            if (accompList && accompList.length) {
                var rows = document.querySelectorAll('#accompFields .evt-accomp-row');
                accompList.forEach(function(a, i) {
                    if (rows[i]) {
                        var inputs = rows[i].querySelectorAll('input');
                        inputs[0].value = a.prenom || '';
                        inputs[1].value = a.nom || '';
                    }
                });
            }
        } catch(e) {}
        openModal(participModal);
    };

    // Also handle card "Participer" buttons
    document.querySelectorAll('.evt-participer-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var id = this.getAttribute('data-id');
            var title = this.closest('.evt-card').querySelector('.evt-card__title').textContent;
            window.ouvrirParticipForm(id, title);
        });
    });

    document.getElementById('participForm').addEventListener('submit', function(e) {
        e.preventDefault();
        var evtId = document.getElementById('participEvtId').value;
        var btn = document.getElementById('participSubmit');
        var msgDiv = document.getElementById('participMsg');
        btn.disabled = true;
        btn.textContent = '…';

        var fd = new FormData();
        fd.append('nb_accompagnants', document.getElementById('participNbAccomp').value);
        fd.append('commentaire', document.getElementById('participComment').value);

        // Accompagnant names
        document.querySelectorAll('#accompFields .evt-accomp-row').forEach(function(row) {
            var inputs = row.querySelectorAll('input');
            fd.append('accomp_prenom[]', inputs[0].value);
            fd.append('accomp_nom[]', inputs[1].value);
        });

        var mode = document.getElementById('participMode').value;
        var url;
        if (mode === 'edit') {
            var participId = document.getElementById('participId').value;
            url = '{{ path("user_evenements") }}/participation/' + participId + '/modifier';
        } else {
            url = '{{ path("user_evenements") }}/' + evtId + '/participer';
        }

        fetch(url, {
            method: 'POST',
            body: fd
        })
        .then(function(r){ return r.json().then(function(d){ return {ok:r.ok, data:d}; }); })
        .then(function(res) {
            msgDiv.style.display = 'block';
            if (res.ok) {
                msgDiv.className = 'evt-form__msg evt-form__msg--success';
                if (mode === 'edit') {
                    msgDiv.innerHTML = '<div class="evt-email-alert">' +
                        '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#20452c" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>' +
                        '<div><strong>' + res.data.message + '</strong></div>' +
                        '</div>';
                } else {
                    msgDiv.innerHTML = '<div class="evt-email-alert">' +
                        '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#20452c" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>' +
                        '<div><strong>Email envoyé !</strong><br><span style="font-size:13px;color:#5a6e5f">' + res.data.message + '</span></div>' +
                        '</div>';
                }
                setTimeout(function(){ location.reload(); }, 3000);
            } else {
                msgDiv.className = 'evt-form__msg evt-form__msg--error';
                msgDiv.textContent = res.data.error || 'Erreur inconnue';
                btn.disabled = false;
                btn.textContent = 'Confirmer l\'inscription';
            }
        })
        .catch(function() {
            msgDiv.style.display = 'block';
            msgDiv.className = 'evt-form__msg evt-form__msg--error';
            msgDiv.textContent = 'Erreur réseau';
            btn.disabled = false;
            btn.textContent = 'Confirmer l\'inscription';
