        var calBtn = document.getElementById('viewCal');
        var mapBtn = document.getElementById('viewMap');
        var gridSection = document.querySelector('.evt-grid') || document.querySelector('.evt-empty');
        var calWrapper = document.getElementById('calendarWrapper');
        var mapWrapper = document.getElementById('mapWrapper');

        // Reset all
        listBtn.classList.remove('active');
        calBtn.classList.remove('active');
        mapBtn.classList.remove('active');
        if (gridSection) gridSection.style.display = 'none';
