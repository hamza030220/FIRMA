{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe — FIRMA{% endblock %}

{% block body %}
<div class="login-page">
  <div class="login-bg-pattern"></div>
  <div class="login-orb login-orb-1"></div>
  <div class="login-orb login-orb-2"></div>
  <div class="login-orb login-orb-3"></div>

  <div class="login-brand-panel">
    <div class="brand-content">
      <a href="{{ path('app_landing') }}" class="brand-logo">
        <img src="{{ asset('image/logofirma.jpg') }}" alt="FIRMA" class="brand-logo-img">
        <span class="brand-logo-text">FIRMA</span>
      </a>
      <div class="brand-hero">
        <div class="brand-circle"></div>
        <div class="brand-circle brand-circle-2"></div>
        <h1 class="brand-title">
          <span class="brand-word bw1">Nouveau</span>
          <em><span class="brand-word bw2">mot de passe</span></em>
        </h1>
        <p class="brand-tagline">Choisissez un mot de passe fort<br><strong>d'au moins 8 caractères.</strong></p>
      </div>
      <div class="brand-features">
        <div class="brand-feature"><div class="bf-icon">🔐</div><span>Chiffré</span></div>
        <div class="brand-feature"><div class="bf-icon">✅</div><span>Sécurisé</span></div>
        <div class="brand-feature"><div class="bf-icon">🚀</div><span>Instantané</span></div>
      </div>
    </div>
  </div>

  <div class="login-form-panel">
    <div class="login-form-wrapper">
      <div class="login-mobile-logo">
        <img src="{{ asset('image/logofirma.jpg') }}" alt="FIRMA" class="mobile-logo-img">
      </div>

      <div class="login-header">
        <h2 class="login-title">Nouveau mot de passe</h2>
        <p class="login-subtitle">Choisissez votre nouveau mot de passe.</p>
      </div>

      {% if error %}
        <div class="login-alert">
          <svg viewBox="0 0 20 20" fill="none" class="alert-icon">
            <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
            <path d="M10 6v5M10 13.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span>{{ error }}</span>
        </div>
      {% endif %}

      <form method="post" class="login-form" novalidate>
        <div class="form-group">
          <label for="input-password" class="form-label">Nouveau mot de passe</label>
          <div class="input-wrapper">
            <svg viewBox="0 0 20 20" fill="none" class="input-icon">
              <rect x="3" y="9" width="14" height="9" rx="2" stroke="currentColor" stroke-width="1.4"/>
              <path d="M6 9V6a4 4 0 118 0v3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              <circle cx="10" cy="13.5" r="1.5" fill="currentColor"/>
            </svg>
            <input type="password" id="input-password" name="password"
                   class="form-input" placeholder="••••••••" required autofocus minlength="8">
            <button type="button" class="toggle-password" onclick="togglePass('input-password','eye1')" aria-label="Afficher">
              <svg viewBox="0 0 20 20" fill="none" class="eye-icon" id="eye1">
                <path d="M1 10s3.5-6 9-6 9 6 9 6-3.5 6-9 6-9-6-9-6z" stroke="currentColor" stroke-width="1.3"/>
                <circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1.3"/>
              </svg>
            </button>
          </div>
        </div>

        <div class="form-group">
          <label for="input-confirm" class="form-label">Confirmer le mot de passe</label>
          <div class="input-wrapper">
            <svg viewBox="0 0 20 20" fill="none" class="input-icon">
              <rect x="3" y="9" width="14" height="9" rx="2" stroke="currentColor" stroke-width="1.4"/>
              <path d="M6 9V6a4 4 0 118 0v3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              <circle cx="10" cy="13.5" r="1.5" fill="currentColor"/>
            </svg>
            <input type="password" id="input-confirm" name="password_confirm"
                   class="form-input" placeholder="••••••••" required minlength="8">
            <button type="button" class="toggle-password" onclick="togglePass('input-confirm','eye2')" aria-label="Afficher">
              <svg viewBox="0 0 20 20" fill="none" class="eye-icon" id="eye2">
                <path d="M1 10s3.5-6 9-6 9 6 9 6-3.5 6-9 6-9-6-9-6z" stroke="currentColor" stroke-width="1.3"/>
                <circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1.3"/>
              </svg>
            </button>
          </div>
        </div>

        <button type="submit" class="login-btn">
          <span class="btn-text">Réinitialiser le mot de passe</span>
          <svg viewBox="0 0 20 20" fill="none" class="btn-arrow">
            <path d="M4 10h12m-4-4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </form>

      <a href="{{ path('app_landing') }}" class="back-home">← Retour à l'accueil</a>
    </div>
  </div>
</div>

<script>
function togglePass(inputId, iconId) {
  const input = document.getElementById(inputId);
  const icon  = document.getElementById(iconId);
  if (input.type === 'password') {
    input.type = 'text';
    icon.innerHTML = '<path d="M1 10s3.5-6 9-6 9 6 9 6-3.5 6-9 6-9-6-9-6z" stroke="currentColor" stroke-width="1.3"/><circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1.3"/><line x1="3" y1="3" x2="17" y2="17" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>';
  } else {
    input.type = 'password';
    icon.innerHTML = '<path d="M1 10s3.5-6 9-6 9 6 9 6-3.5 6-9 6-9-6-9-6z" stroke="currentColor" stroke-width="1.3"/><circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1.3"/>';
  }
}
</script>
{% endblock %}
