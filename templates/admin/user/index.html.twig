{% extends 'admin/base.html.twig' %}

{% block page_title %}Gestion des Utilisateurs{% endblock %}
{% block admin_page_title %}Gestion des Utilisateurs{% endblock %}

{% block admin_content %}
<div class="user-mgmt">

  {# ── Flash messages ── #}
  {% for msg in app.flashes('success') %}
    <div class="user-flash user-flash--success">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
      {{ msg }}
    </div>
  {% endfor %}
  {% for msg in app.flashes('error') %}
    <div class="user-flash user-flash--error">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      {{ msg }}
    </div>
  {% endfor %}

  {# ── Statistiques ── #}
  <div class="user-stats">
    <div class="user-stat-card">
      <div class="user-stat-icon" style="background:#dcfce7;color:#166534">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </div>
      <div>
        <div class="user-stat-value">{{ stats.client + stats.technicien + stats.admin }}</div>
        <div class="user-stat-label">Total</div>
      </div>
    </div>
    <div class="user-stat-card">
      <div class="user-stat-icon" style="background:#dcfce7;color:#166534">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </div>
      <div>
        <div class="user-stat-value">{{ stats.client }}</div>
        <div class="user-stat-label">Utilisateurs</div>
      </div>
    </div>
    <div class="user-stat-card">
      <div class="user-stat-icon" style="background:#dbeafe;color:#1e40af">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
      </div>
      <div>
        <div class="user-stat-value">{{ stats.technicien }}</div>
        <div class="user-stat-label">Techniciens</div>
      </div>
    </div>
    <div class="user-stat-card">
      <div class="user-stat-icon" style="background:#fef3c7;color:#92400e">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
      </div>
      <div>
        <div class="user-stat-value">{{ stats.admin }}</div>
        <div class="user-stat-label">Admins</div>
      </div>
    </div>
  </div>

  {# ── Barre de recherche et filtres ── #}
  <div class="user-toolbar">
    <form method="get" action="{{ path('admin_utilisateurs') }}" class="user-search-form">
      <div class="user-search-wrap">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="search-ico"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" name="q" value="{{ keyword }}" placeholder="Rechercher par nom, email, ville…" class="user-search-input">
      </div>
      <select name="role" class="user-role-select" onchange="this.form.submit()">
        <option value="" {% if role == '' %}selected{% endif %}>Tous les rôles</option>
        <option value="client"     {% if role == 'client'     %}selected{% endif %}>Utilisateur</option>
        <option value="technicien" {% if role == 'technicien' %}selected{% endif %}>Technicien</option>
        <option value="admin"      {% if role == 'admin'      %}selected{% endif %}>Admin</option>
      </select>
      <button type="submit" class="btn-search">Rechercher</button>
      {% if keyword or role %}
        <a href="{{ path('admin_utilisateurs') }}" class="btn-reset">Réinitialiser</a>
      {% endif %}
    </form>

    <a href="{{ path('admin_utilisateur_new') }}" class="btn-add-user">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Ajouter un utilisateur
    </a>
  </div>

  {# ── Tableau des utilisateurs ── #}
  {% if utilisateurs is empty %}
    <div class="user-empty">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
      <p>Aucun utilisateur trouvé.</p>
    </div>
  {% else %}
    <div class="user-table-wrap">
      <table class="user-table">
        <thead>
          <tr>
            <th>Utilisateur</th>
            <th>Email</th>
            <th>Téléphone</th>
            <th>Ville</th>
            <th>Rôle</th>
            <th>Inscription</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for u in utilisateurs %}
            <tr>
              <td>
                <div class="user-cell-name">
                  <div class="user-mini-avatar user-mini-avatar--{{ u.typeUser }}">
                    {{ u.prenom|first|upper }}{{ u.nom|first|upper }}
                  </div>
                  <div>
                    <strong>{{ u.fullName }}</strong>
                  </div>
                </div>
              </td>
              <td>{{ u.email }}</td>
              <td>{{ u.telephone ?? '—' }}</td>
              <td>{{ u.ville ?? '—' }}</td>
              <td>
                <span class="user-role-badge user-role-badge--{{ u.typeUser }}">
                  {% if u.typeUser == 'admin' %}Admin
                  {% elseif u.typeUser == 'technicien' %}Technicien
                  {% else %}Utilisateur{% endif %}
                </span>
              </td>
              <td>{{ u.dateCreation ? u.dateCreation|date('d/m/Y') : '—' }}</td>
              <td>
                <div class="user-actions">
                  <a href="{{ path('admin_utilisateur_show', {id: u.id}) }}" class="btn-action btn-view" title="Voir">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                  </a>
                  <a href="{{ path('admin_utilisateur_edit', {id: u.id}) }}" class="btn-action btn-edit" title="Modifier">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                  </a>
                  {% if u.id != app.user.id %}
                    <button type="button"
                      class="btn-action btn-delete"
                      title="Supprimer"
                      data-delete-id="{{ u.id }}"
                      data-delete-name="{{ u.fullName|e('html_attr') }}"
                      data-delete-token="{{ csrf_token('delete_user_' ~ u.id) }}">
                      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                    </button>
                  {% endif %}
                </div>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% include 'shared/_pagination.html.twig' with {
        currentPage: currentPage,
        totalPages: totalPages,
        route: 'admin_utilisateurs',
        routeParams: { q: keyword, role: role }
    } %}
  {% endif %}
</div>

{# ── Modal confirmation suppression ── #}
<div id="deleteModal" class="delete-modal-overlay" style="display:none">
  <div class="delete-modal">
    <div class="delete-modal-icon">
      <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
    </div>
    <h3>Confirmer la suppression</h3>
    <p id="deleteModalMsg">Voulez-vous vraiment supprimer cet utilisateur ?</p>
    <div class="delete-modal-actions">
      <button type="button" class="btn-modal-cancel" onclick="closeDeleteModal()">Annuler</button>
      <form id="deleteForm" method="post" style="display:inline">
        <input type="hidden" name="_token" id="deleteToken">
        <button type="submit" class="btn-modal-confirm">Supprimer</button>
      </form>
    </div>
  </div>
</div>

<style>
.user-mgmt { padding: .5rem 0; }

/* Flash */
.user-flash { display:flex; align-items:center; gap:.5rem; padding:.75rem 1.2rem;
  border-radius:10px; margin-bottom:1rem; font-size:.9rem; }
.user-flash--success { background:#f0faf2; color:#166534; border:1px solid #bbf7d0; }
.user-flash--error   { background:#fef2f2; color:#991b1b; border:1px solid #fecaca; }

/* Stats */
.user-stats { display:grid; grid-template-columns:repeat(4,1fr); gap:1rem; margin-bottom:1.5rem; }
@media(max-width:700px){ .user-stats{grid-template-columns:repeat(2,1fr);} }
.user-stat-card { background:#fff; border-radius:14px; padding:1.2rem 1.4rem;
  display:flex; align-items:center; gap:1rem; box-shadow:0 2px 10px rgba(0,0,0,.05); }
.user-stat-icon { width:44px; height:44px; border-radius:12px; display:flex;
  align-items:center; justify-content:center; flex-shrink:0; }
.user-stat-value { font-size:1.6rem; font-weight:800; color:#1a1a1a; line-height:1; }
.user-stat-label { font-size:.8rem; color:#6b7280; margin-top:.15rem; }

/* Toolbar */
.user-toolbar { display:flex; align-items:center; gap:1rem; margin-bottom:1.2rem; flex-wrap:wrap; }
.user-search-form { display:flex; align-items:center; gap:.6rem; flex:1; flex-wrap:wrap; }
.user-search-wrap { position:relative; flex:1; min-width:200px; }
.search-ico { position:absolute; left:.75rem; top:50%; transform:translateY(-50%); color:#9ca3af; }
.user-search-input { width:100%; padding:.6rem .9rem .6rem 2.5rem; border:1.5px solid #e2e8f0;
  border-radius:8px; font-size:.9rem; box-sizing:border-box; }
.user-search-input:focus { outline:none; border-color:#2d7a3a; }
.user-role-select { padding:.6rem .9rem; border:1.5px solid #e2e8f0; border-radius:8px; font-size:.9rem; }
.btn-search { padding:.6rem 1.2rem; background:#2d7a3a; color:#fff; border:none;
  border-radius:8px; font-size:.9rem; font-weight:600; cursor:pointer; }
.btn-reset { padding:.6rem 1rem; background:#f3f4f6; color:#374151; border:1.5px solid #e2e8f0;
  border-radius:8px; font-size:.9rem; text-decoration:none; }
.btn-add-user { display:inline-flex; align-items:center; gap:.4rem; padding:.65rem 1.3rem;
  background:linear-gradient(135deg,#2d7a3a,#4caf50); color:#fff; border-radius:9px;
  text-decoration:none; font-weight:600; font-size:.9rem; white-space:nowrap; }
.btn-add-user:hover { opacity:.9; }

/* Table */
.user-table-wrap { background:#fff; border-radius:14px; overflow:hidden;
  box-shadow:0 2px 10px rgba(0,0,0,.05); }
.user-table { width:100%; border-collapse:collapse; font-size:.9rem; }
.user-table thead th { background:#f8fafc; padding:.85rem 1rem; text-align:left;
  font-weight:700; color:#374151; border-bottom:2px solid #e2e8f0; white-space:nowrap; }
.user-table tbody td { padding:.85rem 1rem; border-bottom:1px solid #f0f0f0; }
.user-table tbody tr:last-child td { border-bottom:none; }
.user-table tbody tr:hover { background:#fafafa; }

.user-cell-name { display:flex; align-items:center; gap:.7rem; }
.user-mini-avatar { width:36px; height:36px; border-radius:50%; display:flex;
  align-items:center; justify-content:center; font-size:.8rem; font-weight:700; flex-shrink:0; }
.user-mini-avatar--admin      { background:#fef3c7; color:#92400e; }
.user-mini-avatar--technicien { background:#dbeafe; color:#1e40af; }
.user-mini-avatar--client     { background:#dcfce7; color:#166534; }

.user-role-badge { display:inline-block; padding:.2rem .65rem; border-radius:20px;
  font-size:.78rem; font-weight:600; }
.user-role-badge--admin      { background:#fef3c7; color:#92400e; }
.user-role-badge--technicien { background:#dbeafe; color:#1e40af; }
.user-role-badge--client     { background:#dcfce7; color:#166534; }

.user-actions { display:flex; gap:.4rem; }
.btn-action { width:30px; height:30px; border:none; border-radius:7px; cursor:pointer;
  display:inline-flex; align-items:center; justify-content:center; text-decoration:none; }
.btn-view   { background:#eff6ff; color:#3b82f6; }
.btn-edit   { background:#f0fdf4; color:#16a34a; }
.btn-delete { background:#fef2f2; color:#dc2626; }
.btn-action:hover { opacity:.8; }

.user-empty { text-align:center; padding:3rem; color:#9ca3af; background:#fff;
  border-radius:14px; box-shadow:0 2px 10px rgba(0,0,0,.05); }
.user-empty svg { margin-bottom:.7rem; opacity:.4; }

/* Delete modal */
.delete-modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,.4);
  display:flex; align-items:center; justify-content:center; z-index:9999; }
.delete-modal { background:#fff; border-radius:16px; padding:2rem; max-width:400px;
  width:90%; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,.2); }
.delete-modal-icon { margin-bottom:1rem; }
.delete-modal h3 { font-size:1.15rem; font-weight:700; color:#1a1a1a; margin:0 0 .5rem; }
.delete-modal p  { color:#6b7280; font-size:.9rem; margin:0 0 1.5rem; }
.delete-modal-actions { display:flex; gap:.75rem; justify-content:center; }
.btn-modal-cancel  { padding:.65rem 1.5rem; background:#f3f4f6; color:#374151;
  border:1.5px solid #e2e8f0; border-radius:9px; font-size:.9rem; cursor:pointer; font-weight:600; }
.btn-modal-confirm { padding:.65rem 1.5rem; background:#dc2626; color:#fff;
  border:none; border-radius:9px; font-size:.9rem; cursor:pointer; font-weight:600; }
</style>

<script>
function closeDeleteModal() {
  document.getElementById('deleteModal').style.display = 'none';
}

document.addEventListener('DOMContentLoaded', function () {
  document.querySelectorAll('[data-delete-id]').forEach(function(btn){
    btn.addEventListener('click', function(){
      var id    = btn.dataset.deleteId;
      var name  = btn.dataset.deleteName;
      var token = btn.dataset.deleteToken;
      document.getElementById('deleteModalMsg').textContent = 'Voulez-vous vraiment supprimer "' + name + '" ? Cette action est irréversible.';
      document.getElementById('deleteForm').action = '/admin/utilisateurs/' + id + '/supprimer';
      document.getElementById('deleteToken').value = token;
      document.getElementById('deleteModal').style.display = 'flex';
    });
  });
  document.getElementById('deleteModal').addEventListener('click', function(e){
    if (e.target === this) closeDeleteModal();
  });
});
</script>
{% endblock %}
