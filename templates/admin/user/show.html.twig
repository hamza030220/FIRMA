{% extends 'admin/base.html.twig' %}

{% block page_title %}Profil — {{ utilisateur.fullName }}{% endblock %}
{% block admin_page_title %}Détails de l'utilisateur{% endblock %}

{% block admin_content %}
<div class="admin-form-page">

  <div class="admin-form-header">
    <a href="{{ path('admin_utilisateurs') }}" class="btn-back">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      Retour à la liste
    </a>
    <a href="{{ path('admin_utilisateur_edit', {id: utilisateur.id}) }}" class="btn-save" style="text-decoration:none">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
      Modifier
    </a>
  </div>

  <div class="admin-form-card" style="max-width:620px">
    {# Avatar + nom #}
    <div style="display:flex;align-items:center;gap:1.2rem;margin-bottom:2rem;padding-bottom:1.5rem;border-bottom:2px solid #f0f0f0">
      <div class="show-avatar show-avatar--{{ utilisateur.typeUser }}">
        {{ utilisateur.prenom|first|upper }}{{ utilisateur.nom|first|upper }}
      </div>
      <div>
        <h2 style="margin:0 0 .3rem;font-size:1.4rem;font-weight:700">{{ utilisateur.fullName }}</h2>
        <span class="show-badge show-badge--{{ utilisateur.typeUser }}">
          {% if utilisateur.typeUser == 'admin' %}Administrateur
          {% elseif utilisateur.typeUser == 'technicien' %}Technicien
          {% else %}Utilisateur{% endif %}
        </span>
        {# ── ✅ ADDED: Banned badge next to role badge ── #}
        {% if utilisateur.isBanned %}
          <span style="display:inline-block;padding:.25rem .8rem;border-radius:20px;font-size:.82rem;
                       font-weight:600;background:#fef2f2;color:#dc2626;margin-left:.4rem;">
            Suspendu
          </span>
        {% endif %}
      </div>
    </div>

    {# Infos #}
    <div class="show-grid">
      <div class="show-field">
        <div class="show-field-label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Nom
        </div>
        <div class="show-field-value">{{ utilisateur.nom }}</div>
      </div>
      <div class="show-field">
        <div class="show-field-label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Prénom
        </div>
        <div class="show-field-value">{{ utilisateur.prenom }}</div>
      </div>
      <div class="show-field show-field--full">
        <div class="show-field-label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 7l10 7 10-7"/></svg>
          Email
        </div>
        <div class="show-field-value">{{ utilisateur.email }}</div>
      </div>
      <div class="show-field">
        <div class="show-field-label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 5a2 2 0 0 1 2-2h1.5l2 4.5-1.5 1a11 11 0 0 0 4.5 4.5l1-1.5L17 13.5V15a2 2 0 0 1-2 2A14 14 0 0 1 3 5z"/></svg>
          Téléphone
        </div>
        <div class="show-field-value">{{ utilisateur.telephone ?? '—' }}</div>
      </div>
      <div class="show-field">
        <div class="show-field-label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a7 7 0 0 1 7 7c0 5.25-7 13-7 13S5 14.25 5 9a7 7 0 0 1 7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
          Ville
        </div>
        <div class="show-field-value">{{ utilisateur.ville ?? '—' }}</div>
      </div>
      <div class="show-field show-field--full">
        <div class="show-field-label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 9h20"/></svg>
          Adresse
        </div>
        <div class="show-field-value">{{ utilisateur.adresse ?? '—' }}</div>
      </div>
      <div class="show-field">
        <div class="show-field-label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Date d'inscription
        </div>
        <div class="show-field-value">{{ utilisateur.dateCreation ? utilisateur.dateCreation|date('d/m/Y à H:i') : '—' }}</div>
      </div>

      {# ── ✅ ADDED: Ban info fields (only visible when banned) ── #}
      {% if utilisateur.isBanned %}
        <div class="show-field show-field--full" style="background:#fef2f2;border:1.5px solid #fecaca;">
          <div class="show-field-label" style="color:#dc2626;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
            Motif de suspension
          </div>
          <div class="show-field-value" style="color:#7f1d1d;">{{ utilisateur.banReason ?? 'Aucun motif précisé.' }}</div>
        </div>
        <div class="show-field">
          <div class="show-field-label" style="color:#dc2626;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Suspendu le
          </div>
          <div class="show-field-value" style="color:#7f1d1d;">{{ utilisateur.bannedAt ? utilisateur.bannedAt|date('d/m/Y à H:i') : '—' }}</div>
        </div>
      {% endif %}

    </div>

    {# Actions #}
    <div class="admin-form-actions" style="margin-top:2rem">
      {% if utilisateur.id != app.user.id %}

        {# ── ✅ ADDED: Ban button (shown when NOT banned, and not an admin) ── #}
        {% if not utilisateur.isBanned and 'ROLE_ADMIN' not in utilisateur.roles %}
          <button type="button" class="btn-ban-show" onclick="document.getElementById('banModal').style.display='flex'">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
            Suspendre
          </button>
        {% endif %}

        {# ── ✅ ADDED: Unban button (shown when banned) ── #}
        {% if utilisateur.isBanned %}
          <form method="post" action="{{ path('admin_utilisateur_unban', {id: utilisateur.id}) }}"
                onsubmit="return confirm('Réactiver le compte de {{ utilisateur.fullName }} ?')">
            <input type="hidden" name="_token" value="{{ csrf_token('unban_user_' ~ utilisateur.id) }}">
            <button type="submit" class="btn-unban-show">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              Réactiver
            </button>
          </form>
        {% endif %}

        {# Delete #}
        <form method="post" action="{{ path('admin_utilisateur_delete', {id: utilisateur.id}) }}" onsubmit="return confirm('Supprimer définitivement cet utilisateur ?')">
          <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ utilisateur.id) }}">
          <button type="submit" class="btn-delete-show">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
            Supprimer
          </button>
        </form>
      {% endif %}

      {% if utilisateur.id != app.user.id and 'ROLE_ADMIN' not in utilisateur.roles and not utilisateur.isBanned %}
        <a href="{{ path('user_dashboard', {'_switch_user': utilisateur.email}) }}"
          style="display:inline-flex;align-items:center;gap:.5rem;padding:.65rem 1.3rem;
                  background:#f5f3ff;color:#6d28d9;border:1.5px solid #ddd6fe;
                  border-radius:9px;font-size:.9rem;font-weight:600;text-decoration:none;
                  transition:background .15s;"
          onmouseover="this.style.background='#ede9fe'"
          onmouseout="this.style.background='#f5f3ff'"
          onclick="return confirm('Vous allez vous connecter en tant que {{ utilisateur.fullName }}. Continuer ?')">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
          Connecter
        </a>
      {% endif %}

      <a href="{{ path('admin_utilisateur_edit', {id: utilisateur.id}) }}" class="btn-save" style="text-decoration:none">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        Modifier
      </a>
    </div>
  </div>
</div>

{# ── ✅ ADDED: Ban modal ── #}
{% if not utilisateur.isBanned and utilisateur.id != app.user.id and 'ROLE_ADMIN' not in utilisateur.roles %}
<div id="banModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);
     z-index:1000;align-items:center;justify-content:center;">
  <div style="background:#fff;border-radius:16px;padding:2rem;max-width:440px;width:90%;box-shadow:0 8px 40px rgba(0,0,0,.15);">
    <h3 style="margin:0 0 .5rem;font-size:1.1rem;font-weight:700;color:#1a1a1a;">
      Suspendre {{ utilisateur.fullName }} ?
    </h3>
    <p style="color:#6b7280;font-size:.9rem;margin:0 0 1.2rem;">
      L'utilisateur ne pourra plus se connecter à la plateforme.
    </p>
    <form method="post" action="{{ path('admin_utilisateur_ban', {id: utilisateur.id}) }}">
      <input type="hidden" name="_token" value="{{ csrf_token('ban_user_' ~ utilisateur.id) }}">
      <label style="display:block;font-weight:600;font-size:.875rem;color:#374151;margin-bottom:.4rem;">
        Motif <span style="font-weight:400;color:#9ca3af;">(optionnel)</span>
      </label>
      <textarea name="ban_reason" rows="3" placeholder="Ex : comportement abusif, fraude…"
                style="width:100%;padding:.6rem .9rem;border:1.5px solid #e2e8f0;border-radius:8px;
                       font-size:.93rem;resize:vertical;box-sizing:border-box;"></textarea>
      <div style="display:flex;gap:.8rem;justify-content:flex-end;margin-top:1.2rem;">
        <button type="button" onclick="document.getElementById('banModal').style.display='none'"
                style="padding:.65rem 1.3rem;background:#f8fafc;border:1.5px solid #e2e8f0;
                       border-radius:9px;font-size:.9rem;font-weight:600;cursor:pointer;color:#374151;">
          Annuler
        </button>
        <button type="submit" class="btn-ban-show">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
          Confirmer la suspension
        </button>
      </div>
    </form>
  </div>
</div>
{% endif %}

{% include 'admin/user/_form_styles.html.twig' %}
<style>
.show-avatar { width:64px; height:64px; border-radius:50%; display:flex;
  align-items:center; justify-content:center; font-size:1.4rem; font-weight:700; flex-shrink:0; }
.show-avatar--admin      { background:#fef3c7; color:#92400e; }
.show-avatar--technicien { background:#dbeafe; color:#1e40af; }
.show-avatar--client     { background:#dcfce7; color:#166534; }
.show-badge { display:inline-block; padding:.25rem .8rem; border-radius:20px; font-size:.82rem; font-weight:600; }
.show-badge--admin      { background:#fef3c7; color:#92400e; }
.show-badge--technicien { background:#dbeafe; color:#1e40af; }
.show-badge--client     { background:#dcfce7; color:#166534; }

.show-grid { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
@media(max-width:500px){ .show-grid{grid-template-columns:1fr;} }
.show-field { background:#f8fafc; border-radius:10px; padding:1rem 1.2rem; }
.show-field--full { grid-column:span 2; }
@media(max-width:500px){ .show-field--full{grid-column:span 1;} }
.show-field-label { display:flex; align-items:center; gap:.4rem;
  font-size:.78rem; font-weight:600; color:#6b7280; text-transform:uppercase;
  letter-spacing:.04em; margin-bottom:.4rem; }
.show-field-value { font-size:.95rem; color:#1a1a1a; font-weight:500; }

.btn-delete-show { display:inline-flex; align-items:center; gap:.4rem; padding:.65rem 1.3rem;
  background:#fef2f2; color:#dc2626; border:1.5px solid #fecaca;
  border-radius:9px; font-size:.9rem; font-weight:600; cursor:pointer; }
.btn-delete-show:hover { background:#fee2e2; }

/* ── ✅ ADDED: Ban / Unban button styles ── */
.btn-ban-show { display:inline-flex; align-items:center; gap:.4rem; padding:.65rem 1.3rem;
  background:#fff7ed; color:#c2410c; border:1.5px solid #fed7aa;
  border-radius:9px; font-size:.9rem; font-weight:600; cursor:pointer; }
.btn-ban-show:hover { background:#ffedd5; }

.btn-unban-show { display:inline-flex; align-items:center; gap:.4rem; padding:.65rem 1.3rem;
  background:#f0fdf4; color:#166534; border:1.5px solid #bbf7d0;
  border-radius:9px; font-size:.9rem; font-weight:600; cursor:pointer; }
.btn-unban-show:hover { background:#dcfce7; }
</style>
{% endblock %}
