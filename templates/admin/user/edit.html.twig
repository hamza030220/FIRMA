{% extends 'admin/base.html.twig' %}

{% block page_title %}Modifier — {{ utilisateur.fullName }}{% endblock %}
{% block admin_page_title %}Modifier l'utilisateur{% endblock %}

{% block admin_content %}
<div class="admin-form-page">

  <div class="admin-form-header">
    <a href="{{ path('admin_utilisateurs') }}" class="btn-back">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      Retour à la liste
    </a>
    <div style="display:flex;align-items:center;gap:.8rem">
      <div class="admin-user-avatar admin-user-avatar--{{ utilisateur.typeUser }}">
        {{ utilisateur.prenom|first|upper }}{{ utilisateur.nom|first|upper }}
      </div>
      <div>
        <h2 style="margin:0">{{ utilisateur.fullName }}</h2>
        <span class="user-role-badge user-role-badge--{{ utilisateur.typeUser }}" style="font-size:.8rem">
          {% if utilisateur.typeUser == 'admin' %}Administrateur
          {% elseif utilisateur.typeUser == 'technicien' %}Technicien
          {% else %}Utilisateur{% endif %}
        </span>
      </div>
    </div>
  </div>

  {% for msg in app.flashes('error') %}
    <div class="admin-flash admin-flash--error">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      {{ msg }}
    </div>
  {% endfor %}

  <div class="admin-form-card">
    {{ form_start(form, {'attr': {'class': 'admin-user-form', 'novalidate': 'novalidate'}}) }}

      <div class="admin-form-grid">
        <div class="form-group">
          {{ form_label(form.nom) }}
          {{ form_widget(form.nom, {'attr': {'class': 'form-input'}}) }}
          {{ form_errors(form.nom) }}
        </div>
        <div class="form-group">
          {{ form_label(form.prenom) }}
          {{ form_widget(form.prenom, {'attr': {'class': 'form-input'}}) }}
          {{ form_errors(form.prenom) }}
        </div>
      </div>

      <div class="form-group">
        {{ form_label(form.email) }}
        {{ form_widget(form.email, {'attr': {'class': 'form-input'}}) }}
        {{ form_errors(form.email) }}
      </div>

      <div class="admin-form-grid">
        <div class="form-group">
          {{ form_label(form.telephone) }}
          {{ form_widget(form.telephone, {'attr': {'class': 'form-input'}}) }}
          {{ form_errors(form.telephone) }}
        </div>
        <div class="form-group">
          {{ form_label(form.ville) }}
          {{ form_widget(form.ville, {'attr': {'class': 'form-input'}}) }}
          {{ form_errors(form.ville) }}
        </div>
      </div>

      <div class="form-group">
        {{ form_label(form.adresse) }}
        {{ form_widget(form.adresse, {'attr': {'class': 'form-input'}}) }}
        {{ form_errors(form.adresse) }}
      </div>

      <div class="form-group">
        {{ form_label(form.typeUser) }}
        {{ form_widget(form.typeUser, {'attr': {'class': 'form-input'}}) }}
        {{ form_errors(form.typeUser) }}
      </div>

      <div class="form-group">
        {{ form_label(form.plainPassword) }}
        <div class="input-wrapper">
          {{ form_widget(form.plainPassword, {'attr': {'class': 'form-input', 'id': 'edit-pwd'}}) }}
          <button type="button" class="toggle-password" onclick="togglePass('edit-pwd','edit-eye')" aria-label="Afficher">
            <svg viewBox="0 0 20 20" fill="none" class="eye-icon" id="edit-eye"><path d="M1 10s3.5-6 9-6 9 6 9 6-3.5 6-9 6-9-6-9-6z" stroke="currentColor" stroke-width="1.3"/><circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1.3"/></svg>
          </button>
        </div>
        {{ form_errors(form.plainPassword) }}
      </div>

      {{ form_errors(form) }}

      <div class="admin-form-actions">
        <a href="{{ path('admin_utilisateur_show', {id: utilisateur.id}) }}" class="btn-cancel">Annuler</a>
        <button type="submit" class="btn-save">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          Sauvegarder
        </button>
      </div>

    {{ form_end(form) }}
  </div>
</div>

{% include 'admin/user/_form_styles.html.twig' %}
<style>
.admin-user-avatar { width:48px; height:48px; border-radius:50%; display:flex;
  align-items:center; justify-content:center; font-size:1rem; font-weight:700; flex-shrink:0; }
.admin-user-avatar--admin      { background:#fef3c7; color:#92400e; }
.admin-user-avatar--technicien { background:#dbeafe; color:#1e40af; }
.admin-user-avatar--client     { background:#dcfce7; color:#166534; }
.user-role-badge { display:inline-block; padding:.2rem .65rem; border-radius:20px; font-weight:600; }
.user-role-badge--admin      { background:#fef3c7; color:#92400e; }
.user-role-badge--technicien { background:#dbeafe; color:#1e40af; }
.user-role-badge--client     { background:#dcfce7; color:#166534; }
</style>
<script>
function togglePass(inputId, iconId) {
  const input = document.getElementById(inputId);
  const icon  = document.getElementById(iconId);
  if (input.type === 'password') {
    input.type = 'text';
    icon.innerHTML = '<path d="M1 10s3.5-6 9-6 9 6 9 6-3.5 6-9 6-9-6-9-6z" stroke="currentColor" stroke-width="1.3"/><circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1.3"/><line x1="3" y1="3" x2="17" y2="17" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>';
  } else {
    input.type = 'password';
    icon.innerHTML = '<path d="M1 10s3.5-6 9-6 9 6 9 6-3.5 6-9 6-9-6-9-6z" stroke="currentColor" stroke-width="1.3"/><circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1.3"/>';
  }
}
</script>
{% endblock %}
