{% extends 'base.html.twig' %}

{% block title %}{% block page_title %}Administration{% endblock %} — FIRMA Admin{% endblock %}

{% block body %}
<div class="admin-layout">
    {# ── Sidebar ── #}
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="admin-sidebar-header">
            <a href="{{ path('admin_dashboard') }}" class="admin-sidebar-brand">
                <img src="{{ asset('image/logofirma.jpg') }}" alt="FIRMA" class="admin-sidebar-logo">
                <span class="admin-sidebar-brand-text">FIRMA<small>Admin</small></span>
            </a>
        </div>

        <div class="admin-sidebar-menu">
            <span class="admin-menu-label">Navigation</span>
            <a href="{{ path('admin_dashboard') }}" class="admin-menu-item {% if app.request.get('_route') == 'admin_dashboard' %}active{% endif %}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                <span>Tableau de bord</span>
            </a>
            <a href="{{ path('admin_marketplace') }}" class="admin-menu-item {% if app.request.get('_route') starts with 'admin_marketplace' %}active{% endif %}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                <span>Marketplace</span>
            </a>
            <a href="{{ path('admin_evenements') }}" class="admin-menu-item {% if app.request.get('_route') starts with 'admin_evenement' %}active{% endif %}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <span>Gérer Événements</span>
            </a>
            <a href="{{ path('admin_techniciens') }}" class="admin-menu-item {% if app.request.get('_route') starts with 'admin_technicien' %}active{% endif %}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                <span>Gérer Techniciens</span>
            </a>
            <a href="{{ path('admin_forum') }}" class="admin-menu-item {% if app.request.get('_route') starts with 'admin_forum' %}active{% endif %}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                <span>Gérer Forum</span>
            </a>
            <a href="{{ path('admin_utilisateurs') }}" class="admin-menu-item {% if app.request.get('_route') starts with 'admin_utilisateur' %}active{% endif %}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <span>Gérer Utilisateurs</span>
            </a>
        </div>

        <div class="admin-sidebar-footer">
            <a href="{{ path('app_logout') }}" class="admin-menu-item admin-menu-logout">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                <span>Déconnexion</span>
            </a>
        </div>
    </aside>

    {# ── Sidebar Toggle (mobile) ── #}
    <button class="admin-sidebar-toggle" id="sidebarToggle" aria-label="Menu">
        <span></span><span></span><span></span>
    </button>

    {# ── Main Content ── #}
    <main class="admin-main">
        <header class="admin-topbar">
            <h1 class="admin-page-title">{% block admin_page_title %}Tableau de bord{% endblock %}</h1>
            <div class="admin-topbar-user">
                <div class="admin-topbar-avatar">{{ app.user.prenom|first }}{{ app.user.nom|first }}</div>
                <span>{{ app.user.fullName }}</span>
            </div>
        </header>
        <div class="admin-content">
            {% block admin_content %}{% endblock %}
        </div>
    </main>
</div>
{% endblock %}
