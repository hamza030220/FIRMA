{% extends 'base.html.twig' %}

{% block title %}{% block page_title %}Administration{% endblock %} - FIRMA Admin{% endblock %}

{% block footer %}{% endblock %}

{% block body %}
<div class="admin-layout">
    {# Sidebar #}
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="admin-sidebar-header">
            <a href="{{ path('admin_dashboard') }}" class="admin-sidebar-brand">
                <img src="{{ asset('image/logofirma.jpg') }}" alt="FIRMA" class="admin-sidebar-logo">
                <span class="admin-sidebar-brand-text">FIRMA<small>Admin</small></span>
            </a>
        </div>

        <div class="admin-sidebar-menu">
            <span class="admin-menu-label">Navigation</span>
            <a href="{{ path('admin_dashboard') }}" class="admin-menu-item {% if app.request.get('_route') == 'admin_dashboard' %}active{% endif %}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                <span>Tableau de bord</span>
            </a>
            <a href="{{ path('admin_marketplace') }}" class="admin-menu-item {% if app.request.get('_route') starts with 'admin_marketplace' %}active{% endif %}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                <span>Marketplace</span>
            </a>
            <a href="{{ path('admin_evenements') }}" class="admin-menu-item {% if app.request.get('_route') starts with 'admin_evenement' %}active{% endif %}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <span>Gerer evenements</span>
            </a>
            <a href="{{ path('admin_maladie_index') }}" class="admin-menu-item {% if app.request.get('_route') starts with 'admin_maladie' %}active{% endif %}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                <span>Gerer maladies</span>
            </a>
            <a href="{{ path('admin_forum') }}" class="admin-menu-item {% if app.request.get('_route') starts with 'admin_forum' %}active{% endif %}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                <span>Gerer forum</span>
            </a>
            <a href="{{ path('admin_utilisateurs') }}" class="admin-menu-item {% if app.request.get('_route') starts with 'admin_utilisateur' %}active{% endif %}">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <span>Gerer utilisateurs</span>
            </a>
        </div>

        <div class="admin-sidebar-footer">
            <a href="{{ path('app_logout') }}" class="admin-menu-item admin-menu-logout">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                <span>Deconnexion</span>
            </a>
        </div>
    </aside>

    {# Sidebar Toggle (mobile) #}
    <button class="admin-sidebar-toggle" id="sidebarToggle" aria-label="Menu">
        <span></span><span></span><span></span>
    </button>

    {# Main Content #}
    <main class="admin-main">
        <header class="admin-topbar">
            <h1 class="admin-page-title">{% block admin_page_title %}Tableau de bord{% endblock %}</h1>
            <div class="admin-topbar-actions">
                {% set showForumAlerts = app.request.get('_route') starts with 'admin_forum' %}
                {% if showForumAlerts %}
                {% set forumAlertsCount = forum_pending_alerts_count() %}
                {% set forumReviewedAlerts = forum_recent_reviewed_alerts(5) %}
                <button
                    type="button"
                    class="admin-notification-button {% if forumAlertsCount > 0 %}has-alerts{% endif %}"
                    id="adminForumAlertsButton"
                    title="{% if forumAlertsCount > 0 %}{{ forumAlertsCount }} signalement{{ forumAlertsCount > 1 ? 's' : '' }} forum en attente{% else %}Aucun signalement forum en attente{% endif %}"
                    aria-label="{% if forumAlertsCount > 0 %}{{ forumAlertsCount }} signalement{{ forumAlertsCount > 1 ? 's' : '' }} forum en attente{% else %}Aucun signalement forum en attente{% endif %}"
                >
                    <svg class="admin-notification-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M15 17H9"/>
                        <path d="M10 21h4"/>
                        <path d="M18 8a6 6 0 1 0-12 0c0 7-3 7-3 9h18c0-2-3-2-3-9"/>
                    </svg>
                    {% if forumAlertsCount > 0 %}
                        <span class="admin-notification-badge" aria-hidden="true">?</span>
                    {% endif %}
                </button>
                {% endif %}
                <div class="admin-topbar-user">
                    <div class="admin-topbar-avatar">{{ app.user.prenom|first }}{{ app.user.nom|first }}</div>
                    <span>{{ app.user.fullName }}</span>
                </div>
            </div>
        </header>
        <div class="admin-content">
            {% block admin_content %}{% endblock %}
        </div>
    </main>
</div>

{% if showForumAlerts %}
{% set forumRecentAlerts = forum_recent_alerts(5) %}
<div class="admin-alert-modal" id="adminForumAlertModal" hidden>
    <div class="admin-alert-modal-backdrop" data-admin-alert-close></div>
    <div class="admin-alert-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="adminForumAlertTitle" aria-describedby="adminForumAlertDescription">
        <div class="admin-alert-modal-header">
            <div>
                <p class="admin-alert-modal-eyebrow">Forum moderation</p>
                <h2 id="adminForumAlertTitle">Signalements en attente</h2>
            </div>
            <button type="button" class="admin-alert-modal-close" data-admin-alert-close aria-label="Fermer">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M18 6 6 18"/>
                    <path d="M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <p id="adminForumAlertDescription" class="admin-alert-modal-subtitle">
            {% if forumAlertsCount > 0 %}
                {{ forumAlertsCount }} signalement{{ forumAlertsCount > 1 ? 's' : '' }} en attente de traitement.
            {% else %}
                Aucun signalement en attente pour le moment.
            {% endif %}
        </p>

        <div class="admin-alert-modal-list">
            {% if forumRecentAlerts is not empty %}
                {% for alert in forumRecentAlerts %}
                    {% set comment = alert.commentaire %}
                    {% set post = comment ? comment.post : null %}
                    <article class="admin-alert-card">
                        <div class="admin-alert-card-head">
                            <div>
                                <strong>{{ alert.utilisateur.email }}</strong>
                                <span>{{ alert.createdAt|date('d/m/Y H:i', 'Africa/Lagos') }}</span>
                            </div>
                            <span class="admin-alert-card-status{% if alert.status == 'treated' %} admin-alert-card-status--treated{% endif %}">{{ alert.status == 'treated' ? 'Fait' : 'En attente' }}</span>
                        </div>

                        <p class="admin-alert-card-message" style="font-weight:700;color:#b91c1c;display:flex;align-items:flex-start;gap:0.55rem;">
                            <span aria-hidden="true" style="display:inline-flex;align-items:center;justify-content:center;width:1.45rem;height:1.45rem;border-radius:999px;background:#fff1f1;color:#b91c1c;border:1px solid #f3c6c6;flex:0 0 auto;font-weight:900;">?</span>
                            <span>{{ alert.maskedContent }}</span>
                        </p>

                        <div class="admin-alert-card-meta">
                            {% if post and post.id %}
                                <a href="{{ path('admin_forum_post_show', {id: post.id}) }}">Voir le post</a>
                            {% else %}
                                <span>Post introuvable</span>
                            {% endif %}
                        </div>

                        {% if alert.note is not empty %}
                            <p class="forum-flash forum-flash-success" style="margin-top:0.85rem;">{{ alert.note }}</p>
                        {% else %}
                            <form method="post" action="{{ path('admin_forum_alert_warn', {id: alert.id}) }}" style="margin-top:0.85rem;display:flex;justify-content:flex-end;">
                                <input type="hidden" name="_token" value="{{ csrf_token('warn_alert_' ~ alert.id) }}">
                                <button type="submit" class="forum-button forum-button-secondary" style="border-color:#f2b4b4;color:#9f1d1d;background:#fff1f1;font-weight:700;">Envoyer un avertissement</button>
                            </form>
                        {% endif %}
                    </article>
                {% endfor %}
            {% elseif forumReviewedAlerts is empty %}
                <div class="admin-alert-empty">
                    <p>Aucune alerte forum pour le moment.</p>
                    <a href="{{ path('admin_forum') }}">Aller a la moderation forum</a>
                </div>
            {% endif %}

            {% if forumReviewedAlerts is not empty %}
                <div class="admin-alert-divider"></div>
                <div class="admin-alert-history-head">
                    <strong>Signalements traites recemment</strong>
                    <span>{{ forumReviewedAlerts|length }}</span>
                </div>
                {% for alert in forumReviewedAlerts %}
                    {% set comment = alert.commentaire %}
                    {% set post = comment ? comment.post : null %}
                    <article class="admin-alert-card admin-alert-card--treated">
                        <div class="admin-alert-card-head">
                            <div>
                                <strong>{{ alert.utilisateur.email }}</strong>
                                <span>{{ alert.reviewedAt ? alert.reviewedAt|date('d/m/Y H:i', 'Africa/Lagos') : alert.createdAt|date('d/m/Y H:i', 'Africa/Lagos') }}</span>
                            </div>
                            <span class="admin-alert-card-status admin-alert-card-status--treated">Fait</span>
                        </div>

                        <p class="admin-alert-card-message" style="font-weight:700;color:#b91c1c;display:flex;align-items:flex-start;gap:0.55rem;">
                            <span aria-hidden="true" style="display:inline-flex;align-items:center;justify-content:center;width:1.45rem;height:1.45rem;border-radius:999px;background:#fff1f1;color:#b91c1c;border:1px solid #f3c6c6;flex:0 0 auto;font-weight:900;">?</span>
                            <span>{{ alert.maskedContent }}</span>
                        </p>

                        <div class="admin-alert-card-meta">
                            {% if post and post.id %}
                                <a href="{{ path('admin_forum_post_show', {id: post.id}) }}">Voir le post</a>
                            {% else %}
                                <span>Commentaire supprimé</span>
                            {% endif %}
                        </div>

                        {% if alert.note is not empty %}
                            <p class="forum-flash forum-flash-success" style="margin-top:0.85rem;">{{ alert.note }}</p>
                        {% endif %}
                    </article>
                {% endfor %}
            {% endif %}
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const button = document.getElementById('adminForumAlertsButton');
        const modal = document.getElementById('adminForumAlertModal');
        const closeTargets = modal ? modal.querySelectorAll('[data-admin-alert-close]') : [];
        let alertAudioContext = null;

        const playAlertSound = () => {
            if (!button || !button.classList.contains('has-alerts')) {
                return;
            }

            const AudioCtx = window.AudioContext || window.webkitAudioContext;
            if (!AudioCtx) {
                return;
            }

            alertAudioContext = alertAudioContext || new AudioCtx();
            if (alertAudioContext.state === 'suspended') {
                alertAudioContext.resume().catch(() => {});
            }

            const now = alertAudioContext.currentTime;
            const oscillator = alertAudioContext.createOscillator();
            const gain = alertAudioContext.createGain();
            const filter = alertAudioContext.createBiquadFilter();

            oscillator.type = 'triangle';
            oscillator.frequency.setValueAtTime(1320, now);
            oscillator.frequency.exponentialRampToValueAtTime(1040, now + 0.14);

            filter.type = 'highpass';
            filter.frequency.setValueAtTime(1100, now);

            gain.gain.setValueAtTime(0.0001, now);
            gain.gain.exponentialRampToValueAtTime(0.1, now + 0.012);
            gain.gain.exponentialRampToValueAtTime(0.0001, now + 0.22);

            oscillator.connect(filter);
            filter.connect(gain);
            gain.connect(alertAudioContext.destination);

            oscillator.start(now);
            oscillator.stop(now + 0.24);
        };

        const openModal = () => {
            if (!modal) {
                return;
            }
            modal.hidden = false;
            document.body.classList.add('admin-alert-modal-open');
        };

        const closeModal = () => {
            if (!modal) {
                return;
            }
            modal.hidden = true;
            document.body.classList.remove('admin-alert-modal-open');
        };

        if (button && modal) {
            button.addEventListener('mouseenter', () => {
                playAlertSound();
            });

            button.addEventListener('click', openModal);
            button.addEventListener('click', () => {
                playAlertSound();
            });
        }

        closeTargets.forEach((target) => {
            target.addEventListener('click', closeModal);
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && modal && !modal.hidden) {
                closeModal();
            }
        });
    });
</script>
{% endif %}
{% endblock %}
