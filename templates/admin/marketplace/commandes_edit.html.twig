{% extends 'admin/base.html.twig' %}
{% import 'admin/marketplace/_macros.html.twig' as macros %}

{% block page_title %}Modifier la Commande{% endblock %}
{% block admin_page_title %}Commande {{ commande.numeroCommande }}{% endblock %}

{% block admin_content %}
<div class="mp-page">
    <a href="{{ path('admin_marketplace_commandes') }}" class="mp-back-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Retour à la liste
    </a>

    {{ macros.flashes() }}

    <div class="mp-edit-card">
        {# ── Résumé ── #}
        <div class="mp-order-summary">
            <div class="mp-summary-row">
                <span class="mp-label">Client :</span>
                <span>{{ commande.utilisateur ? commande.utilisateur.fullName : '—' }}</span>
            </div>
            <div class="mp-summary-row">
                <span class="mp-label">Email :</span>
                <span>{{ commande.utilisateur ? commande.utilisateur.email : '—' }}</span>
            </div>
            <div class="mp-summary-row">
                <span class="mp-label">Montant total :</span>
                <span><strong>{{ commande.montantTotal|number_format(2, ',', ' ') }} TND</strong></span>
            </div>
            <div class="mp-summary-row">
                <span class="mp-label">Date commande :</span>
                <span>{{ commande.dateCommande ? commande.dateCommande|date('d/m/Y H:i') : '—' }}</span>
            </div>
            <div class="mp-summary-row">
                <span class="mp-label">Adresse livraison :</span>
                <span>{{ commande.adresseLivraison ?? '—' }}, {{ commande.villeLivraison ?? '' }}</span>
            </div>
            {% if commande.notes %}
            <div class="mp-summary-row">
                <span class="mp-label">Notes :</span>
                <span>{{ commande.notes }}</span>
            </div>
            {% endif %}
        </div>

        {# ── Détails articles ── #}
        {% if commande.details is not empty %}
        <h3 class="mp-section-title">Articles commandés</h3>
        <div class="mp-table-wrap">
            <table class="mp-table">
                <thead>
                    <tr>
                        <th>Équipement</th>
                        <th>Quantité</th>
                        <th>Prix unitaire</th>
                        <th>Sous-total</th>
                    </tr>
                </thead>
                <tbody>
                {% for d in commande.details %}
                    <tr>
                        <td>{{ d.equipement }}</td>
                        <td>{{ d.quantite }}</td>
                        <td>{{ d.prixUnitaire|number_format(2, ',', ' ') }} TND</td>
                        <td>{{ d.sousTotal|number_format(2, ',', ' ') }} TND</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}

        {# ── Mise à jour des statuts ── #}
        <h3 class="mp-section-title">Mettre à jour les statuts</h3>
        <form method="post" action="{{ path('admin_marketplace_commandes_edit', {id: commande.id}) }}" class="mp-form">
            <input type="hidden" name="_token" value="{{ csrf_token('commande_status' ~ commande.id) }}">
            <div class="mp-form-grid">
                <div>
                    <label for="statut_paiement">Statut paiement</label>
                    <select name="statut_paiement" id="statut_paiement">
                        {% for val in ['en_attente', 'paye', 'echoue'] %}
                            <option value="{{ val }}" {{ commande.statutPaiement == val ? 'selected' : '' }}>
                                {{ val|replace({'_': ' '})|capitalize }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label for="statut_livraison">Statut livraison</label>
                    <select name="statut_livraison" id="statut_livraison">
                        {% for val in ['en_attente', 'en_preparation', 'expedie', 'livre', 'annule'] %}
                            <option value="{{ val }}" {{ commande.statutLivraison == val ? 'selected' : '' }}>
                                {{ val|replace({'_': ' '})|capitalize }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
            </div>
            <div class="mp-form-actions">
                <button type="submit" class="mp-btn mp-btn-primary">Enregistrer</button>
                <a href="{{ path('admin_marketplace_commandes') }}" class="mp-btn mp-btn-secondary">Annuler</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
