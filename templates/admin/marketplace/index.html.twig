{% extends 'admin/base.html.twig' %}

{% block page_title %}Marketplace{% endblock %}
{% block admin_page_title %}Marketplace{% endblock %}

{% block admin_content %}
<div class="mp-dashboard">
    <div class="mp-dashboard-header">
        <h2>Gestion du Marketplace</h2>
        <p>Gérez vos produits, véhicules, terrains, fournisseurs et suivez les commandes et locations.</p>
    </div>

    <div class="mp-cards-grid">
        {# ── Équipements ── #}
        <div class="mp-card">
            <div class="mp-card-icon">
                <img src="{{ asset('image/marketplace/icone_equipements.png') }}" alt="Équipements">
            </div>
            <div class="mp-card-body">
                <h3>Gestion Équipements</h3>
                <p>{{ counts.equipements }} équipement{{ counts.equipements > 1 ? 's' : '' }} enregistré{{ counts.equipements > 1 ? 's' : '' }}</p>
            </div>
            <a href="{{ path('admin_marketplace_equipements') }}" class="mp-card-btn">Consulter</a>
        </div>

        {# ── Véhicules ── #}
        <div class="mp-card">
            <div class="mp-card-icon">
                <img src="{{ asset('image/marketplace/icone_vehicule.png') }}" alt="Véhicules">
            </div>
            <div class="mp-card-body">
                <h3>Gestion Véhicules</h3>
                <p>{{ counts.vehicules }} véhicule{{ counts.vehicules > 1 ? 's' : '' }} enregistré{{ counts.vehicules > 1 ? 's' : '' }}</p>
            </div>
            <a href="{{ path('admin_marketplace_vehicules') }}" class="mp-card-btn">Consulter</a>
        </div>

        {# ── Terrains ── #}
        <div class="mp-card">
            <div class="mp-card-icon">
                <img src="{{ asset('image/marketplace/icone_terrains.png') }}" alt="Terrains">
            </div>
            <div class="mp-card-body">
                <h3>Gestion Terrains</h3>
                <p>{{ counts.terrains }} terrain{{ counts.terrains > 1 ? 's' : '' }} enregistré{{ counts.terrains > 1 ? 's' : '' }}</p>
            </div>
            <a href="{{ path('admin_marketplace_terrains') }}" class="mp-card-btn">Consulter</a>
        </div>

        {# ── Fournisseurs ── #}
        <div class="mp-card">
            <div class="mp-card-icon">
                <img src="{{ asset('image/marketplace/icone_fournisseurs.png') }}" alt="Fournisseurs">
            </div>
            <div class="mp-card-body">
                <h3>Gestion Fournisseurs</h3>
                <p>{{ counts.fournisseurs }} fournisseur{{ counts.fournisseurs > 1 ? 's' : '' }} enregistré{{ counts.fournisseurs > 1 ? 's' : '' }}</p>
            </div>
            <a href="{{ path('admin_marketplace_fournisseurs') }}" class="mp-card-btn">Consulter</a>
        </div>

        {# ── Commandes ── #}
        <div class="mp-card">
            <div class="mp-card-icon">
                <img src="{{ asset('image/marketplace/icone_commande.png') }}" alt="Commandes">
            </div>
            <div class="mp-card-body">
                <h3>Gestion Commandes</h3>
                <p>{{ counts.commandes }} commande{{ counts.commandes > 1 ? 's' : '' }} enregistrée{{ counts.commandes > 1 ? 's' : '' }}</p>
            </div>
            <a href="{{ path('admin_marketplace_commandes') }}" class="mp-card-btn">Consulter</a>
        </div>

        {# ── Locations ── #}
        <div class="mp-card">
            <div class="mp-card-icon">
                <img src="{{ asset('image/marketplace/icone_location.png') }}" alt="Locations">
            </div>
            <div class="mp-card-body">
                <h3>Gestion Locations</h3>
                <p>{{ counts.locations }} location{{ counts.locations > 1 ? 's' : '' }} enregistrée{{ counts.locations > 1 ? 's' : '' }}</p>
            </div>
            <a href="{{ path('admin_marketplace_locations') }}" class="mp-card-btn">Consulter</a>
        </div>

        {# ── Calendrier Locations ── #}
        <div class="mp-card">
            <div class="mp-card-icon" style="background: linear-gradient(135deg, #e8f5e9, #fff3e0);">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#20452c" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><circle cx="8" cy="15" r="1.5" fill="#27ae60" stroke="none"/><circle cx="16" cy="15" r="1.5" fill="#e67e22" stroke="none"/></svg>
            </div>
            <div class="mp-card-body">
                <h3>Calendrier Locations</h3>
                <p>Vue calendrier des terrains et véhicules</p>
            </div>
            <a href="{{ path('admin_marketplace_calendrier') }}" class="mp-card-btn">Voir le calendrier</a>
        </div>
    </div>
</div>
{% endblock %}
