{% extends 'admin/base.html.twig' %}
{% import 'admin/marketplace/_macros.html.twig' as macros %}

{% block page_title %}Modifier Véhicule{% endblock %}
{% block admin_page_title %}Modifier — {{ vehicule.nom }}{% endblock %}

{% block admin_content %}
<div class="mp-page">
    <a href="{{ path('admin_marketplace_vehicules') }}" class="mp-back-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Retour à la liste
    </a>

    {{ macros.flashes() }}

    <div class="mp-edit-card">
        {{ form_start(form, {'attr': {'class': 'mp-form', 'enctype': 'multipart/form-data', 'novalidate': 'novalidate'}}) }}
            <div class="mp-form-grid">
                {{ form_row(form.nom) }}
                {{ form_row(form.categorie) }}
                {{ form_row(form.marque) }}
                {{ form_row(form.modele) }}
                {{ form_row(form.immatriculation) }}
                {{ form_row(form.prixJour) }}
                {{ form_row(form.prixSemaine) }}
                {{ form_row(form.prixMois) }}
                {{ form_row(form.caution) }}
                <div>
                    {{ form_row(form.imageFile) }}
                    {% if vehicule.imageUrl %}
                        <p class="mp-current-img-label">Image actuelle :</p>
                        <img src="{{ vehicule.imageUrl }}" alt="" class="mp-current-img">
                    {% endif %}
                </div>
            </div>
            {{ form_row(form.description) }}
            <div class="mp-form-check-row">
                {{ form_row(form.disponible) }}
            </div>
            <div class="mp-form-actions">
                <button type="submit" class="mp-btn mp-btn-primary">Enregistrer les modifications</button>
                <a href="{{ path('admin_marketplace_vehicules') }}" class="mp-btn mp-btn-secondary">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
