{% extends 'admin/base.html.twig' %}
{% import 'admin/marketplace/_macros.html.twig' as macros %}

{% block page_title %}Modifier un Fournisseur{% endblock %}
{% block admin_page_title %}Modifier le Fournisseur{% endblock %}

{% block admin_content %}
<div class="mp-page">
    <a href="{{ path('admin_marketplace_fournisseurs') }}" class="mp-back-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Retour à la liste
    </a>

    {{ macros.flashes() }}

    <div class="mp-edit-card">
        {{ form_start(form, {'attr': {'class': 'mp-form'}}) }}
            <div class="mp-form-grid">
                {{ form_row(form.nomEntreprise) }}
                {{ form_row(form.contactNom) }}
                {{ form_row(form.email) }}
                {{ form_row(form.telephone) }}
                {{ form_row(form.ville) }}
            </div>
            {{ form_row(form.adresse) }}
            <div class="mp-form-check-row">
                {{ form_row(form.actif) }}
            </div>
            <div class="mp-form-actions">
                <button type="submit" class="mp-btn mp-btn-primary">Enregistrer</button>
                <a href="{{ path('admin_marketplace_fournisseurs') }}" class="mp-btn mp-btn-secondary">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
