{% extends 'admin/base.html.twig' %}
{% import 'admin/marketplace/_macros.html.twig' as macros %}

{% block page_title %}Modifier la Location{% endblock %}
{% block admin_page_title %}Location {{ location.numeroLocation }}{% endblock %}

{% block admin_content %}
<div class="mp-page">
    <a href="{{ path('admin_marketplace_locations') }}" class="mp-back-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Retour à la liste
    </a>

    {{ macros.flashes() }}

    <div class="mp-edit-card">
        {# ── Résumé ── #}
        <div class="mp-order-summary">
            <div class="mp-summary-row">
                <span class="mp-label">Client :</span>
                <span>{{ location.utilisateur ? location.utilisateur.fullName : '—' }}</span>
            </div>
            <div class="mp-summary-row">
                <span class="mp-label">Type :</span>
                <span>{{ location.typeLocation|capitalize }}</span>
            </div>
            <div class="mp-summary-row">
                <span class="mp-label">Bien loué :</span>
                <span>{{ location.itemName }}</span>
            </div>
            <div class="mp-summary-row">
                <span class="mp-label">Période :</span>
                <span>
                    {{ location.dateDebut ? location.dateDebut|date('d/m/Y') : '—' }}
                    → {{ location.dateFin ? location.dateFin|date('d/m/Y') : '—' }}
                    ({{ location.dureeJours ?? '?' }} jours)
                </span>
            </div>
            <div class="mp-summary-row">
                <span class="mp-label">Prix total :</span>
                <span><strong>{{ location.prixTotal|number_format(2, ',', ' ') }} TND</strong></span>
            </div>
            <div class="mp-summary-row">
                <span class="mp-label">Caution :</span>
                <span>{{ location.caution ? location.caution|number_format(2, ',', ' ') ~ ' TND' : '—' }}</span>
            </div>
            <div class="mp-summary-row">
                <span class="mp-label">Date réservation :</span>
                <span>{{ location.dateReservation ? location.dateReservation|date('d/m/Y H:i') : '—' }}</span>
            </div>
            {% if location.notes %}
            <div class="mp-summary-row">
                <span class="mp-label">Notes :</span>
                <span>{{ location.notes }}</span>
            </div>
            {% endif %}
        </div>

        {# ── Mise à jour du statut ── #}
        <h3 class="mp-section-title">Mettre à jour le statut</h3>
        <form method="post" action="{{ path('admin_marketplace_locations_edit', {id: location.id}) }}" class="mp-form">
            <input type="hidden" name="_token" value="{{ csrf_token('location_status' ~ location.id) }}">
            <div class="mp-form-grid">
                <div>
                    <label for="statut">Statut</label>
                    <select name="statut" id="statut">
                        {% for val in ['en_attente', 'confirmee', 'en_cours', 'terminee', 'annulee'] %}
                            <option value="{{ val }}" {{ location.statut == val ? 'selected' : '' }}>
                                {{ val|replace({'_': ' '})|capitalize }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
            </div>
            <div class="mp-form-actions">
                <button type="submit" class="mp-btn mp-btn-primary">Enregistrer</button>
                <a href="{{ path('admin_marketplace_locations') }}" class="mp-btn mp-btn-secondary">Annuler</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
