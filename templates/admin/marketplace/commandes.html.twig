{% extends 'admin/base.html.twig' %}
{% import 'admin/marketplace/_macros.html.twig' as macros %}

{% block page_title %}Commandes{% endblock %}
{% block admin_page_title %}Gestion des Commandes{% endblock %}

{% block admin_content %}
<div class="mp-page">
    <a href="{{ path('admin_marketplace') }}" class="mp-back-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Retour au Marketplace
    </a>

    {{ macros.flashes() }}

    {% if commandes is empty %}
        <div class="mp-empty">Aucune commande enregistrée.</div>
    {% else %}
    <div class="mp-toolbar">
        <div class="mp-search-box">
            <svg class="mp-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" class="mp-search" data-table="commandes" placeholder="Rechercher par N°, client…">
        </div>
        <div class="mp-filters">
            <select class="mp-filter" data-table="commandes" data-col="3">
                <option value="">Paiement</option>
                <option value="En attente">En attente</option>
                <option value="Paye">Payé</option>
                <option value="Echoue">Échoué</option>
            </select>
            <select class="mp-filter" data-table="commandes" data-col="4">
                <option value="">Livraison</option>
                <option value="En preparation">En préparation</option>
                <option value="Expedie">Expédié</option>
                <option value="Livre">Livré</option>
                <option value="Annule">Annulé</option>
            </select>
        </div>
    </div>
    <div class="mp-table-wrap">
        <table class="mp-table" id="table-commandes">
            <thead>
                <tr>
                    <th>N° Commande</th>
                    <th>Client</th>
                    <th>Montant</th>
                    <th>Paiement</th>
                    <th>Livraison</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for c in commandes %}
                <tr>
                    <td><strong>{{ c.numeroCommande }}</strong></td>
                    <td>{{ c.utilisateur ? c.utilisateur.fullName : '—' }}</td>
                    <td>{{ c.montantTotal|number_format(2, ',', ' ') }} TND</td>
                    <td>
                        {% set pClass = {
                            'en_attente': 'mp-badge-warning',
                            'paye': 'mp-badge-success',
                            'echoue': 'mp-badge-danger'
                        } %}
                        <span class="mp-badge {{ pClass[c.statutPaiement] ?? '' }}">
                            {{ c.statutPaiement|replace({'_': ' '})|capitalize }}
                        </span>
                    </td>
                    <td>
                        {% set lClass = {
                            'en_attente': 'mp-badge-secondary',
                            'en_preparation': 'mp-badge-warning',
                            'expedie': 'mp-badge-info',
                            'livre': 'mp-badge-success',
                            'annule': 'mp-badge-danger'
                        } %}
                        <span class="mp-badge {{ lClass[c.statutLivraison] ?? '' }}">
                            {{ c.statutLivraison|replace({'_': ' '})|capitalize }}
                        </span>
                    </td>
                    <td>{{ c.dateCommande ? c.dateCommande|date('d/m/Y') : '—' }}</td>
                    <td class="mp-actions">
                        <a href="{{ path('admin_marketplace_commandes_edit', {id: c.id}) }}" class="mp-btn mp-btn-sm mp-btn-edit" title="Modifier le statut">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        </a>
                        <form method="post" action="{{ path('admin_marketplace_commandes_delete', {id: c.id}) }}" data-firma-confirm="Êtes-vous sûr de vouloir supprimer cette commande ? Cette action est irréversible.">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ c.id) }}">
                            <button type="submit" class="mp-btn mp-btn-sm mp-btn-delete" title="Supprimer">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                            </button>
                        </form>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
            <tfoot>
                <tr class="mp-no-results" style="display:none">
                    <td colspan="7">Aucun résultat trouvé.</td>
                </tr>
            </tfoot>
        </table>
    </div>
    {% endif %}
</div>
{% endblock %}
