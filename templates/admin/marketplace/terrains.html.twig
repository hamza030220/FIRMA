{% extends 'admin/base.html.twig' %}
{% import 'admin/marketplace/_macros.html.twig' as macros %}

{% block page_title %}Terrains{% endblock %}
{% block admin_page_title %}Gestion des Terrains{% endblock %}

{% block admin_content %}
<div class="mp-page">
    <a href="{{ path('admin_marketplace') }}" class="mp-back-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Retour au Marketplace
    </a>

    {{ macros.flashes() }}

    <div class="mp-tabs">
        <button class="mp-tab {{ not formHasErrors ? 'active' : '' }}" data-tab="list">Liste des Terrains</button>
        <button class="mp-tab {{ formHasErrors ? 'active' : '' }}" data-tab="add">Ajouter un Terrain</button>
    </div>

    {# ── TAB 1 : Liste ── #}
    <div class="mp-tab-pane {{ not formHasErrors ? 'active' : '' }}" id="tab-list">
        {% if terrains is empty %}
            <div class="mp-empty">Aucun terrain enregistré.</div>
        {% else %}
        <div class="mp-toolbar">
            <div class="mp-search-box">
                <svg class="mp-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" class="mp-search" data-table="terrains" placeholder="Rechercher par titre, ville, catégorie…">
            </div>
            <div class="mp-filters">
                <select class="mp-filter" data-table="terrains" data-col="6">
                    <option value="">Disponibilité</option>
                    <option value="Oui">Disponible</option>
                    <option value="Non">Indisponible</option>
                </select>
            </div>
        </div>
        <div class="mp-table-wrap">
            <table class="mp-table" id="table-terrains">
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Titre</th>
                        <th>Catégorie</th>
                        <th>Ville</th>
                        <th>Superficie</th>
                        <th>Prix/mois</th>
                        <th>Disponible</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for t in terrains %}
                    <tr>
                        <td>
                            {% if t.imageUrl %}
                                <img src="{{ asset(t.imageUrl) }}" alt="" class="mp-thumb" loading="lazy">
                            {% else %}
                                <span class="mp-no-img">—</span>
                            {% endif %}
                        </td>
                        <td>{{ t.titre }}</td>
                        <td>{{ t.categorie }}</td>
                        <td>{{ t.ville }}</td>
                        <td>{{ t.superficieHectares }} ha</td>
                        <td>{{ t.prixMois ? t.prixMois|number_format(2, ',', ' ') ~ ' TND' : '—' }}</td>
                        <td>
                            <span class="mp-badge {{ t.disponible ? 'mp-badge-success' : 'mp-badge-danger' }}">
                                {{ t.disponible ? 'Oui' : 'Non' }}
                            </span>
                        </td>
                        <td class="mp-actions">
                            <a href="{{ path('admin_marketplace_terrains_edit', {id: t.id}) }}" class="mp-btn mp-btn-sm mp-btn-edit" title="Modifier">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                            </a>
                            <form method="post" action="{{ path('admin_marketplace_terrains_delete', {id: t.id}) }}" data-firma-confirm="Êtes-vous sûr de vouloir supprimer ce terrain ? Cette action est irréversible.">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ t.id) }}">
                                <button type="submit" class="mp-btn mp-btn-sm mp-btn-delete" title="Supprimer">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                </button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
                <tfoot>
                    <tr class="mp-no-results" style="display:none">
                        <td colspan="8">Aucun résultat trouvé.</td>
                    </tr>
                </tfoot>
            </table>
        </div>
        {% endif %}
    </div>

    {# ── TAB 2 : Ajouter ── #}
    <div class="mp-tab-pane {{ formHasErrors ? 'active' : '' }}" id="tab-add">
        {{ form_start(form, {'attr': {'class': 'mp-form', 'enctype': 'multipart/form-data', 'novalidate': 'novalidate'}}) }}
            <div class="mp-form-grid">
                {{ form_row(form.titre) }}
                {{ form_row(form.categorie) }}
                {{ form_row(form.ville) }}
                {{ form_row(form.superficieHectares) }}
                {{ form_row(form.prixMois) }}
                {{ form_row(form.prixAnnee) }}
                {{ form_row(form.caution) }}
                {{ form_row(form.imageFile) }}
            </div>
            <div style="display:flex;align-items:flex-end;gap:8px;">
                <div style="flex:1;">{{ form_row(form.adresse) }}</div>
                <button type="button" class="firma-map-btn" style="margin-bottom:6px;" title="Choisir sur la carte"
                    onclick="firmaMapPicker({adresseFieldId:'{{ form.adresse.vars.id }}',villeFieldId:'{{ form.ville.vars.id }}'})">
                    <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </button>
            </div>
            {{ form_row(form.description) }}
            <div class="mp-form-check-row">
                {{ form_row(form.disponible) }}
            </div>
            <div class="mp-form-actions">
                <button type="submit" class="mp-btn mp-btn-primary">Ajouter le terrain</button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
