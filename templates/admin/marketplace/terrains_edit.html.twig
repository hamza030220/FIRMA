{% extends 'admin/base.html.twig' %}
{% import 'admin/marketplace/_macros.html.twig' as macros %}

{% block page_title %}Modifier un Terrain{% endblock %}
{% block admin_page_title %}Modifier le Terrain{% endblock %}

{% block admin_content %}
<div class="mp-page">
    <a href="{{ path('admin_marketplace_terrains') }}" class="mp-back-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Retour à la liste
    </a>

    {{ macros.flashes() }}

    <div class="mp-edit-card">
        {{ form_start(form, {'attr': {'class': 'mp-form', 'enctype': 'multipart/form-data'}}) }}
            {% if terrain.imageUrl %}
                <div class="mp-current-img">
                    <span class="mp-current-img-label">Image actuelle :</span>
                    <img src="{{ terrain.imageUrl }}" alt="">
                </div>
            {% endif %}
            <div class="mp-form-grid">
                {{ form_row(form.titre) }}
                {{ form_row(form.categorie) }}
                {{ form_row(form.ville) }}
                {{ form_row(form.superficieHectares) }}
                {{ form_row(form.prixMois) }}
                {{ form_row(form.prixAnnee) }}
                {{ form_row(form.caution) }}
                {{ form_row(form.imageFile) }}
            </div>
            <div style="display:flex;align-items:flex-end;gap:8px;">
                <div style="flex:1;">{{ form_row(form.adresse) }}</div>
                <button type="button" class="firma-map-btn" style="margin-bottom:6px;" title="Modifier la localisation"
                    onclick="firmaMapPicker({adresseFieldId:'{{ form.adresse.vars.id }}',villeFieldId:'{{ form.ville.vars.id }}',currentAdresse:'{{ terrain.adresse|default('')|e('js') }}',currentVille:'{{ terrain.ville|default('')|e('js') }}'})">
                    <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </button>
            </div>
            {{ form_row(form.description) }}
            <div class="mp-form-check-row">
                {{ form_row(form.disponible) }}
            </div>
            <div class="mp-form-actions">
                <button type="submit" class="mp-btn mp-btn-primary">Enregistrer</button>
                <a href="{{ path('admin_marketplace_terrains') }}" class="mp-btn mp-btn-secondary">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
