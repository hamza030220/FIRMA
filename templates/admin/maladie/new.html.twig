{% extends 'admin/base.html.twig' %}

{% block page_title %}Nouvelle maladie{% endblock %}
{% block admin_page_title %}Nouvelle maladie{% endblock %}

{% block admin_content %}

<style>
.form-wrap{max-width:1040px;margin:0 auto;padding-bottom:2rem}
.back-link{display:inline-flex;align-items:center;gap:8px;font-size:14px;color:#4a5a51;text-decoration:none;margin-bottom:1.2rem;transition:color .18s}
.back-link:hover{color:#173d2a}
.back-link svg{width:16px;height:16px}
.new-hero{position:relative;overflow:hidden;background:linear-gradient(135deg,#163d2b 0%,#24593f 45%,#d9ead7 140%);border-radius:28px;padding:1.7rem 1.8rem;margin-bottom:1.4rem;color:#fff;box-shadow:0 20px 45px rgba(16,53,35,.16)}
.new-hero::after{content:"";position:absolute;width:220px;height:220px;border-radius:50%;background:rgba(255,255,255,.09);top:-70px;right:-40px}
.new-hero-grid{position:relative;display:grid;grid-template-columns:1.25fr .85fr;gap:1rem;align-items:end}
.new-kicker{display:inline-flex;align-items:center;gap:8px;padding:6px 10px;border-radius:999px;background:rgba(255,255,255,.12);font-size:12px;letter-spacing:.04em;text-transform:uppercase}
.new-title{font-size:clamp(28px,4vw,40px);line-height:1.03;margin:.85rem 0 .7rem;font-weight:700;max-width:11ch}
.new-subtitle{margin:0;max-width:58ch;color:rgba(255,255,255,.86);font-size:14px;line-height:1.7}
.new-hero-stats{display:grid;grid-template-columns:repeat(2,1fr);gap:.85rem}
.new-stat{background:rgba(255,255,255,.12);backdrop-filter:blur(6px);border:1px solid rgba(255,255,255,.14);border-radius:20px;padding:1rem}
.new-stat strong{display:block;font-size:22px;margin-bottom:4px}
.new-stat span{font-size:12px;color:rgba(255,255,255,.82)}
.form-card{background:#fcfdf9;border:1px solid rgba(23,61,42,.08);border-radius:28px;overflow:hidden;box-shadow:0 18px 40px rgba(14,38,27,.08)}
.form-card-header{padding:1.35rem 1.5rem;border-bottom:1px solid rgba(23,61,42,.08);display:flex;align-items:center;gap:12px;background:linear-gradient(180deg,#f7fbf5 0%,#fcfdf9 100%)}
.form-card-header h2{font-size:17px;font-weight:700;color:#173d2a;margin:0}
.header-icon{width:42px;height:42px;border-radius:14px;background:linear-gradient(135deg,#dcefd8,#eef7ec);display:flex;align-items:center;justify-content:center;box-shadow:inset 0 0 0 1px rgba(36,89,63,.08)}
.header-icon svg{width:18px;height:18px;color:#24593f}
.form-body{padding:1.55rem;display:grid;grid-template-columns:1fr 1fr;gap:1.2rem}
.form-group{display:flex;flex-direction:column;gap:7px}
.form-group.full{grid-column:1/-1}
.form-label{font-size:13px;font-weight:700;color:#173d2a}
.form-label .req{color:#b42318;margin-left:2px}
.form-label .hint{font-weight:500;color:#6a7d72;font-size:12px;margin-left:6px}
.form-input,.form-select,.form-textarea{width:100%;padding:11px 13px;border:1px solid #d7e2da;border-radius:16px;background:#fff;font-size:14px;color:#162c21;outline:none;transition:border-color .18s,box-shadow .18s,transform .18s;font-family:var(--font-sans);box-shadow:0 1px 0 rgba(12,37,25,.02)}
.form-input:focus,.form-select:focus,.form-textarea:focus{border-color:#2f7d55;box-shadow:0 0 0 4px rgba(47,125,85,.10)}
.form-input.is-error,.form-select.is-error,.form-textarea.is-error{border-color:#d44b4b;background:#fff8f8}
.form-input.is-valid,.form-select.is-valid,.form-textarea.is-valid{border-color:#3b6d11;background:#fbfff8}
.form-textarea{resize:vertical;min-height:120px;line-height:1.65}
.error-msg{font-size:12px;color:#a32d2d;display:flex;align-items:center;gap:5px}
.error-msg svg{width:12px;height:12px;flex-shrink:0}
.char-count{font-size:11px;color:#708176;text-align:right;margin-top:2px}
.char-count.warn{color:#9a6b12}
.char-count.over{color:#a32d2d}
.gravite-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.gravite-option{position:relative}
.gravite-option input{position:absolute;opacity:0;width:0;height:0}
.gravite-label{display:flex;flex-direction:column;align-items:center;gap:8px;padding:14px 10px;border:1px solid #d7e2da;border-radius:18px;cursor:pointer;transition:all .18s;text-align:center;background:#fff}
.gravite-label:hover{transform:translateY(-1px);box-shadow:0 10px 20px rgba(18,46,32,.05)}
.gravite-option input:checked + .gravite-label{border-width:1.5px}
.gl-faible input:checked + .gravite-label{border-color:#3b6d11;background:#edf8e9}
.gl-moyen input:checked + .gravite-label{border-color:#185fa5;background:#ebf4fd}
.gl-eleve input:checked + .gravite-label{border-color:#854f0b;background:#fff3df}
.gl-critique input:checked + .gravite-label{border-color:#a32d2d;background:#fff0f0}
.gravite-dot{width:12px;height:12px;border-radius:50%}
.gd-f{background:#3b6d11}.gd-m{background:#185fa5}.gd-e{background:#854f0b}.gd-c{background:#a32d2d}
.gravite-name{font-size:12px;font-weight:700;color:#173d2a}
.upload-zone{border:1px dashed #c8d8ce;border-radius:22px;padding:1.65rem;text-align:center;cursor:pointer;transition:all .18s;background:linear-gradient(180deg,#f7fbf8 0%,#ffffff 100%)}
.upload-zone:hover{border-color:#2f7d55;background:#fbfffc}
.upload-zone.dragover{border-color:#2f7d55;background:#eef8f0}
.upload-zone input{display:none}
.upload-icon{width:46px;height:46px;border-radius:50%;background:#fff;border:1px solid #d7e2da;display:flex;align-items:center;justify-content:center;margin:0 auto 10px}
.upload-icon svg{width:18px;height:18px;color:#4f6558}
.upload-text{font-size:14px;color:#607168}
.upload-text strong{color:#173d2a}
.upload-hint{font-size:12px;color:#718279;margin-top:4px}
.preview-wrap{margin-top:12px;display:none}
.preview-wrap img{max-height:120px;border-radius:16px;border:1px solid #d7e2da}
.form-footer{padding:1.2rem 1.5rem;border-top:1px solid rgba(23,61,42,.08);display:flex;align-items:center;gap:10px;justify-content:flex-end;background:#f7fbf8}
.btn-submit{display:inline-flex;align-items:center;gap:8px;background:linear-gradient(135deg,#24593f,#2f7d55);color:#fff;border:none;padding:11px 24px;border-radius:16px;font-size:14px;font-weight:700;cursor:pointer;transition:transform .18s,box-shadow .18s}
.btn-submit:hover{transform:translateY(-1px);box-shadow:0 14px 25px rgba(36,89,63,.22)}
.btn-cancel{display:inline-flex;align-items:center;gap:7px;padding:11px 20px;border:1px solid #d7e2da;border-radius:16px;font-size:14px;color:#52655b;text-decoration:none;background:#fff;transition:all .18s}
.btn-cancel:hover{background:#f2f7f3;color:#173d2a}
.alert-error{display:flex;align-items:center;gap:10px;background:#fff2f1;border:1px solid #f5c5c0;border-radius:18px;padding:12px 14px;margin-bottom:1rem;font-size:14px;color:#791f1f}
@media (max-width: 900px){
  .new-hero-grid{grid-template-columns:1fr}
}
@media (max-width: 720px){
  .form-wrap{max-width:100%}
  .form-body{grid-template-columns:1fr}
  .gravite-grid{grid-template-columns:repeat(2,1fr)}
  .form-footer{flex-direction:column-reverse;align-items:stretch}
  .btn-submit,.btn-cancel{justify-content:center}
}
</style>

<div class="form-wrap">
    <a href="{{ path('admin_maladie_index') }}" class="back-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Retour à la liste
    </a>

    <section class="new-hero">
        <div class="new-hero-grid">
            <div>
                <span class="new-kicker">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20"/><path d="M2 12h20"/></svg>
                    Gestion Maladie
                </span>
                <h2 class="new-title">Ajouter une fiche maladie claire et complete</h2>
                <p class="new-subtitle">Renseignez les symptomes, la gravite et le contexte de la maladie dans une page plus propre, sans modifier les autres ecrans du projet.</p>
            </div>
            <div class="new-hero-stats">
                <div class="new-stat">
                    <strong>3</strong>
                    <span>zones importantes a verifier</span>
                </div>
                <div class="new-stat">
                    <strong>1</strong>
                    <span>image optionnelle pour enrichir la fiche</span>
                </div>
            </div>
        </div>
    </section>

    {% if errors is defined and errors|length > 0 %}
    <div class="alert-error">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        Veuillez corriger les {{ errors|length }} erreur(s) avant de soumettre.
    </div>
    {% endif %}

    <form method="post" enctype="multipart/form-data" novalidate id="newMaladieForm">
        <div class="form-card">
            <div class="form-card-header">
                <div class="header-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                </div>
                <h2>Ajouter une nouvelle maladie</h2>
            </div>

            <div class="form-body">

                {# NOM #}
                <div class="form-group">
                    <label class="form-label">Nom <span class="req">*</span><span class="hint">min. 3 caractères</span></label>
                    <input type="text" name="nom" id="nom"
                        class="form-input {% if errors.nom is defined %}is-error{% elseif old.nom is defined and old.nom %}is-valid{% endif %}"
                        value="{{ old.nom|default('') }}"
                        maxlength="150"
                        placeholder="Ex: Mildiou"
                        oninput="countChars(this,'nom-count',150)">
                    <span class="char-count" id="nom-count">0 / 150</span>
                    {% if errors.nom is defined %}
                    <span class="error-msg">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        {{ errors.nom }}
                    </span>
                    {% endif %}
                </div>

                {# NOM SCIENTIFIQUE #}
                <div class="form-group">
                    <label class="form-label">Nom scientifique <span class="hint">optionnel</span></label>
                    <input type="text" name="nomScientifique" id="nomSci"
                        class="form-input {% if errors.nomScientifique is defined %}is-error{% elseif old.nomScientifique is defined and old.nomScientifique %}is-valid{% endif %}"
                        value="{{ old.nomScientifique|default('') }}"
                        maxlength="200"
                        placeholder="Ex: Phytophthora infestans"
                        oninput="countChars(this,'sci-count',200)">
                    <span class="char-count" id="sci-count">0 / 200</span>
                    {% if errors.nomScientifique is defined %}
                    <span class="error-msg">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        {{ errors.nomScientifique }}
                    </span>
                    {% endif %}
                </div>

                {# DESCRIPTION #}
                <div class="form-group full">
                    <label class="form-label">Description <span class="req">*</span><span class="hint">min. 10 caractères</span></label>
                    <textarea name="description" id="desc"
                        class="form-textarea {% if errors.description is defined %}is-error{% elseif old.description is defined and old.description %}is-valid{% endif %}"
                        maxlength="2000"
                        placeholder="Décrivez la maladie, son origine et ses caractéristiques..."
                        oninput="countChars(this,'desc-count',2000)">{{ old.description|default('') }}</textarea>
                    <span class="char-count" id="desc-count">0 / 2000</span>
                    {% if errors.description is defined %}
                    <span class="error-msg">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        {{ errors.description }}
                    </span>
                    {% endif %}
                </div>

                {# SYMPTOMES #}
                <div class="form-group full">
                    <label class="form-label">Symptômes <span class="req">*</span><span class="hint">min. 10 caractères</span></label>
                    <textarea name="symptomes" id="symp"
                        class="form-textarea {% if errors.symptomes is defined %}is-error{% elseif old.symptomes is defined and old.symptomes %}is-valid{% endif %}"
                        maxlength="2000"
                        placeholder="Décrivez les symptômes visibles sur la plante..."
                        oninput="countChars(this,'symp-count',2000)">{{ old.symptomes|default('') }}</textarea>
                    <span class="char-count" id="symp-count">0 / 2000</span>
                    {% if errors.symptomes is defined %}
                    <span class="error-msg">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        {{ errors.symptomes }}
                    </span>
                    {% endif %}
                </div>

                {# GRAVITE #}
                <div class="form-group full">
                    <label class="form-label">Niveau de gravité <span class="req">*</span></label>
                    <div class="gravite-grid">
                        {% for val, label in {faible: 'Faible', moyen: 'Moyen', eleve: 'Élevé', critique: 'Critique'} %}
                        <div class="gravite-option gl-{{ val }}">
                            <input type="radio" name="niveauGravite" id="g-{{ val }}" value="{{ val }}"
                                {{ (old.niveauGravite|default('moyen')) == val ? 'checked' : '' }}>
                            <label class="gravite-label" for="g-{{ val }}">
                                <span class="gravite-dot gd-{{ val|slice(0,1) }}"></span>
                                <span class="gravite-name">{{ label }}</span>
                            </label>
                        </div>
                        {% endfor %}
                    </div>
                    {% if errors.niveauGravite is defined %}
                    <span class="error-msg">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        {{ errors.niveauGravite }}
                    </span>
                    {% endif %}
                </div>

                {# SAISON #}
                <div class="form-group">
                    <label class="form-label">Saison fréquente</label>
                    <select name="saisonFrequente" class="form-select {% if errors.saisonFrequente is defined %}is-error{% endif %}">
                        <option value="">Toute l'année</option>
                        {% for s in ['Printemps', 'Été', 'Automne', 'Hiver', 'Printemps-Été', 'Printemps-Automne'] %}
                        <option value="{{ s }}" {{ old.saisonFrequente|default('') == s ? 'selected' : '' }}>{{ s }}</option>
                        {% endfor %}
                    </select>
                    {% if errors.saisonFrequente is defined %}
                    <span class="error-msg">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        {{ errors.saisonFrequente }}
                    </span>
                    {% endif %}
                </div>

                <div class="form-group">
                    <label class="form-label">Temp min risque <span class="hint">optionnel</span></label>
                    <input type="number" step="0.1" name="tempMin" class="form-input {% if errors.tempMin is defined or errors.tempRange is defined %}is-error{% endif %}" value="{{ old.tempMin|default('') }}" placeholder="Ex: 15">
                    {% if errors.tempMin is defined %}
                    <span class="error-msg">{{ errors.tempMin }}</span>
                    {% elseif errors.tempRange is defined %}
                    <span class="error-msg">{{ errors.tempRange }}</span>
                    {% endif %}
                </div>

                <div class="form-group">
                    <label class="form-label">Temp max risque <span class="hint">optionnel</span></label>
                    <input type="number" step="0.1" name="tempMax" class="form-input {% if errors.tempMax is defined or errors.tempRange is defined %}is-error{% endif %}" value="{{ old.tempMax|default('') }}" placeholder="Ex: 25">
                    {% if errors.tempMax is defined %}
                    <span class="error-msg">{{ errors.tempMax }}</span>
                    {% elseif errors.tempRange is defined %}
                    <span class="error-msg">{{ errors.tempRange }}</span>
                    {% endif %}
                </div>

                <div class="form-group">
                    <label class="form-label">Humidite min risque <span class="hint">optionnel</span></label>
                    <input type="number" min="0" max="100" name="humiditeMin" class="form-input {% if errors.humiditeMin is defined %}is-error{% endif %}" value="{{ old.humiditeMin|default('') }}" placeholder="Ex: 80">
                    {% if errors.humiditeMin is defined %}
                    <span class="error-msg">{{ errors.humiditeMin }}</span>
                    {% endif %}
                </div>

                {# IMAGE #}
                <div class="form-group full">
                    <label class="form-label">Photo <span class="hint">JPG, PNG, WEBP · max 2MB</span></label>
                    <div class="upload-zone {% if errors.imageFile is defined %}is-error{% endif %}" id="dropZone" onclick="document.getElementById('imageFile').click()">
                        <input type="file" name="imageFile" id="imageFile" accept="image/*" onchange="previewImage(this)">
                        <div class="upload-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                        </div>
                        <div class="upload-text"><strong>Cliquez</strong> ou glissez une image ici</div>
                        <div class="upload-hint">JPG, PNG, WEBP ou GIF · Maximum 2 MB</div>
                        <div class="preview-wrap" id="previewWrap">
                            <img id="previewImg" src="" alt="Aperçu">
                        </div>
                    </div>
                    {% if errors.imageFile is defined %}
                    <span class="error-msg">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        {{ errors.imageFile }}
                    </span>
                    {% endif %}
                </div>

            </div>{# end form-body #}

            <div class="form-footer">
                <a href="{{ path('admin_maladie_index') }}" class="btn-cancel">Annuler</a>
                <button type="submit" class="btn-submit">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                    Enregistrer la maladie
                </button>
            </div>
        </div>
    </form>
</div>

<script>
const serverFlashMessages = [
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            { message: {{ message|json_encode|raw }}, type: {{ type|json_encode|raw }} },
        {% endfor %}
    {% endfor %}
];

const serverValidationErrors = [
    {% for field, message in errors %}
        {{ message|json_encode|raw }},
    {% endfor %}
];

function countChars(el, countId, max) {
    const len = el.value.length;
    const counter = document.getElementById(countId);
    counter.textContent = len + ' / ' + max;
    counter.className = 'char-count' + (len > max * 0.9 ? (len >= max ? ' over' : ' warn') : '');
}

function previewImage(input) {
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = e => {
            document.getElementById('previewImg').src = e.target.result;
            document.getElementById('previewWrap').style.display = 'block';
        };
        reader.readAsDataURL(input.files[0]);
    }
}

// Drag & drop
const zone = document.getElementById('dropZone');
zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('dragover'); });
zone.addEventListener('dragleave', () => zone.classList.remove('dragover'));
zone.addEventListener('drop', e => {
    e.preventDefault();
    zone.classList.remove('dragover');
    const input = document.getElementById('imageFile');
    input.files = e.dataTransfer.files;
    previewImage(input);
});

// Init compteurs
document.querySelectorAll('[oninput]').forEach(el => el.dispatchEvent(new Event('input')));

document.addEventListener('DOMContentLoaded', () => {
    if (window.firmaToast) {
        serverFlashMessages.forEach(({ message, type }) => {
            window.firmaToast(message, type === 'error' ? 'danger' : type);
        });

        serverValidationErrors.forEach((message) => {
            window.firmaToast(message, 'danger');
        });
    }
});

document.getElementById('newMaladieForm')?.addEventListener('submit', function(e) {
    const nom = document.getElementById('nom');
    const description = document.getElementById('desc');
    const symptomes = document.getElementById('symp');
    let isValid = true;

    if (!nom.value.trim() || nom.value.trim().length < 3) {
        nom.classList.add('is-error');
        isValid = false;
    }

    if (!description.value.trim() || description.value.trim().length < 10) {
        description.classList.add('is-error');
        isValid = false;
    }

    if (!symptomes.value.trim() || symptomes.value.trim().length < 10) {
        symptomes.classList.add('is-error');
        isValid = false;
    }

    if (!isValid) {
        e.preventDefault();
        if (window.firmaToast) {
            window.firmaToast('Veuillez corriger les champs obligatoires avant de continuer.', 'danger');
        }
        (nom.value.trim().length < 3 ? nom : (!description.value.trim() || description.value.trim().length < 10 ? description : symptomes)).focus();
    }
});
</script>

{% endblock %}
