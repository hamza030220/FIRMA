{% extends 'admin/base.html.twig' %}

{% block page_title %}Modifier - {{ maladie.nom }}{% endblock %}
{% block admin_page_title %}Modifier la maladie{% endblock %}

{% block admin_content %}
<style>
:root {
    --primary: #0f5c2f;
    --primary-dark: #0a3d1f;
    --primary-light: #e8f5e9;
    --secondary: #1e6f9f;
    --secondary-light: #e3f2fd;
    --danger: #e74c3c;
    --danger-light: #fdeaea;
    --warning: #f39c12;
    --warning-light: #fff3e0;
    --success: #27ae60;
    --success-light: #eafaf1;
    --gray-50: #f8f9fa;
    --gray-100: #f5f5f5;
    --gray-200: #eeeeee;
    --gray-300: #e0e0e0;
    --gray-400: #bdbdbd;
    --gray-600: #757575;
    --gray-700: #616161;
    --gray-800: #424242;
    --gray-900: #212121;
    --shadow-sm: 0 1px 3px rgba(0,0,0,0.07);
    --shadow-md: 0 4px 16px rgba(0,0,0,0.08);
    --radius: 16px;
    --radius-md: 12px;
    --radius-sm: 8px;
}

* { box-sizing: border-box; }

.edt-wrap { max-width: 1400px; margin: 0 auto; padding: 0 0 3rem; font-family: 'Plus Jakarta Sans', 'Segoe UI', sans-serif; }
.edt-hero {
    position: relative;
    overflow: hidden;
    margin-bottom: 1.6rem;
    padding: 1.7rem 1.8rem;
    border-radius: 28px;
    background: linear-gradient(135deg, #163d2b 0%, #24593f 48%, #dcebd9 145%);
    color: #fff;
    box-shadow: 0 20px 45px rgba(16, 53, 35, 0.16);
}
.edt-hero::after {
    content: "";
    position: absolute;
    width: 240px;
    height: 240px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    top: -80px;
    right: -50px;
}
.edt-hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1.25fr 0.85fr;
    gap: 1rem;
    align-items: end;
}
.edt-hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.38rem 0.72rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.12);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}
.edt-hero h1 {
    margin: 0.85rem 0 0.55rem;
    font-size: clamp(1.9rem, 4vw, 2.7rem);
    line-height: 1.04;
    max-width: 12ch;
}
.edt-hero p {
    margin: 0;
    max-width: 58ch;
    color: rgba(255,255,255,0.86);
    font-size: 0.93rem;
    line-height: 1.7;
}
.edt-hero-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.8rem;
}
.edt-hero-stat {
    padding: 1rem;
    border-radius: 20px;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.14);
    backdrop-filter: blur(6px);
}
.edt-hero-stat strong {
    display: block;
    margin-bottom: 0.25rem;
    font-size: 1.35rem;
}
.edt-hero-stat span {
    font-size: 0.76rem;
    color: rgba(255,255,255,0.82);
}

/* ===== TOPBAR ===== */
.edt-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2rem;
}
.edt-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.83rem;
    color: var(--gray-600);
}
.edt-breadcrumb a { color: var(--primary); text-decoration: none; font-weight: 500; }
.edt-breadcrumb a:hover { text-decoration: underline; }
.edt-breadcrumb-sep { color: var(--gray-400); }
.edt-header-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

/* ===== BUTTONS ===== */
.edt-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.55rem 1.1rem;
    border-radius: var(--radius-sm);
    font-size: 0.83rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    text-decoration: none;
    transition: all 0.18s;
    white-space: nowrap;
    font-family: inherit;
}
.edt-btn-primary { background: var(--primary); color: white; }
.edt-btn-primary:hover { background: var(--primary-dark); color: white; }
.edt-btn-view { background: var(--secondary-light); color: var(--secondary); border: 1px solid #b3d4f0; }
.edt-btn-view:hover { background: #c8e3f5; }
.edt-btn-delete { background: var(--danger-light); color: var(--danger); border: 1px solid #f5b8b2; }
.edt-btn-delete:hover { background: #fcc9c4; }
.edt-btn-cancel { background: var(--gray-100); color: var(--gray-700); border: 1px solid var(--gray-300); }
.edt-btn-cancel:hover { background: var(--gray-200); color: var(--gray-900); }
.edt-btn-add { background: var(--secondary); color: white; }
.edt-btn-add:hover { background: #155a82; color: white; }
.edt-btn-save { background: var(--primary); color: white; padding: 0.7rem 1.8rem; font-size: 0.9rem; }
.edt-btn-save:hover { background: var(--primary-dark); }

/* ===== GRID ===== */
.edt-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 1.5rem; }

/* ===== CARD ===== */
.edt-card {
    background: #fcfdf9;
    border-radius: var(--radius);
    border: 1px solid rgba(23,61,42,0.08);
    box-shadow: 0 18px 40px rgba(14,38,27,0.08);
    overflow: hidden;
}
.edt-card-head {
    padding: 1rem 1.4rem;
    border-bottom: 1px solid rgba(23,61,42,0.08);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: linear-gradient(180deg, #f7fbf5 0%, #fcfdf9 100%);
}
.edt-card-head-icon {
    width: 32px; height: 32px;
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
.edt-card-head-icon.green { background: var(--primary-light); color: var(--primary); }
.edt-card-head-icon.blue { background: var(--secondary-light); color: var(--secondary); }
.edt-card-head h2 { font-size: 0.95rem; font-weight: 600; color: var(--gray-800); margin: 0; flex: 1; }
.edt-card-count {
    background: var(--primary-light); color: var(--primary);
    padding: 0.15rem 0.6rem; border-radius: 20px;
    font-size: 0.72rem; font-weight: 700;
}
.edt-card-body { padding: 1.4rem; }

/* ===== FORM ===== */
.edt-form-group { margin-bottom: 1.1rem; }
.edt-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--gray-600);
    margin-bottom: 0.4rem;
}
.edt-label .req { color: var(--danger); margin-left: 2px; }
.edt-input, .edt-select, .edt-textarea {
    width: 100%;
    padding: 0.78rem 0.95rem;
    border: 1px solid #d7e2da;
    border-radius: 16px;
    font-size: 0.875rem;
    font-family: inherit;
    color: #162c21;
    background: #fff;
    transition: border-color 0.18s, box-shadow 0.18s, transform 0.18s;
    outline: none;
}
.edt-input:focus, .edt-select:focus, .edt-textarea:focus {
    border-color: #2f7d55;
    box-shadow: 0 0 0 4px rgba(47,125,85,0.10);
}
.edt-input.invalid { border-color: var(--danger); box-shadow: 0 0 0 3px rgba(231,76,60,0.08); }
.edt-input.valid { border-color: var(--success); }
.edt-select.invalid { border-color: var(--danger); box-shadow: 0 0 0 3px rgba(231,76,60,0.08); }
.edt-select.valid { border-color: var(--success); }
.edt-textarea { resize: vertical; min-height: 90px; line-height: 1.5; }
.edt-err { font-size: 0.72rem; color: var(--danger); margin-top: 0.3rem; display: none; }
.edt-err.show { display: block; }

.edt-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.edt-inline-help { font-size: 0.72rem; color: var(--gray-600); margin-top: 0.35rem; line-height: 1.5; }

/* ===== GRAVITÉ RADIO ===== */
.edt-gravite-group { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.5rem; }
.edt-grav-opt input { display: none; }
.edt-grav-lbl {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    padding: 0.7rem 0.4rem;
    background: var(--gray-50);
    border: 2px solid var(--gray-200);
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--gray-600);
    text-align: center;
    transition: all 0.15s;
}
.edt-grav-lbl:hover { border-color: var(--gray-400); background: var(--gray-100); }
.edt-grav-opt input:checked + .edt-grav-lbl {
    border-color: var(--primary);
    background: var(--primary-light);
    color: var(--primary);
}
.edt-grav-lbl-faible input:checked + .edt-grav-lbl { border-color: var(--success); background: var(--success-light); color: var(--success); }
.edt-grav-lbl-eleve input:checked + .edt-grav-lbl { border-color: var(--warning); background: var(--warning-light); color: var(--warning); }
.edt-grav-lbl-critique input:checked + .edt-grav-lbl { border-color: var(--danger); background: var(--danger-light); color: var(--danger); }

/* ===== UPLOAD ===== */
.edt-current-img {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.7rem;
    background: var(--gray-50);
    border-radius: var(--radius-sm);
    border: 1px solid var(--gray-200);
    margin-bottom: 0.75rem;
}
.edt-current-img img { width: 52px; height: 52px; object-fit: cover; border-radius: var(--radius-sm); }
.edt-current-img span { font-size: 0.78rem; color: var(--gray-600); }
.edt-upload-zone {
    border: 2px dashed var(--gray-300);
    border-radius: var(--radius-sm);
    padding: 1.2rem;
    text-align: center;
    cursor: pointer;
    background: var(--gray-50);
    transition: all 0.18s;
    font-size: 0.83rem;
    color: var(--gray-600);
}
.edt-upload-zone:hover { border-color: var(--primary); background: var(--primary-light); color: var(--primary); }
.edt-upload-zone svg { margin-bottom: 0.4rem; }
.edt-upload-hint { font-size: 0.72rem; color: var(--gray-400); margin-top: 0.25rem; }
.edt-preview { display: none; margin-top: 0.75rem; }
.edt-preview img { max-height: 90px; border-radius: var(--radius-sm); border: 1px solid var(--gray-200); }

/* ===== SOLUTIONS HEADER ===== */
.edt-sol-toprow {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 1.1rem;
}

/* ===== SOLUTION ITEM ===== */
.edt-sol-item {
    background: #fff;
    border: 1px solid #dce5de;
    border-radius: var(--radius-md);
    margin-bottom: 0.75rem;
    overflow: hidden;
    transition: box-shadow 0.18s;
}
.edt-sol-item:hover { box-shadow: 0 16px 30px rgba(16,53,35,0.08); }
.edt-sol-head {
    padding: 0.85rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--gray-50);
    cursor: pointer;
    user-select: none;
}
.edt-sol-icon {
    width: 30px; height: 30px;
    border-radius: var(--radius-sm);
    background: var(--secondary-light);
    color: var(--secondary);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
.edt-sol-info { flex: 1; min-width: 0; }
.edt-sol-info h3 { font-size: 0.9rem; font-weight: 600; color: var(--gray-800); margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.edt-sol-meta { display: flex; gap: 0.5rem; margin-top: 0.2rem; flex-wrap: wrap; }
.edt-sol-tag { font-size: 0.68rem; padding: 0.1rem 0.45rem; border-radius: 10px; background: var(--gray-200); color: var(--gray-600); }
.edt-sol-stats { display: flex; align-items: center; gap: 0.6rem; }
.edt-sol-stat { font-size: 0.75rem; font-weight: 600; }
.edt-sol-stat.pos { color: var(--success); }
.edt-sol-stat.neg { color: var(--danger); }
.edt-sol-stat.rate { color: var(--secondary); }
.edt-sol-btns { display: flex; gap: 0.35rem; }
.edt-sol-btn {
    width: 30px; height: 30px;
    border-radius: var(--radius-sm);
    border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.15s;
}
.edt-sol-btn.edit { background: var(--warning-light); color: #b36b00; }
.edt-sol-btn.edit:hover { background: var(--warning); color: white; }
.edt-sol-btn.del { background: var(--danger-light); color: var(--danger); }
.edt-sol-btn.del:hover { background: var(--danger); color: white; }
.edt-sol-chev { color: var(--gray-400); transition: transform 0.2s; flex-shrink: 0; }
.edt-sol-chev.open { transform: rotate(180deg); }

.edt-sol-body {
    display: none;
    padding: 1rem;
    border-top: 1px solid var(--gray-100);
    background: white;
}
.edt-sol-body.open { display: block; }
.edt-sol-section { margin-bottom: 0.8rem; }
.edt-sol-section:last-child { margin-bottom: 0; }
.edt-sol-lbl {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--gray-500, #9e9e9e);
    display: flex; align-items: center; gap: 0.3rem;
    margin-bottom: 0.3rem;
}
.edt-sol-val {
    font-size: 0.875rem;
    color: var(--gray-800);
    background: var(--gray-50);
    border-radius: var(--radius-sm);
    padding: 0.55rem 0.75rem;
    border: 1px solid var(--gray-200);
    line-height: 1.5;
}

/* Stats dans le body */
.edt-sol-stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
    margin-top: 0.8rem;
    padding-top: 0.8rem;
    border-top: 1px solid var(--gray-200);
}
.edt-sol-stat-card {
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-sm);
    padding: 0.5rem;
    text-align: center;
}
.edt-sol-stat-num { font-size: 1rem; font-weight: 700; display: block; color: var(--gray-800); }
.edt-sol-stat-num.green { color: var(--success); }
.edt-sol-stat-num.red { color: var(--danger); }
.edt-sol-stat-num.blue { color: var(--secondary); }
.edt-sol-stat-lbl { font-size: 0.65rem; color: var(--gray-600); margin-top: 0.1rem; display: block; }

/* Progress */
.edt-progress-wrap { margin-top: 0.8rem; }
.edt-progress-label { display: flex; justify-content: space-between; font-size: 0.72rem; color: var(--gray-600); margin-bottom: 0.3rem; }
.edt-progress-bar { height: 5px; background: var(--gray-200); border-radius: 3px; overflow: hidden; }
.edt-progress-fill { height: 100%; border-radius: 3px; background: linear-gradient(90deg, var(--primary), var(--success)); }

/* ===== EMPTY ===== */
.edt-empty {
    text-align: center;
    padding: 3rem 2rem;
    color: var(--gray-400);
}
.edt-empty-icon { width: 60px; height: 60px; background: var(--gray-100); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; }
.edt-empty p { font-size: 0.875rem; color: var(--gray-600); margin: 0 0 1rem; }

/* ===== BOTTOM ACTIONS ===== */
.edt-bottom-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    margin-top: 1.5rem;
}

/* ===== MODAL ===== */
.edt-modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 1000;
    align-items: center;
    justify-content: center;
}
.edt-modal-overlay.open { display: flex; }
.edt-modal {
    background: white;
    border-radius: var(--radius);
    width: 90%;
    max-width: 620px;
    max-height: 88vh;
    overflow-y: auto;
    box-shadow: 0 24px 64px rgba(0,0,0,0.2);
}
.edt-modal-head {
    padding: 1.1rem 1.4rem;
    border-bottom: 1px solid var(--gray-200);
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    background: white;
    z-index: 1;
}
.edt-modal-head h3 { font-size: 1rem; font-weight: 600; color: var(--gray-800); margin: 0; }
.edt-modal-close {
    width: 30px; height: 30px;
    background: var(--gray-100);
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    color: var(--gray-600);
    transition: background 0.15s;
}
.edt-modal-close:hover { background: var(--gray-200); }
.edt-modal-body { padding: 1.4rem; }
.edt-modal-foot {
    padding: 1rem 1.4rem;
    border-top: 1px solid var(--gray-200);
    display: flex;
    justify-content: flex-end;
    gap: 0.6rem;
    background: var(--gray-50);
}

/* ===== RESPONSIVE ===== */
@media (max-width: 1000px) {
    .edt-grid { grid-template-columns: 1fr; }
    .edt-hero-grid { grid-template-columns: 1fr; }
}
@media (max-width: 600px) {
    .edt-form-row { grid-template-columns: 1fr; }
    .edt-gravite-group { grid-template-columns: repeat(2, 1fr); }
    .edt-sol-stats { display: none; }
    .edt-sol-stats-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>

<div class="edt-wrap">

    <section class="edt-hero">
        <div class="edt-hero-grid">
            <div>
                <span class="edt-hero-kicker">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20"/><path d="M2 12h20"/></svg>
                    Gestion Maladie
                </span>
                <h1>Modifier la fiche de {{ maladie.nom }}</h1>
                <p>Mettez a jour les informations de la maladie et ses traitements dans une interface plus claire, sans changer les autres ecrans du projet.</p>
            </div>
            <div class="edt-hero-stats">
                <div class="edt-hero-stat">
                    <strong>{{ traitements|length }}</strong>
                    <span>traitement{% if traitements|length > 1 %}s{% endif %} associe{% if traitements|length > 1 %}s{% endif %}</span>
                </div>
                <div class="edt-hero-stat">
                    <strong>{{ maladie.niveauGravite|default('moyen')|capitalize }}</strong>
                    <span>niveau de gravite actuel</span>
                </div>
            </div>
        </div>
    </section>

    {# ===== TOPBAR ===== #}
    <div class="edt-topbar">
        <div class="edt-breadcrumb">
            <a href="{{ path('admin_dashboard') }}">Dashboard</a>
            <span class="edt-breadcrumb-sep">›</span>
            <a href="{{ path('admin_maladie_index') }}">Maladies</a>
            <span class="edt-breadcrumb-sep">›</span>
            <a href="{{ path('admin_maladie_show', {'id': maladie.id}) }}">{{ maladie.nom }}</a>
            <span class="edt-breadcrumb-sep">›</span>
            <span>Modifier</span>
        </div>
        <div class="edt-header-actions">
            <a href="{{ path('admin_maladie_show', {'id': maladie.id}) }}" class="edt-btn edt-btn-view">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                Voir la fiche
            </a>
            <form method="post" action="{{ path('admin_maladie_delete', {'id': maladie.id}) }}" style="display:inline" data-firma-confirm="Êtes-vous sûr de vouloir supprimer cette maladie et tous ses traitements ?">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ maladie.id) }}">
                <button type="submit" class="edt-btn edt-btn-delete">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3,6 5,6 21,6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
                    Supprimer
                </button>
            </form>
        </div>
    </div>

    <div class="edt-grid">

        {# ---- FORMULAIRE MALADIE ---- #}
        <form method="post" enctype="multipart/form-data" id="maladieForm" novalidate>
            <div class="edt-card">
                <div class="edt-card-head">
                    <div class="edt-card-head-icon green">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2z"/><path d="M12 6v6l4 2"/></svg>
                    </div>
                    <h2>Informations de la maladie</h2>
                </div>
                <div class="edt-card-body">

                    <div class="edt-form-group">
                        <label class="edt-label">Nom <span class="req">*</span></label>
                        <input type="text" name="nom" id="maladieNom" class="edt-input" value="{{ maladie.nom }}" placeholder="Ex: Mildiou">
                        <div class="edt-err" id="nomErr">Le nom doit contenir au moins 3 caractères.</div>
                    </div>

                    <div class="edt-form-group">
                        <label class="edt-label">Nom scientifique</label>
                        <input type="text" name="nomScientifique" class="edt-input" value="{{ maladie.nomScientifique }}" placeholder="Ex: Plasmopara viticola">
                    </div>

                    <div class="edt-form-group">
                        <label class="edt-label">Description</label>
                        <textarea name="description" id="maladieDescription" class="edt-textarea" rows="3" placeholder="Décrivez la maladie...">{{ maladie.description }}</textarea>
                        <div class="edt-err" id="descriptionErr">La description doit contenir au moins 10 caracteres.</div>
                    </div>

                    <div class="edt-form-group">
                        <label class="edt-label">Symptômes</label>
                        <textarea name="symptomes" id="maladieSymptomes" class="edt-textarea" rows="3" placeholder="Listez les symptômes observables...">{{ maladie.symptomes }}</textarea>
                        <div class="edt-err" id="symptomesErr">Les symptomes doivent contenir au moins 10 caracteres.</div>
                    </div>

                    <div class="edt-form-row">
                        <div class="edt-form-group">
                            <label class="edt-label">Niveau de gravité <span class="req">*</span></label>
                            <div class="edt-gravite-group">
                                {% set gravites = [
                                    {value: 'faible', label: 'Faible', icon: '🌱'},
                                    {value: 'moyen', label: 'Moyen', icon: '🌿'},
                                    {value: 'eleve', label: 'Élevé', icon: '⚠️'},
                                    {value: 'critique', label: 'Critique', icon: '🔥'}
                                ] %}
                                {% for g in gravites %}
                                <div class="edt-grav-opt">
                                    <input type="radio" name="niveauGravite" id="grav_{{ g.value }}" value="{{ g.value }}" {{ maladie.niveauGravite == g.value ? 'checked' : '' }}>
                                    <label class="edt-grav-lbl" for="grav_{{ g.value }}">
                                        <span>{{ g.icon }}</span>
                                        <span>{{ g.label }}</span>
                                    </label>
                                </div>
                                {% endfor %}
                            </div>
                        </div>

                        <div class="edt-form-group">
                            <label class="edt-label">Saison fréquente</label>
                            <select name="saisonFrequente" class="edt-select">
                                <option value="">Toute l'année</option>
                                {% for s in ['Printemps', 'Été', 'Automne', 'Hiver', 'Printemps-Été', 'Printemps-Automne'] %}
                                <option value="{{ s }}" {{ maladie.saisonFrequente == s ? 'selected' : '' }}>{{ s }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>

                    <div class="edt-form-group">
                        <label class="edt-label">Photo</label>
                        {% if maladie.imageUrl %}
                        <div class="edt-current-img">
                            <img src="{{ asset('uploads/maladies/' ~ maladie.imageUrl) }}" alt="{{ maladie.nom }}">
                            <span>Image actuelle · remplacer ci-dessous</span>
                        </div>
                        {% endif %}
                        <div class="edt-upload-zone" onclick="document.getElementById('imageFile').click()" id="dropZone">
                            <input type="file" name="imageFile" id="imageFile" accept="image/*" style="display:none" onchange="previewImage(this)">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17,8 12,3 7,8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                            <div>Cliquez ou glissez une image</div>
                            <div class="edt-upload-hint">JPG, PNG, WEBP · Max 2MB</div>
                        </div>
                        <div class="edt-preview" id="previewWrap">
                            <img id="previewImg" src="" alt="Aperçu">
                        </div>
                    </div>

                </div>
            </div>

            <div class="edt-bottom-actions">
                <a href="{{ path('admin_maladie_show', {'id': maladie.id}) }}" class="edt-btn edt-btn-cancel">Annuler</a>
                <button type="submit" class="edt-btn edt-btn-save">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17,21 17,13 7,13 7,21"/><polyline points="7,3 7,8 15,8"/></svg>
                    Enregistrer
                </button>
            </div>
        </form>

        {# ---- TRAITEMENTS ---- #}
        <div class="edt-card" style="align-self: start;">
            <div class="edt-card-head">
                <div class="edt-card-head-icon blue">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 3-6 6 6 6"/><path d="M3 9h14a4 4 0 0 1 0 8H3"/></svg>
                </div>
                <h2>Solutions de traitement</h2>
                <span class="edt-card-count" id="solCount">{{ traitements|length }}</span>
            </div>
            <div class="edt-card-body">

                <div class="edt-sol-toprow">
                    <button type="button" class="edt-btn edt-btn-add" onclick="openAddModal()">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Ajouter un traitement
                    </button>
                </div>

                <div id="solContainer">
                    {% if traitements is empty %}
                    <div class="edt-empty">
                        <div class="edt-empty-icon">
                            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/></svg>
                        </div>
                        <p>Aucun traitement associé à cette maladie.</p>
                        <button type="button" class="edt-btn edt-btn-add" onclick="openAddModal()">+ Ajouter</button>
                    </div>
                    {% else %}
                        {% for t in traitements %}
                        {% set rate = t.usageCount > 0 ? (t.feedbackPositive * 100 / t.usageCount)|round : 0 %}
                        <div class="edt-sol-item"
                             data-id="{{ t.id }}"
                             data-titre="{{ t.titre|e('html_attr') }}"
                             data-solution="{{ t.solution|e('html_attr') }}"
                             data-etapes="{{ t.etapes|default('')|e('html_attr') }}"
                             data-produits="{{ t.produitsRecommandes|default('')|e('html_attr') }}"
                             data-prevention="{{ t.conseilsPrevention|default('')|e('html_attr') }}"
                             data-duree="{{ t.dureeTraitement|default('')|e('html_attr') }}">

                            <div class="edt-sol-head" onclick="toggleSol({{ t.id }})">
                                <div class="edt-sol-icon">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/></svg>
                                </div>
                                <div class="edt-sol-info" onclick="event.stopPropagation()">
                                    <h3>{{ t.titre }}</h3>
                                    <div class="edt-sol-meta">
                                        {% if t.dureeTraitement %}<span class="edt-sol-tag">⏱ {{ t.dureeTraitement }}</span>{% endif %}
                                        <span class="edt-sol-tag">{{ t.usageCount }} utilisation{% if t.usageCount > 1 %}s{% endif %}</span>
                                    </div>
                                </div>
                                <div class="edt-sol-stats" onclick="event.stopPropagation()">
                                    <span class="edt-sol-stat pos">👍 {{ t.feedbackPositive }}</span>
                                    <span class="edt-sol-stat neg">👎 {{ t.feedbackNegative }}</span>
                                    <span class="edt-sol-stat rate">{{ rate }}%</span>
                                </div>
                                <div class="edt-sol-btns" onclick="event.stopPropagation()">
                                    <button type="button" class="edt-sol-btn edit" onclick="openEditModal({{ t.id }})" title="Modifier">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    </button>
                                    <form method="post" action="{{ path('admin_solution_traitement_delete', {'id': t.id}) }}" style="display:inline" data-firma-confirm="Êtes-vous sûr de vouloir supprimer ce traitement ?">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete-solution' ~ t.id) }}">
                                        <button type="submit" class="edt-sol-btn del" title="Supprimer">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3,6 5,6 21,6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                                        </button>
                                    </form>
                                </div>
                                <div class="edt-sol-chev" id="chev-{{ t.id }}">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
                                </div>
                            </div>

                            <div class="edt-sol-body" id="sbody-{{ t.id }}">
                                {% if t.solution %}
                                <div class="edt-sol-section">
                                    <div class="edt-sol-lbl">
                                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
                                        Solution
                                    </div>
                                    <div class="edt-sol-val">{{ t.solution|nl2br }}</div>
                                </div>
                                {% endif %}
                                {% if t.etapes %}
                                <div class="edt-sol-section">
                                    <div class="edt-sol-lbl">
                                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/></svg>
                                        Étapes
                                    </div>
                                    <div class="edt-sol-val">{{ t.etapes|nl2br }}</div>
                                </div>
                                {% endif %}
                                {% if t.produitsRecommandes %}
                                <div class="edt-sol-section">
                                    <div class="edt-sol-lbl">
                                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                                        Produits
                                    </div>
                                    <div class="edt-sol-val">{{ t.produitsRecommandes|nl2br }}</div>
                                </div>
                                {% endif %}
                                {% if t.conseilsPrevention %}
                                <div class="edt-sol-section">
                                    <div class="edt-sol-lbl">
                                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                                        Prévention
                                    </div>
                                    <div class="edt-sol-val">{{ t.conseilsPrevention|nl2br }}</div>
                                </div>
                                {% endif %}

                                <div class="edt-sol-stats-grid">
                                    <div class="edt-sol-stat-card">
                                        <span class="edt-sol-stat-num blue">{{ t.usageCount }}</span>
                                        <span class="edt-sol-stat-lbl">Utilisations</span>
                                    </div>
                                    <div class="edt-sol-stat-card">
                                        <span class="edt-sol-stat-num green">👍 {{ t.feedbackPositive }}</span>
                                        <span class="edt-sol-stat-lbl">Positifs</span>
                                    </div>
                                    <div class="edt-sol-stat-card">
                                        <span class="edt-sol-stat-num red">👎 {{ t.feedbackNegative }}</span>
                                        <span class="edt-sol-stat-lbl">Négatifs</span>
                                    </div>
                                    <div class="edt-sol-stat-card">
                                        <span class="edt-sol-stat-num {% if rate >= 70 %}green{% elseif rate >= 40 %}blue{% else %}red{% endif %}">{{ rate }}%</span>
                                        <span class="edt-sol-stat-lbl">Taux succès</span>
                                    </div>
                                </div>
                                <div class="edt-progress-wrap">
                                    <div class="edt-progress-label"><span>Satisfaction</span><span>{{ rate }}%</span></div>
                                    <div class="edt-progress-bar"><div class="edt-progress-fill" style="width: {{ rate }}%"></div></div>
                                </div>
                            </div>
                        </div>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

{# ===== MODAL ===== #}
<div id="solModal" class="edt-modal-overlay">
    <div class="edt-modal">
        <div class="edt-modal-head">
            <h3 id="modalTitle">Ajouter un traitement</h3>
            <button class="edt-modal-close" onclick="closeModal()">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="edt-modal-body">
            <input type="hidden" id="editId">

            <div class="edt-form-group">
                <label class="edt-label">Titre <span class="req">*</span></label>
                <input type="text" id="solTitre" class="edt-input" placeholder="Ex: Bouillie bordelaise">
                <div class="edt-err" id="titreErr">Le titre doit contenir au moins 3 caractères.</div>
            </div>

            <div class="edt-form-group">
                <label class="edt-label">Solution <span class="req">*</span></label>
                <textarea id="solSolution" class="edt-textarea" rows="3" placeholder="Description du traitement..."></textarea>
                <div class="edt-err" id="solutionErr">La solution doit contenir au moins 10 caractères.</div>
            </div>

            <div class="edt-form-row">
                <div class="edt-form-group">
                    <label class="edt-label">Étapes</label>
                    <textarea id="solEtapes" class="edt-textarea" rows="4" placeholder="Étape 1 : ...&#10;Étape 2 : ...&#10;Étape 3 : ..."></textarea>
                    <div class="edt-inline-help">Saisissez les etapes une par ligne.</div>
                </div>
                <div class="edt-form-group">
                    <label class="edt-label">Produits recommandés</label>
                    <textarea id="solProduits" class="edt-textarea" rows="3" placeholder="Bouillie bordelaise..."></textarea>
                </div>
            </div>

            <div class="edt-form-row">
                <div class="edt-form-group">
                    <label class="edt-label">Conseils prévention</label>
                    <textarea id="solPrevention" class="edt-textarea" rows="3" placeholder="Conseils préventifs..."></textarea>
                </div>
                <div class="edt-form-group">
                    <label class="edt-label">Durée du traitement</label>
                    <select id="solDuree" class="edt-select">
                        <option value="">Choisir une duree</option>
                        <option value="4 jours">4 jours</option>
                        <option value="7 jours">7 jours</option>
                        <option value="10 jours">10 jours</option>
                        <option value="14 jours (2 semaines)">14 jours (2 semaines)</option>
                        <option value="21 jours (3 semaines)">21 jours (3 semaines)</option>
                        <option value="30 jours (1 mois)">30 jours (1 mois)</option>
                    </select>
                    <div class="edt-inline-help">Selectionnez une duree type du traitement.</div>
                    <div class="edt-err" id="dureeErr">Veuillez choisir une duree de traitement.</div>
                </div>
            </div>
        </div>
        <div class="edt-modal-foot">
            <button type="button" class="edt-btn edt-btn-cancel" onclick="closeModal()">Annuler</button>
            <button type="button" class="edt-btn edt-btn-save" onclick="saveSolution()">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17,21 17,13 7,13 7,21"/></svg>
                Enregistrer
            </button>
        </div>
    </div>
</div>

<script>
const serverFlashMessages = [
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            { message: {{ message|json_encode|raw }}, type: {{ type|json_encode|raw }} },
        {% endfor %}
    {% endfor %}
];

const serverValidationErrors = [
    {% for field, message in errors %}
        {{ message|json_encode|raw }},
    {% endfor %}
];

function previewImage(input) {
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = e => {
            document.getElementById('previewImg').src = e.target.result;
            document.getElementById('previewWrap').style.display = 'block';
        };
        reader.readAsDataURL(input.files[0]);
    }
}

const zone = document.getElementById('dropZone');
if (zone) {
    zone.addEventListener('dragover', e => { e.preventDefault(); zone.style.borderColor = 'var(--primary)'; });
    zone.addEventListener('dragleave', () => zone.style.borderColor = '');
    zone.addEventListener('drop', e => {
        e.preventDefault();
        zone.style.borderColor = '';
        const inp = document.getElementById('imageFile');
        inp.files = e.dataTransfer.files;
        previewImage(inp);
    });
}

document.getElementById('maladieNom')?.addEventListener('input', function() {
    this.classList.toggle('invalid', this.value.trim().length > 0 && this.value.trim().length < 3);
    this.classList.toggle('valid', this.value.trim().length >= 3);
    document.getElementById('nomErr').classList.toggle('show', this.value.trim().length > 0 && this.value.trim().length < 3);
});

document.getElementById('maladieDescription')?.addEventListener('input', function() {
    const invalid = this.value.trim().length > 0 && this.value.trim().length < 10;
    this.classList.toggle('invalid', invalid);
    this.classList.toggle('valid', this.value.trim().length >= 10);
    document.getElementById('descriptionErr').classList.toggle('show', invalid);
});

document.getElementById('maladieSymptomes')?.addEventListener('input', function() {
    const invalid = this.value.trim().length > 0 && this.value.trim().length < 10;
    this.classList.toggle('invalid', invalid);
    this.classList.toggle('valid', this.value.trim().length >= 10);
    document.getElementById('symptomesErr').classList.toggle('show', invalid);
});

document.getElementById('maladieForm')?.addEventListener('submit', function(e) {
    if (this.dataset.confirmed === 'true') {
        this.dataset.confirmed = '';
        return;
    }

    const nom = document.getElementById('maladieNom');
    const description = document.getElementById('maladieDescription');
    const symptomes = document.getElementById('maladieSymptomes');
    let isValid = true;

    if (!nom.value.trim() || nom.value.trim().length < 3) {
        e.preventDefault();
        nom.classList.add('invalid');
        document.getElementById('nomErr').classList.add('show');
        isValid = false;
    }

    if (!description.value.trim() || description.value.trim().length < 10) {
        e.preventDefault();
        description.classList.add('invalid');
        document.getElementById('descriptionErr').classList.add('show');
        isValid = false;
    }

    if (!symptomes.value.trim() || symptomes.value.trim().length < 10) {
        e.preventDefault();
        symptomes.classList.add('invalid');
        document.getElementById('symptomesErr').classList.add('show');
        isValid = false;
    }

    if (!isValid) {
        if (window.firmaToast) {
            window.firmaToast('Veuillez corriger les champs du formulaire avant de continuer.', 'danger');
        } else {
            const el = document.createElement('div');
            el.textContent = 'Veuillez corriger les champs du formulaire avant de continuer.';
            el.style.cssText = 'position:fixed;top:18px;right:18px;z-index:99999;padding:10px 14px;border-radius:10px;background:#fdeaea;color:#a32d2d;border:1px solid #f5c5c0';
            document.body.appendChild(el);
            window.setTimeout(() => el.remove(), 4200);
        }
        (nom.value.trim().length < 3 ? nom : (!description.value.trim() || description.value.trim().length < 10 ? description : symptomes)).focus();
        return;
    }

    e.preventDefault();
    if (window.firmaOpenConfirmModal) {
        window.firmaOpenConfirmModal(
            this.id || 'maladieForm',
            'Confirmer la modification',
            'Voulez-vous vraiment enregistrer ces modifications ?',
            'Enregistrer',
            'primary'
        );
    } else if (window.firmaToast) {
        window.firmaToast('La fenetre de confirmation est indisponible.', 'danger');
    }
});

function toggleSol(id) {
    document.getElementById('sbody-' + id).classList.toggle('open');
    document.getElementById('chev-' + id).classList.toggle('open');
}

let currentEditId = null;

function openAddModal() {
    currentEditId = null;
    document.getElementById('modalTitle').textContent = 'Ajouter un traitement';
    ['solTitre','solSolution','solEtapes','solProduits','solPrevention','solDuree'].forEach(id => {
        const el = document.getElementById(id);
        el.value = '';
        el.classList.remove('invalid', 'valid');
    });
    ['titreErr','solutionErr'].forEach(id => document.getElementById(id).classList.remove('show'));
    document.getElementById('solModal').classList.add('open');
}

function openEditModal(id) {
    const row = document.querySelector(`.edt-sol-item[data-id="${id}"]`);
    if (!row) return;
    currentEditId = id;
    document.getElementById('modalTitle').textContent = 'Modifier le traitement';
    document.getElementById('editId').value = id;
    document.getElementById('solTitre').value = row.dataset.titre || '';
    document.getElementById('solSolution').value = row.dataset.solution || '';
    document.getElementById('solEtapes').value = row.dataset.etapes || '';
    document.getElementById('solProduits').value = row.dataset.produits || '';
    document.getElementById('solPrevention').value = row.dataset.prevention || '';
    const dureeSelect = document.getElementById('solDuree');
    const dureeValue = row.dataset.duree || '';
    if (dureeSelect) {
        const hasOption = Array.from(dureeSelect.options).some((opt) => opt.value === dureeValue);
        if (dureeValue && !hasOption) {
            const option = document.createElement('option');
            option.value = dureeValue;
            option.textContent = dureeValue;
            dureeSelect.appendChild(option);
        }
        dureeSelect.value = dureeValue;
    }
    document.getElementById('solModal').classList.add('open');
}

function closeModal() {
    document.getElementById('solModal').classList.remove('open');
}

function maladieNotify(message, type = 'success', duration = 10000) {
    if (window.firmaToast) {
        window.firmaToast(message, type, duration);
        return;
    }

    if (!document.getElementById('maladie-toast-fallback-style')) {
        const style = document.createElement('style');
        style.id = 'maladie-toast-fallback-style';
        style.textContent = '@keyframes maladieToastProgress{from{transform:scaleX(1)}to{transform:scaleX(0)}}';
        document.head.appendChild(style);
    }

    const el = document.createElement('div');
    const isDanger = type === 'danger' || type === 'error';
    el.style.cssText = 'position:fixed;top:18px;right:18px;z-index:99999;min-width:260px;max-width:420px;padding:12px 14px;border-radius:12px;background:' + (isDanger ? '#fdeaea;color:#a32d2d;border:1px solid #f5c5c0' : '#eaf3de;color:#27500a;border:1px solid #c0dd97') + ';box-shadow:0 14px 30px rgba(0,0,0,.14);overflow:hidden;';
    el.innerHTML = '<div style="position:absolute;top:0;left:0;height:3px;width:100%;background:' + (isDanger ? '#dc2626' : '#2f7d55') + ';transform-origin:left;animation:maladieToastProgress ' + duration + 'ms linear forwards"></div><div>' + String(message) + '</div>';
    document.body.appendChild(el);
    window.setTimeout(() => el.remove(), duration + 350);
}

document.addEventListener('DOMContentLoaded', () => {
    const notify = maladieNotify;

    document.addEventListener('submit', (event) => {
        const form = event.target.closest('form[data-firma-confirm]');
        if (!(form instanceof HTMLFormElement)) {
            return;
        }

        if (form.dataset.confirmed === 'true') {
            form.dataset.confirmed = '';
            return;
        }

        event.preventDefault();
        event.stopPropagation();
        const formId = form.id || `maladie-confirm-${Math.random().toString(36).slice(2, 9)}`;
        form.id = formId;
        const msg = form.getAttribute('data-firma-confirm') || 'Voulez-vous confirmer cette suppression ?';

        if (window.firmaOpenConfirmModal) {
            window.firmaOpenConfirmModal(formId, 'Confirmer la suppression', msg, 'Supprimer', 'danger');
        } else {
            notify('La fenetre de confirmation est indisponible.', 'danger');
        }
    }, true);

    const flash = sessionStorage.getItem('adminMaladieToast');
    if (flash) {
        try {
            const data = JSON.parse(flash);
            if (data.message) {
                notify(data.message, data.type || 'success', 10000);
            }
        } catch (e) {}
        sessionStorage.removeItem('adminMaladieToast');
    }

    serverFlashMessages.forEach(({ message, type }) => {
        notify(message, type === 'error' ? 'danger' : type, 10000);
    });

    if (!serverFlashMessages.length) {
        serverValidationErrors.forEach((message) => {
            notify(message, 'danger', 10000);
        });
    }
});

function validateModal() {
    let valid = true;
    const titre = document.getElementById('solTitre');
    const sol = document.getElementById('solSolution');
    const duree = document.getElementById('solDuree');
    if (!titre.value.trim() || titre.value.trim().length < 3) {
        titre.classList.add('invalid');
        document.getElementById('titreErr').classList.add('show');
        valid = false;
    } else { titre.classList.remove('invalid'); document.getElementById('titreErr').classList.remove('show'); }
    if (!sol.value.trim() || sol.value.trim().length < 10) {
        sol.classList.add('invalid');
        document.getElementById('solutionErr').classList.add('show');
        valid = false;
    } else { sol.classList.remove('invalid'); document.getElementById('solutionErr').classList.remove('show'); }

    if (!duree.value.trim()) {
        duree.classList.add('invalid');
        document.getElementById('dureeErr').classList.add('show');
        valid = false;
    } else {
        duree.classList.remove('invalid');
        duree.classList.add('valid');
        document.getElementById('dureeErr').classList.remove('show');
    }

    return valid;
}

async function saveSolution() {
    if (!validateModal()) {
        maladieNotify('Veuillez remplir correctement les champs obligatoires avant d\'enregistrer.', 'danger', 10000);
        const firstInvalid = document.querySelector('#solModal .invalid');
        if (firstInvalid && typeof firstInvalid.focus === 'function') {
            firstInvalid.focus();
        }
        return;
    }
    const data = {
        titre: document.getElementById('solTitre').value.trim(),
        solution: document.getElementById('solSolution').value.trim(),
        etapes: document.getElementById('solEtapes').value,
        produitsRecommandes: document.getElementById('solProduits').value,
        conseilsPrevention: document.getElementById('solPrevention').value,
        dureeTraitement: document.getElementById('solDuree').value
    };
    const url = currentEditId
        ? `/admin/solution-traitement/edit/${currentEditId}`
        : `/admin/solution-traitement/new/{{ maladie.id }}`;
    const saveBtn = document.querySelector('#solModal .edt-btn-save');
    if (saveBtn) {
        saveBtn.disabled = true;
    }
    try {
        const res = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
        const result = await res.json();
        if (result.success) {
            sessionStorage.setItem('adminMaladieToast', JSON.stringify({
                message: result.message || (currentEditId ? 'Traitement modifie avec succes.' : 'Traitement ajoute avec succes.'),
                type: 'success'
            }));
            location.reload();
        } else {
            maladieNotify('Erreur : ' + (result.error || 'Operation impossible.'), 'danger', 10000);
        }
    } catch(e) {
        maladieNotify('Erreur reseau lors de l\'enregistrement.', 'danger', 10000);
    } finally {
        if (saveBtn) {
            saveBtn.disabled = false;
        }
    }
}

document.getElementById('solModal')?.addEventListener('click', function(e) {
    if (e.target === this) closeModal();
});
</script>
{% endblock %}






