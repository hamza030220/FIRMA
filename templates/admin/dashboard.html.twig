{% extends 'admin/base.html.twig' %}

{% block page_title %}Tableau de bord{% endblock %}
{% block admin_page_title %}Tableau de bord{% endblock %}

{% block admin_content %}
<div class="admin-welcome">
    <div class="admin-welcome-card">
        <div class="admin-welcome-text">
            <h2>Bienvenue, {{ app.user.prenom }}</h2>
            <p>Gérez l'ensemble de la plateforme FIRMA depuis le menu latéral. Sélectionnez une section pour commencer.</p>
        </div>
        <div class="admin-welcome-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        </div>
    </div>

    <h3 class="admin-stats-title">Marketplace</h3>
    <div class="admin-stats">
        {# ── Marketplace ── #}
        <a href="{{ path('admin_marketplace') }}" class="admin-stat-card admin-stat-card-link">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            <span class="admin-stat-label">Produits en catalogue</span>
            <span class="admin-stat-value">{{ totalProducts }}</span>
            <span class="admin-stat-extra">
                {{ totalFournisseurs }} fournisseur{{ totalFournisseurs > 1 ? 's' : '' }} actif{{ totalFournisseurs > 1 ? 's' : '' }}
            </span>
        </a>

        {# ── Commandes ── #}
        <a href="{{ path('admin_marketplace_commandes') }}" class="admin-stat-card admin-stat-card-link">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            <span class="admin-stat-label">Commandes</span>
            <span class="admin-stat-value">{{ totalCommandes }}</span>
            {% if pendingOrders > 0 %}
            <span class="admin-stat-extra admin-stat-warning">
                {{ pendingOrders }} en attente de paiement
            </span>
            {% else %}
            <span class="admin-stat-extra">Aucune commande en attente</span>
            {% endif %}
        </a>

        {# ── Locations ── #}
        <a href="{{ path('admin_marketplace_locations') }}" class="admin-stat-card admin-stat-card-link">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <span class="admin-stat-label">Locations</span>
            <span class="admin-stat-value">{{ totalLocations }}</span>
            {% if activeLocations > 0 %}
            <span class="admin-stat-extra admin-stat-success">
                {{ activeLocations }} en cours
            </span>
            {% else %}
            <span class="admin-stat-extra">Aucune location active</span>
            {% endif %}
        </a>

        {# ── Nos Terrains ── #}
        <div class="admin-stat-card">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span class="admin-stat-label">Nos Terrains</span>
            <span class="admin-stat-value">{{ totalTerrains }}</span>
        </div>

    </div>
</div>
{% endblock %}
