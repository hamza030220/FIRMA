{% extends 'admin/base.html.twig' %}

{% block page_title %}Gérer Événements{% endblock %}
{% block admin_page_title %}Gérer Événements{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/admin/evenements.css') }}">
{% endblock %}

{% block admin_content %}
<div class="aevt-page">
    {# ── Tabs ── #}
    <nav class="aevt-tabs">
        <a href="#" class="aevt-tab {% if tab == 'liste' %}aevt-tab--active{% endif %}" data-tab="liste">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
            Liste
        </a>
        <a href="#" class="aevt-tab {% if tab == 'creer' %}aevt-tab--active{% endif %}" data-tab="creer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Créer
        </a>
        <a href="#" class="aevt-tab {% if tab == 'modifier' %}aevt-tab--active{% endif %}" data-tab="modifier">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            Modifier
        </a>
        <a href="#" class="aevt-tab {% if tab == 'sponsors' %}aevt-tab--active{% endif %}" data-tab="sponsors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
            Sponsors
        </a>
        <a href="#" class="aevt-tab {% if tab == 'dashboard' %}aevt-tab--active{% endif %}" data-tab="dashboard">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            Dashboard
        </a>
    </nav>

    {# ── Flash messages ── #}
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="aevt-flash aevt-flash--{{ type }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    {# ════════════════════════════════════════════════
       TAB 1 — LISTE
       ════════════════════════════════════════════════ #}
    <div class="aevt-panel {% if tab == 'liste' %}aevt-panel--active{% endif %}" id="panel-liste">
        {# Toolbar #}
        <div class="aevt-toolbar">
            <form class="aevt-search" method="get" action="{{ path('admin_evenements') }}">
                <input type="text" name="q" value="{{ search }}" placeholder="Recherche">
                <button type="submit" class="aevt-search__btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                </button>
                <button type="button" class="aevt-search__more">⋯</button>
            </form>
            <div class="aevt-sort">
                <label>Trier par :</label>
                <select onchange="window.location.href='{{ path('admin_evenements') }}?q={{ search }}&sort='+this.value">
                    <option value="date_desc" {% if sort == 'date_desc' %}selected{% endif %}>Date (plus récent)</option>
                    <option value="date_asc"  {% if sort == 'date_asc' %}selected{% endif %}>Date (plus ancien)</option>
                    <option value="titre_asc" {% if sort == 'titre_asc' %}selected{% endif %}>Titre A → Z</option>
                    <option value="titre_desc" {% if sort == 'titre_desc' %}selected{% endif %}>Titre Z → A</option>
                    <option value="places"    {% if sort == 'places' %}selected{% endif %}>Places disponibles</option>
                    <option value="statut"    {% if sort == 'statut' %}selected{% endif %}>Statut</option>
                </select>
            </div>
        </div>

        {# Cards #}
        {% if evenements is empty %}
            <div class="aevt-empty">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <p>Aucun événement trouvé.</p>
            </div>
        {% else %}
            <div class="aevt-cards">
                {% for evt in evenements %}
                    {% set typeEnum   = evt.typeEnum %}
                    {% set statutEnum = evt.statutEnum %}
                    {% set confirmed  = participationCounts[evt.idEvenement] ?? 0 %}

                    <article class="aevt-card">
                        <div class="aevt-card__thumb">
                            {% if evt.imageUrl %}
                                <img src="{{ asset(evt.imageUrl) }}" alt="{{ evt.titre }}">
                            {% else %}
                                <div class="aevt-card__thumb-ph">
                                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                </div>
                            {% endif %}
                        </div>

                        <div class="aevt-card__body">
                            <div class="aevt-card__title">Titre : <strong>{{ evt.titre }}</strong></div>
                            <div class="aevt-card__org">Organisateur : {{ evt.organisateur ?? '—' }}</div>
                            <div class="aevt-card__dates">
                                Du {{ evt.dateDebut|date('d/m/Y') }} au {{ evt.dateFin|date('d/m/Y') }}
                                <span class="aevt-card__sep">|</span>
                                {{ evt.horaireDebut|date('H:i') }} → {{ evt.horaireFin|date('H:i') }}
                            </div>
                            {% if statutEnum %}
                                <span class="aevt-badge {{ statutEnum.badgeClass }}">{{ statutEnum.label }}</span>
                            {% endif %}
                            {% if typeEnum %}
                                <span class="aevt-badge aevt-badge--type">{{ typeEnum.label }}</span>
                            {% endif %}
                        </div>

                        <div class="aevt-card__stats">
                            <div class="aevt-card__places">
                                <strong>Places : {{ evt.placesDisponibles }}/{{ evt.capaciteMax }}</strong>
                            </div>
                            <div class="aevt-card__participants">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                                Participations : {{ confirmed }}
                            </div>
                        </div>

                        <div class="aevt-card__actions">
                            <button type="button" class="aevt-btn aevt-btn--primary js-detail-btn" data-id="{{ evt.idEvenement }}">Détails</button>
                            <button type="button" class="aevt-btn aevt-btn--outline js-participants-btn" data-id="{{ evt.idEvenement }}">Participants</button>
                            <a href="{{ path('admin_evenements', {tab: 'modifier', edit: evt.idEvenement}) }}" class="aevt-btn aevt-btn--neutral">Modif…</a>
                            {% if evt.isModifiable %}
                                <form method="post" action="{{ path('admin_evenement_cancel', {id: evt.idEvenement}) }}" data-firma-confirm="Êtes-vous sûr de vouloir annuler cet événement ?">
                                    <input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ evt.idEvenement) }}">
                                    <button type="submit" class="aevt-btn aevt-btn--warn">Annuler</button>
                                </form>
                            {% endif %}
                            <form method="post" action="{{ path('admin_evenement_delete', {id: evt.idEvenement}) }}" data-firma-confirm="Êtes-vous sûr de vouloir supprimer cet événement ? Cette action est irréversible.">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ evt.idEvenement) }}">
                                <button type="submit" class="aevt-btn aevt-btn--danger-outline">Supprimer</button>
                            </form>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    {# ════════════════════════════════════════════════
       TAB 2 — CRÉER
       ════════════════════════════════════════════════ #}
    <div class="aevt-panel {% if tab == 'creer' %}aevt-panel--active{% endif %}" id="panel-creer">
        <h2 class="aevt-form__title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Créer un nouvel événement
        </h2>

        <form method="post" action="{{ path('admin_evenement_create') }}" class="aevt-form" novalidate>
            <div class="aevt-form__row">
                <label class="aevt-form__label">Titre *</label>
                <input type="text" name="titre" id="evt_titre" class="aevt-form__input" placeholder="Titre de l'événement">
            </div>
            <div class="aevt-form__row">
                <label class="aevt-form__label">Description</label>
                <textarea name="description" id="evt_description" class="aevt-form__textarea" rows="4" placeholder="Description de l'événement"></textarea>
            </div>
            <div class="aevt-form__row">
                <label class="aevt-form__label">Organisateur *</label>
                <input type="text" name="organisateur" id="evt_organisateur" class="aevt-form__input" placeholder="Nom de l'organisateur">
            </div>
            <div class="aevt-form__row">
                <label class="aevt-form__label">Type *</label>
                <select name="type_evenement" id="evt_type" class="aevt-form__select">
                    <option value="">— Choisir —</option>
                    {% for t in typeOptions %}
                        <option value="{{ t.value }}">{{ t.label }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="aevt-form__grid2">
                <div class="aevt-form__row">
                    <label class="aevt-form__label">Date début *</label>
                    <input type="date" name="date_debut" id="evt_date_debut" class="aevt-form__input">
                </div>
                <div class="aevt-form__row">
                    <label class="aevt-form__label">Date fin *</label>
                    <input type="date" name="date_fin" id="evt_date_fin" class="aevt-form__input">
                </div>
            </div>
            <div class="aevt-form__grid2">
                <div class="aevt-form__row">
                    <label class="aevt-form__label">Horaire début *</label>
                    <input type="time" name="horaire_debut" id="evt_horaire_debut" class="aevt-form__input">
                </div>
                <div class="aevt-form__row">
                    <label class="aevt-form__label">Horaire fin *</label>
                    <input type="time" name="horaire_fin" id="evt_horaire_fin" class="aevt-form__input">
                </div>
            </div>
            <div class="aevt-form__row">
                <label class="aevt-form__label">Capacité max *</label>
                <input type="text" name="capacite_max" id="evt_capacite_max" class="aevt-form__input" value="50" placeholder="50">
            </div>
            <div class="aevt-form__row">
                <label class="aevt-form__label">Lieu</label>
                <input type="text" name="lieu" id="evt_lieu" class="aevt-form__input" placeholder="Ex: Tunis, Centre culturel">
            </div>
            <div class="aevt-form__row">
                <label class="aevt-form__label">Adresse</label>
                <input type="text" name="adresse" id="evt_adresse" class="aevt-form__input" placeholder="Adresse complète">
            </div>

            {# Image #}
            <div class="aevt-form__row">
                <label class="aevt-form__label">Image</label>
                <div class="aevt-form__img-group">
                    <input type="text" name="image_url" class="aevt-form__input aevt-form__img-input" placeholder="https://... ou parcourir" id="create_image_url">
                    <input type="file" accept="image/*" class="aevt-form__file-hidden" id="create_image_file" data-target="create_image_url">
                    <button type="button" class="aevt-btn aevt-btn--outline aevt-btn--sm js-browse-btn" data-file="create_image_file">Parcourir</button>
                    <button type="button" class="aevt-btn aevt-btn--primary aevt-btn--sm js-gen-ai" data-target="create_image_url">Générer IA</button>
                </div>
                <div class="aevt-form__img-preview" id="create_image_preview" style="display:none">
                    <img id="create_image_preview_img" alt="Aperçu">
                </div>
            </div>

            {# Sponsors #}
            <div class="aevt-form__row">
                <label class="aevt-form__label">Sponsors</label>
                <div class="aevt-form__sponsors">
                    {% if catalogSponsors is empty %}
                        <p class="aevt-text-muted">Aucun sponsor dans le catalogue.</p>
                    {% else %}
                        {% for s in catalogSponsors %}
                            <label class="aevt-form__sponsor-item">
                                <input type="checkbox" name="sponsors[]" value="{{ s.idSponsor }}">
                                <span class="aevt-form__sponsor-name">{{ s.nom }}</span>
                                <span class="aevt-pill">{{ s.secteurActivite }}</span>
                            </label>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>

            <div class="aevt-form__actions">
                <button type="submit" class="aevt-btn aevt-btn--primary aevt-btn--lg">Créer l'événement</button>
                <button type="reset" class="aevt-btn aevt-btn--outline aevt-btn--lg">Réinitialiser</button>
            </div>
        </form>
    </div>

    {# ════════════════════════════════════════════════
       TAB 3 — MODIFIER
       ════════════════════════════════════════════════ #}
    <div class="aevt-panel {% if tab == 'modifier' %}aevt-panel--active{% endif %}" id="panel-modifier">
        {% if editEvent %}
            <h2 class="aevt-form__title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Modifier : {{ editEvent.titre }}
            </h2>

            <form method="post" action="{{ path('admin_evenement_update', {id: editEvent.idEvenement}) }}" class="aevt-form" novalidate>
                <div class="aevt-form__row">
                    <label class="aevt-form__label">Titre *</label>
                    <input type="text" name="titre" id="evt_titre" class="aevt-form__input" value="{{ editEvent.titre }}">
                </div>
                <div class="aevt-form__row">
                    <label class="aevt-form__label">Description</label>
                    <textarea name="description" id="evt_description" class="aevt-form__textarea" rows="4">{{ editEvent.description }}</textarea>
                </div>
                <div class="aevt-form__row">
                    <label class="aevt-form__label">Organisateur *</label>
                    <input type="text" name="organisateur" id="evt_organisateur" class="aevt-form__input" value="{{ editEvent.organisateur }}">
                </div>
                <div class="aevt-form__row">
                    <label class="aevt-form__label">Type *</label>
                    <select name="type_evenement" id="evt_type" class="aevt-form__select">
                        <option value="">— Choisir —</option>
                        {% for t in typeOptions %}
                            <option value="{{ t.value }}" {% if editEvent.typeEvenement == t.value %}selected{% endif %}>{{ t.label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="aevt-form__grid2">
                    <div class="aevt-form__row">
                        <label class="aevt-form__label">Date début *</label>
                        <input type="date" name="date_debut" id="evt_date_debut" class="aevt-form__input" value="{{ editEvent.dateDebut|date('Y-m-d') }}">
                    </div>
                    <div class="aevt-form__row">
                        <label class="aevt-form__label">Date fin *</label>
                        <input type="date" name="date_fin" id="evt_date_fin" class="aevt-form__input" value="{{ editEvent.dateFin|date('Y-m-d') }}">
                    </div>
                </div>
                <div class="aevt-form__grid2">
                    <div class="aevt-form__row">
                        <label class="aevt-form__label">Horaire début *</label>
                        <input type="time" name="horaire_debut" id="evt_horaire_debut" class="aevt-form__input" value="{{ editEvent.horaireDebut ? editEvent.horaireDebut|date('H:i') : '' }}">
                    </div>
                    <div class="aevt-form__row">
                        <label class="aevt-form__label">Horaire fin *</label>
                        <input type="time" name="horaire_fin" id="evt_horaire_fin" class="aevt-form__input" value="{{ editEvent.horaireFin ? editEvent.horaireFin|date('H:i') : '' }}">
                    </div>
                </div>
                <div class="aevt-form__row">
                    <label class="aevt-form__label">Capacité max *</label>
                    <input type="text" name="capacite_max" id="evt_capacite_max" class="aevt-form__input" value="{{ editEvent.capaciteMax }}">
                </div>
                <div class="aevt-form__row">
                    <label class="aevt-form__label">Lieu</label>
                    <input type="text" name="lieu" id="evt_lieu" class="aevt-form__input" value="{{ editEvent.lieu }}">
                </div>
                <div class="aevt-form__row">
                    <label class="aevt-form__label">Adresse</label>
                    <input type="text" name="adresse" id="evt_adresse" class="aevt-form__input" value="{{ editEvent.adresse }}">
                </div>

                {# Image #}
                <div class="aevt-form__row">
                    <label class="aevt-form__label">Image</label>
                    <div class="aevt-form__img-group">
                        <input type="text" name="image_url" class="aevt-form__input aevt-form__img-input" value="{{ editEvent.imageUrl }}" placeholder="https://... ou parcourir" id="edit_image_url">
                        <input type="file" accept="image/*" class="aevt-form__file-hidden" id="edit_image_file" data-target="edit_image_url">
                        <button type="button" class="aevt-btn aevt-btn--outline aevt-btn--sm js-browse-btn" data-file="edit_image_file">Parcourir</button>
                        <button type="button" class="aevt-btn aevt-btn--primary aevt-btn--sm js-gen-ai" data-target="edit_image_url">Générer IA</button>
                    </div>
                    <div class="aevt-form__img-preview" id="edit_image_preview" style="display:none">
                        <img id="edit_image_preview_img" alt="Aperçu">
                    </div>
                </div>

                {# Sponsors #}
                <div class="aevt-form__row">
                    <label class="aevt-form__label">Sponsors</label>
                    <div class="aevt-form__sponsors">
                        {% if catalogSponsors is empty %}
                            <p class="aevt-text-muted">Aucun sponsor dans le catalogue.</p>
                        {% else %}
                            {% for s in catalogSponsors %}
                                <label class="aevt-form__sponsor-item">
                                    <input type="checkbox" name="sponsors[]" value="{{ s.idSponsor }}"
                                           {% if s.idSponsor in editSponsorIds %}checked{% endif %}>
                                    <span class="aevt-form__sponsor-name">{{ s.nom }}</span>
                                    <span class="aevt-pill">{{ s.secteurActivite }}</span>
                                </label>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>

                <div class="aevt-form__actions">
                    <button type="submit" class="aevt-btn aevt-btn--primary aevt-btn--lg">Enregistrer les modifications</button>
                    <a href="{{ path('admin_evenements') }}" class="aevt-btn aevt-btn--outline aevt-btn--lg">Annuler</a>
                </div>
            </form>
        {% else %}
            {# Event picker #}
            <h2 class="aevt-form__title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Modifier un événement
            </h2>
            <div class="aevt-form__picker">
                <p>Sélectionnez un événement à modifier :</p>
                <div class="aevt-form__picker-search">
                    <svg class="aevt-form__picker-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    <input type="text" id="pickerSearch" class="aevt-form__picker-search-input" placeholder="Rechercher par titre, organisateur, date…">
                </div>
                <div class="aevt-form__picker-list" id="pickerList">
                    {% for evt in evenements %}
                        <a href="{{ path('admin_evenements', {tab: 'modifier', edit: evt.idEvenement}) }}" class="aevt-form__picker-item" data-search="{{ evt.titre|lower }} {{ (evt.organisateur ?? '')|lower }} {{ evt.dateDebut|date('d/m/Y') }}">
                            <strong>{{ evt.titre }}</strong>
                            <span class="aevt-text-muted">{{ evt.dateDebut|date('d/m/Y') }} — {{ evt.organisateur ?? 'N/A' }}</span>
                        </a>
                    {% endfor %}
                </div>
                <p class="aevt-form__picker-empty" id="pickerEmpty" style="display:none">Aucun événement trouvé.</p>
            </div>
        {% endif %}
    </div>

    {# ════════════════════════════════════════════════
       TAB 5 — SPONSORS
       ════════════════════════════════════════════════ #}
    <div class="aevt-panel {% if tab == 'sponsors' %}aevt-panel--active{% endif %}" id="panel-sponsors">
        {# Toolbar #}
        <div class="aevt-toolbar">
            <div class="aevt-search" style="border:1.5px solid #d4d4d4">
                <input type="text" id="spSearch" placeholder="Rechercher un sponsor…">
                <button type="button" class="aevt-search__btn" style="pointer-events:none">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                </button>
            </div>
            <div class="aevt-sort">
                <label>Trier par :</label>
                <select id="spSort">
                    <option value="nom_asc">Nom A → Z</option>
                    <option value="nom_desc">Nom Z → A</option>
                    <option value="montant_desc">Montant ↓</option>
                    <option value="montant_asc">Montant ↑</option>
                    <option value="secteur">Secteur</option>
                </select>
            </div>
            <button type="button" class="aevt-btn aevt-btn--primary aevt-btn--lg" id="spCreateBtn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Créer un sponsor
            </button>
        </div>

        {# Sponsor table #}
        {% if catalogSponsors is empty %}
            <div class="aevt-empty">
                <p>Aucun sponsor dans le catalogue.</p>
            </div>
        {% else %}
            <div class="aevt-table-wrap">
                <table class="aevt-table" id="spTable">
                    <thead>
                        <tr>
                            <th>Logo</th>
                            <th>Nom</th>
                            <th>Secteur</th>
                            <th>Email</th>
                            <th>Téléphone</th>
                            <th>Contribution</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="spTbody">
                        {% for s in catalogSponsors %}
                            {% set secteurEnum = s.secteurEnum %}
                            <tr class="sp-row"
                                data-id="{{ s.idSponsor }}"
                                data-nom="{{ s.nom|lower }}"
                                data-secteur="{{ s.secteurActivite }}"
                                data-email="{{ s.emailContact|lower }}"
                                data-montant="{{ s.montantContribution }}">
                                <td>
                                    <div class="sp-table-logo">
                                        {% if s.logoUrl %}
                                            <img src="{{ s.logoUrl }}" alt="">
                                        {% else %}
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#a3b5a8" stroke-width="1.5"><rect x="2" y="7" width="20" height="15" rx="2"/><path d="M16 3l-4 4-4-4"/></svg>
                                        {% endif %}
                                    </div>
                                </td>
                                <td><strong style="color:#20452c">{{ s.nom }}</strong></td>
                                <td>
                                    {% if secteurEnum %}
                                        <span class="aevt-badge aevt-badge--type">{{ secteurEnum.label }}</span>
                                    {% else %}
                                        {{ s.secteurActivite }}
                                    {% endif %}
                                </td>
                                <td>{{ s.emailContact ?? '—' }}</td>
                                <td>{{ s.telephone ?? '—' }}</td>
                                <td>
                                    {% if s.montantContribution > 0 %}
                                        <span class="aevt-badge badge-success">{{ s.montantContribution }} TND</span>
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td>
                                    <div style="display:flex;gap:.3rem;flex-wrap:wrap">
                                        <button type="button" class="aevt-btn aevt-btn--primary aevt-btn--sm js-sp-detail" data-id="{{ s.idSponsor }}">Détails</button>
                                        <button type="button" class="aevt-btn aevt-btn--neutral aevt-btn--sm js-sp-edit" data-id="{{ s.idSponsor }}">Modifier</button>
                                        <form method="post" action="{{ path('admin_sponsor_delete', {id: s.idSponsor}) }}" data-firma-confirm="Supprimer ce sponsor ? Cette action est irréversible." style="margin:0">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ s.idSponsor) }}">
                                            <button type="submit" class="aevt-btn aevt-btn--danger-outline aevt-btn--sm">Supprimer</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <p id="spNoResult" class="aevt-text-muted" style="padding:1rem;display:none;text-align:center">Aucun sponsor trouvé.</p>
        {% endif %}
    </div>

    {# ── MODAL: Sponsor Create/Edit ── #}
    <div class="aevt-modal-overlay" id="spFormModal" style="display:none">
        <div class="aevt-modal" style="max-width:620px">
            <div class="aevt-modal__header">
                <div class="aevt-modal__header-info">
                    <h2 id="spFormTitle">Créer un sponsor</h2>
                </div>
                <button type="button" class="aevt-modal__close" id="spFormClose">&times;</button>
            </div>
            <form id="spForm" method="post" action="{{ path('admin_sponsor_create') }}" novalidate>
                <div class="aevt-modal__body">
                    <div class="aevt-form__grid2">
                        <div class="aevt-form__row">
                            <label class="aevt-form__label">Nom *</label>
                            <input type="text" name="nom" id="spF_nom" class="aevt-form__input" placeholder="Nom du sponsor">
                        </div>
                        <div class="aevt-form__row">
                            <label class="aevt-form__label">Secteur d'activité</label>
                            <select name="secteur_activite" id="spF_secteur" class="aevt-form__select">
                                {% for sec in secteurOptions %}
                                    <option value="{{ sec.value }}">{{ sec.label }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                    <div class="aevt-form__grid2">
                        <div class="aevt-form__row">
                            <label class="aevt-form__label">Email de contact *</label>
                            <input type="text" name="email_contact" id="spF_email" class="aevt-form__input" placeholder="contact@example.com">
                        </div>
                        <div class="aevt-form__row">
                            <label class="aevt-form__label">Téléphone *</label>
                            <input type="text" name="telephone" id="spF_tel" class="aevt-form__input" placeholder="+216 XX XXX XXX">
                        </div>
                    </div>
                    <div class="aevt-form__grid2">
                        <div class="aevt-form__row">
                            <label class="aevt-form__label">Site web</label>
                            <input type="text" name="site_web" id="spF_web" class="aevt-form__input" placeholder="https://...">
                        </div>
                        <div class="aevt-form__row">
                            <label class="aevt-form__label">Montant (TND)</label>
                            <input type="text" name="montant_contribution" id="spF_montant" class="aevt-form__input" value="0">
                        </div>
                    </div>
                    <div class="aevt-form__row">
                        <label class="aevt-form__label">Description</label>
                        <textarea name="description" id="spF_desc" class="aevt-form__textarea" rows="3" placeholder="Description du sponsor…"></textarea>
                    </div>
                    <div class="aevt-form__row">
                        <label class="aevt-form__label">Logo</label>
                        <div class="aevt-form__img-group">
                            <input type="text" name="logo_url" id="spF_logo" class="aevt-form__input aevt-form__img-input" placeholder="https://... ou parcourir">
                            <input type="file" accept="image/*" class="aevt-form__file-hidden" id="spF_logo_file" data-target="spF_logo">
                            <button type="button" class="aevt-btn aevt-btn--outline aevt-btn--sm js-sp-browse" data-file="spF_logo_file">Parcourir</button>
                        </div>
                        <div class="aevt-form__img-preview" id="spF_logo_preview" style="display:none">
                            <img id="spF_logo_preview_img" alt="Aperçu">
                        </div>
                    </div>
                </div>
                <div class="aevt-modal__footer">
                    <button type="button" class="aevt-btn aevt-btn--outline" id="spFormCancel">Annuler</button>
                    <button type="submit" class="aevt-btn aevt-btn--primary" id="spFormSubmit">Créer</button>
                </div>
            </form>
        </div>
    </div>

    {# ── MODAL: Sponsor Detail ── #}
    <div class="aevt-modal-overlay" id="spDetailModal" style="display:none">
        <div class="aevt-modal" style="max-width:520px">
            <div class="aevt-modal__header">
                <div class="aevt-modal__header-img" id="spD_logo"></div>
                <div class="aevt-modal__header-info">
                    <h2 id="spD_nom"></h2>
                    <div class="aevt-modal__header-badges">
                        <span id="spD_secteur" class="aevt-badge aevt-badge--type"></span>
                        <span id="spD_montant" class="aevt-badge badge-success" style="display:none"></span>
                    </div>
                </div>
                <button type="button" class="aevt-modal__close" id="spDetailClose">&times;</button>
            </div>
            <div class="aevt-modal__body">
                <div class="aevt-modal__section" id="spD_descSection" style="display:none">
                    <h4>Description</h4>
                    <div class="aevt-modal__desc" id="spD_desc"></div>
                </div>
                <div class="aevt-modal__fields">
                    <div class="aevt-modal__field"><span class="aevt-modal__field-label">Email</span><span id="spD_email"></span></div>
                    <div class="aevt-modal__field"><span class="aevt-modal__field-label">Téléphone</span><span id="spD_tel"></span></div>
                    <div class="aevt-modal__field"><span class="aevt-modal__field-label">Site web</span><span id="spD_web"></span></div>
                    <div class="aevt-modal__field"><span class="aevt-modal__field-label">Contribution</span><span id="spD_contrib"></span></div>
                    <div class="aevt-modal__field"><span class="aevt-modal__field-label">Date d'ajout</span><span id="spD_date"></span></div>
                </div>
            </div>
            <div class="aevt-modal__footer">
                <a href="#" id="spD_webLink" class="aevt-btn aevt-btn--outline" target="_blank" rel="noopener" style="display:none">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    Visiter le site
                </a>
                <button type="button" class="aevt-btn aevt-btn--primary" id="spDetailClose2">Fermer</button>
            </div>
        </div>
    </div>

    {# ════════════════════════════════════════════════
       TAB 4 — DASHBOARD
       ════════════════════════════════════════════════ #}
    <div class="aevt-panel {% if tab == 'dashboard' %}aevt-panel--active{% endif %}" id="panel-dashboard">

        {# ── ROW 1 : KPI cards ── #}
        <div class="dash-kpi-row">
            <div class="dash-kpi-card dash-kpi-card--green">
                <div class="dash-kpi-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                </div>
                <div class="dash-kpi-body">
                    <span class="dash-kpi-value">{{ dashStats.totalEvents }}</span>
                    <span class="dash-kpi-label">Total événements</span>
                </div>
                <div class="dash-kpi-sub">
                    <span class="dash-kpi-chip dash-kpi-chip--accent">{{ dashStats.eventsActifs }} actifs</span>
                </div>
            </div>

            <div class="dash-kpi-card dash-kpi-card--blue">
                <div class="dash-kpi-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
                <div class="dash-kpi-body">
                    <span class="dash-kpi-value">{{ dashStats.totalParticipants }}</span>
                    <span class="dash-kpi-label">Participants totaux</span>
                </div>
                <div class="dash-kpi-sub">
                    <span class="dash-kpi-chip dash-kpi-chip--success">{{ dashStats.participConfirm }} confirmés</span>
                    <span class="dash-kpi-chip dash-kpi-chip--warn">{{ dashStats.participAttente }} en attente</span>
                </div>
            </div>

            <div class="dash-kpi-card dash-kpi-card--amber">
                <div class="dash-kpi-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>
                </div>
                <div class="dash-kpi-body">
                    <span class="dash-kpi-value">{{ dashStats.tauxRemplissage|number_format(1) }}%</span>
                    <span class="dash-kpi-label">Taux de remplissage</span>
                </div>
                <div class="dash-kpi-sub">
                    <div class="dash-kpi-bar"><div class="dash-kpi-bar-fill" style="width:{{ dashStats.tauxRemplissage|number_format(0) }}%"></div></div>
                </div>
            </div>

            <div class="dash-kpi-card dash-kpi-card--purple">
                <div class="dash-kpi-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                </div>
                <div class="dash-kpi-body">
                    <span class="dash-kpi-value">{{ dashStats.totalSponsors }}</span>
                    <span class="dash-kpi-label">Sponsors</span>
                </div>
                <div class="dash-kpi-sub">
                    <span class="dash-kpi-chip dash-kpi-chip--accent">{{ dashStats.sponsorsAssignes }} assignés</span>
                    <span class="dash-kpi-chip dash-kpi-chip--info">{{ dashStats.totalContributions|number_format(0, ',', ' ') }} TND</span>
                </div>
            </div>

            <div class="dash-kpi-card dash-kpi-card--teal">
                <div class="dash-kpi-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
                <div class="dash-kpi-body">
                    <span class="dash-kpi-value">{{ dashStats.eventsCetteSemaine }}</span>
                    <span class="dash-kpi-label">Cette semaine</span>
                </div>
                <div class="dash-kpi-sub">
                    <span class="dash-kpi-chip dash-kpi-chip--accent">{{ dashStats.eventsCeMois }} ce mois</span>
                </div>
            </div>
        </div>

        {# ── ROW 2 : Charts ── #}
        <div class="dash-charts-row">
            <div class="dash-card dash-card--wide">
                <div class="dash-card-header">
                    <h3>Événements par mois</h3>
                    <span class="dash-card-badge">12 derniers mois</span>
                </div>
                <div class="dash-chart-wrap"><canvas id="chartEvtMois"></canvas></div>
            </div>
            <div class="dash-card">
                <div class="dash-card-header"><h3>Par type</h3></div>
                <div class="dash-chart-wrap dash-chart-wrap--square"><canvas id="chartType"></canvas></div>
            </div>
            <div class="dash-card">
                <div class="dash-card-header"><h3>Par statut</h3></div>
                <div class="dash-chart-wrap dash-chart-wrap--square"><canvas id="chartStatut"></canvas></div>
            </div>
        </div>

        {# ── ROW 3 : Participations + Sponsors charts ── #}
        <div class="dash-charts-row">
            <div class="dash-card dash-card--wide">
                <div class="dash-card-header">
                    <h3>Participations par mois</h3>
                    <span class="dash-card-badge">12 derniers mois</span>
                </div>
                <div class="dash-chart-wrap"><canvas id="chartParticipMois"></canvas></div>
            </div>
            <div class="dash-card">
                <div class="dash-card-header"><h3>Statut participations</h3></div>
                <div class="dash-chart-wrap dash-chart-wrap--square"><canvas id="chartParticipStatut"></canvas></div>
            </div>
            <div class="dash-card">
                <div class="dash-card-header"><h3>Sponsors par secteur</h3></div>
                <div class="dash-chart-wrap dash-chart-wrap--square"><canvas id="chartSecteur"></canvas></div>
            </div>
        </div>

        {# ── ROW 4 : Tables ── #}
        <div class="dash-tables-row">
            <div class="dash-card">
                <div class="dash-card-header">
                    <h3>Top événements</h3>
                    <span class="dash-card-badge">par participation</span>
                </div>
                <table class="dash-table" id="dashTopEvents">
                    <thead><tr><th>#</th><th>Événement</th><th>Participants</th></tr></thead>
                    <tbody></tbody>
                </table>
            </div>
            <div class="dash-card">
                <div class="dash-card-header">
                    <h3>Places disponibles</h3>
                    <span class="dash-card-badge">top 5</span>
                </div>
                <table class="dash-table" id="dashPlaces">
                    <thead><tr><th>#</th><th>Événement</th><th>Places</th></tr></thead>
                    <tbody></tbody>
                </table>
            </div>
            <div class="dash-card">
                <div class="dash-card-header">
                    <h3>Top sponsors</h3>
                    <span class="dash-card-badge">par événements</span>
                </div>
                <table class="dash-table" id="dashTopSponsors">
                    <thead><tr><th>#</th><th>Sponsor</th><th>Événements</th></tr></thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>

    </div>

    {# ════════════════════════════════════════════════
       MODAL — DETAIL POPUP
       ════════════════════════════════════════════════ #}
    <div class="aevt-modal-overlay" id="detailModal" style="display:none">
        <div class="aevt-modal">
            {# Header #}
            <div class="aevt-modal__header">
                <div class="aevt-modal__header-img" id="modal-thumb"></div>
                <div class="aevt-modal__header-info">
                    <h2 id="modal-titre"></h2>
                    <div class="aevt-modal__header-badges">
                        <span id="modal-statut" class="aevt-badge"></span>
                        <span id="modal-type" class="aevt-badge aevt-badge--type"></span>
                    </div>
                </div>
                <button type="button" class="aevt-modal__close" id="modal-close">&times;</button>
            </div>

            {# Body #}
            <div class="aevt-modal__body">
                {# Description #}
                <div class="aevt-modal__section">
                    <h4>Description</h4>
                    <div class="aevt-modal__desc" id="modal-desc"></div>
                </div>

                {# Info fields #}
                <div class="aevt-modal__fields">
                    <div class="aevt-modal__field"><span class="aevt-modal__field-label">Organisateur</span><span id="modal-org"></span></div>
                    <div class="aevt-modal__field"><span class="aevt-modal__field-label">Date début</span><span id="modal-dateDebut"></span></div>
                    <div class="aevt-modal__field"><span class="aevt-modal__field-label">Date fin</span><span id="modal-dateFin"></span></div>
                    <div class="aevt-modal__field"><span class="aevt-modal__field-label">Horaire</span><span id="modal-horaire"></span></div>
                    <div class="aevt-modal__field"><span class="aevt-modal__field-label">Lieu</span><span id="modal-lieu"></span></div>
                    <div class="aevt-modal__field"><span class="aevt-modal__field-label">Adresse</span><span id="modal-adresse"></span></div>
                    <div class="aevt-modal__field"><span class="aevt-modal__field-label">Capacité</span><span id="modal-capacite"></span></div>
                    <div class="aevt-modal__field"><span class="aevt-modal__field-label">Places dispo.</span><span id="modal-places"></span></div>
                    <div class="aevt-modal__field"><span class="aevt-modal__field-label">Participations</span><span id="modal-participations"></span></div>
                </div>

                {# Sponsors #}
                <div class="aevt-modal__section" id="modal-sponsors-section" style="display:none">
                    <h4>Sponsors</h4>
                    <div class="aevt-modal__sponsors" id="modal-sponsors"></div>
                </div>

                {# Weather #}
                <div class="aevt-modal__section" id="modal-weather-section">
                    <h4>Météo prévue</h4>
                    <div class="aevt-modal__weather" id="modal-weather">
                        <div class="aevt-weather-loading">
                            <span class="aevt-spinner"></span> Chargement de la météo…
                        </div>
                    </div>
                </div>
            </div>

            {# Footer #}
            <div class="aevt-modal__footer">
                <a href="#" id="modal-maps-link" class="aevt-btn aevt-btn--outline" target="_blank" rel="noopener">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    Voir sur Google Maps
                </a>
                <button type="button" class="aevt-btn aevt-btn--primary" id="modal-close2">Fermer</button>
            </div>
        </div>
    </div>

    {# ════════════════════════════════════════════════
       MODAL — PARTICIPANTS POPUP
       ════════════════════════════════════════════════ #}
    <div class="aevt-modal-overlay" id="participantsModal" style="display:none">
        <div class="aevt-modal aevt-modal--wide">
            {# Header #}
            <div class="aevt-modal__header aevt-modal__header--compact">
                <div class="aevt-modal__header-info">
                    <h2 id="part-modal-titre"></h2>
                    <p class="aevt-modal__subtitle" id="part-modal-total"></p>
                </div>
                <button type="button" class="aevt-modal__close" id="part-modal-close">&times;</button>
            </div>

            {# Body — Participants table #}
            <div class="aevt-modal__body">
                <div id="part-modal-empty" class="aevt-empty" style="display:none">
                    <p>Aucun participant pour cet événement.</p>
                </div>
                <div class="aevt-table-wrap" id="part-modal-table-wrap" style="display:none">
                    <table class="aevt-table aevt-table--participants">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Nom complet</th>
                                <th>Email</th>
                                <th>Statut</th>
                                <th>Accompagnants</th>
                                <th>Commentaire</th>
                            </tr>
                        </thead>
                        <tbody id="part-modal-tbody"></tbody>
                    </table>
                </div>
            </div>

            {# Footer #}
            <div class="aevt-modal__footer">
                <button type="button" class="aevt-btn aevt-btn--primary" id="part-modal-close2">Fermer</button>
            </div>
        </div>
    </div>

</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // ═══════════════════════════════
    // Picker search (Modifier tab)
    // ═══════════════════════════════
    var pickerInput = document.getElementById('pickerSearch');
    if (pickerInput) {
        pickerInput.addEventListener('input', function() {
            var q = this.value.toLowerCase().trim();
            var items = document.querySelectorAll('#pickerList .aevt-form__picker-item');
            var visible = 0;
            items.forEach(function(item) {
                var text = item.getAttribute('data-search') || '';
                var show = !q || text.includes(q);
                item.style.display = show ? '' : 'none';
                if (show) visible++;
            });
            var empty = document.getElementById('pickerEmpty');
            if (empty) empty.style.display = visible === 0 ? '' : 'none';
        });
    }

