    // ═══════════════════════════════
    // Sponsors tab — Search & Sort
    // ═══════════════════════════════
    var spSearchInput = document.getElementById('spSearch');
    var spSortSelect  = document.getElementById('spSort');
    var spTbody       = document.getElementById('spTbody');
    var spNoResult    = document.getElementById('spNoResult');

    function spFilterAndSort() {
        if (!spTbody) return;
        var q = (spSearchInput ? spSearchInput.value.toLowerCase().trim() : '');
        var sortBy = spSortSelect ? spSortSelect.value : 'nom_asc';
        var rows = Array.from(spTbody.querySelectorAll('.sp-row'));
        var visible = 0;

        // Filter
        rows.forEach(function(r) {
            var match = !q
                || r.dataset.nom.includes(q)
                || r.dataset.secteur.includes(q)
                || r.dataset.email.includes(q);
            r.style.display = match ? '' : 'none';
            if (match) visible++;
        });

        // Sort visible rows
        rows.sort(function(a, b) {
            switch (sortBy) {
                case 'nom_asc':     return a.dataset.nom.localeCompare(b.dataset.nom);
                case 'nom_desc':    return b.dataset.nom.localeCompare(a.dataset.nom);
                case 'montant_desc':return parseFloat(b.dataset.montant) - parseFloat(a.dataset.montant);
                case 'montant_asc': return parseFloat(a.dataset.montant) - parseFloat(b.dataset.montant);
                case 'secteur':     return a.dataset.secteur.localeCompare(b.dataset.secteur);
                default: return 0;
            }
        });
        rows.forEach(function(r) { spTbody.appendChild(r); });

        if (spNoResult) spNoResult.style.display = (visible === 0 && q) ? '' : 'none';
    }

    if (spSearchInput) spSearchInput.addEventListener('input', spFilterAndSort);
    if (spSortSelect)  spSortSelect.addEventListener('change', spFilterAndSort);

