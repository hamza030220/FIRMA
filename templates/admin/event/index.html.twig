    function badgeClass(statut) {
        if (statut === 'confirme')   return 'aevt-badge aevt-badge--success';
        if (statut === 'en_attente') return 'aevt-badge aevt-badge--warning';
        if (statut === 'annule')     return 'aevt-badge aevt-badge--danger';
        return 'aevt-badge';
    }
    function badgeLabel(statut) {
        if (statut === 'confirme')   return 'Confirmé';
        if (statut === 'en_attente') return 'En attente';
        if (statut === 'annule')     return 'Annulé';
        return statut;
    }

    function escapeHtml(str) {
        var div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
    }

    function openParticipantsModal(eventId) {
        fetch('{{ path('admin_evenements') }}/' + eventId + '/participants/json')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                document.getElementById('part-modal-titre').textContent = 'Participants — ' + data.titre;
                document.getElementById('part-modal-total').textContent =
                    data.totalPersonnes + ' personne' + (data.totalPersonnes > 1 ? 's' : '') + ' au total (participants + accompagnants)';

                var tbody = document.getElementById('part-modal-tbody');
                var tableWrap = document.getElementById('part-modal-table-wrap');
                var emptyMsg  = document.getElementById('part-modal-empty');

                tbody.innerHTML = '';

                if (!data.participants || data.participants.length === 0) {
                    tableWrap.style.display = 'none';
                    emptyMsg.style.display = '';
                } else {
                    tableWrap.style.display = '';
                    emptyMsg.style.display = 'none';

                    data.participants.forEach(function(p, idx) {
                        var rowId = 'part-sub-' + eventId + '-' + idx;
                        var hasAccomp = p.nombreAccompagnants > 0 && p.accompagnants.length > 0;

                        // Main row
                        var tr = document.createElement('tr');
                        var accompHtml;
                        if (hasAccomp) {
                            accompHtml = '<span class="aevt-accomp-toggle" data-target="' + rowId + '">'
                                + '<span class="aevt-arrow">►</span> '
                                + p.nombreAccompagnants
                                + '</span>';
                        } else {
                            accompHtml = '<span>' + p.nombreAccompagnants + '</span>';
                        }

                        tr.innerHTML =
                            '<td>' + (idx + 1) + '</td>'
                            + '<td>' + escapeHtml(p.fullName) + '</td>'
                            + '<td>' + escapeHtml(p.email) + '</td>'
                            + '<td><span class="' + badgeClass(p.statut) + '">' + badgeLabel(p.statut) + '</span></td>'
                            + '<td>' + accompHtml + '</td>'
                            + '<td>' + escapeHtml(p.commentaire || '—') + '</td>';
                        tbody.appendChild(tr);

                        // Sub-row (expandable)
                        if (hasAccomp) {
                            var subTr = document.createElement('tr');
                            subTr.className = 'aevt-sub-row aevt-sub-row--hidden';
