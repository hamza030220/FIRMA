            });
    }

    function spCloseFormModal() {
        spFormModal.style.display = 'none';
        document.body.style.overflow = '';
    }

    document.getElementById('spCreateBtn').addEventListener('click', spOpenFormCreate);
    document.getElementById('spFormClose').addEventListener('click', spCloseFormModal);
    document.getElementById('spFormCancel').addEventListener('click', spCloseFormModal);
    spFormModal.addEventListener('click', function(e) { if (e.target === spFormModal) spCloseFormModal(); });

    document.querySelectorAll('.js-sp-edit').forEach(function(btn) {
        btn.addEventListener('click', function() { spOpenFormEdit(this.dataset.id); });
    });

    // AJAX submit for sponsor form (no page redirect)
    spForm.addEventListener('submit', function(e) {
        e.preventDefault();

        // Clear previous highlights
        spForm.querySelectorAll('.firma-input-invalid').forEach(function(el) {
            el.classList.remove('firma-input-invalid');
        });

        var formData = new URLSearchParams(new FormData(spForm));
        var originalText = spFormSubmit.textContent;
        spFormSubmit.disabled = true;
        spFormSubmit.textContent = 'Envoi…';

        fetch(spForm.action, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: formData.toString()
        })
        .then(function(resp) { return resp.json(); })
        .then(function(data) {
            if (data.success) {
                window.firmaToast(data.message, 'success');
                spCloseFormModal();
                setTimeout(function() { window.location.reload(); }, 600);
            } else {
                if (data.errors && data.errors.length) {
                    data.errors.forEach(function(msg) {
                        window.firmaToast(msg, 'danger');
                    });
                }
                if (data.errorFields && data.errorFields.length) {
                    data.errorFields.forEach(function(name) {
                        var el = spForm.querySelector('[name="' + name + '"]');
                        if (el) el.classList.add('firma-input-invalid');
                    });
                }
            }
        })
        .catch(function(err) {
            console.error('Sponsor form error:', err);
            window.firmaToast('Erreur réseau, veuillez réessayer.', 'danger');
        })
        .finally(function() {
            spFormSubmit.disabled = false;
            spFormSubmit.textContent = originalText;
        });
    });

    // ═══════════════════════════════
    // Sponsor Detail Modal
    // ═══════════════════════════════
    var spDetailModal = document.getElementById('spDetailModal');

    function spOpenDetail(id) {
        fetch('{{ path('admin_sponsors') }}/' + id + '/json')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var logoEl = document.getElementById('spD_logo');
                if (data.logoUrl) {
                    logoEl.innerHTML = '<img src="' + data.logoUrl + '" alt="" style="width:100%;height:100%;object-fit:contain">';
                } else {
                    logoEl.innerHTML = '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#a3b5a8" stroke-width="1.5"><rect x="2" y="7" width="20" height="15" rx="2"/><path d="M16 3l-4 4-4-4"/></svg>';
                }
                document.getElementById('spD_nom').textContent = data.nom;
                document.getElementById('spD_secteur').textContent = data.secteur;

                var montantBadge = document.getElementById('spD_montant');
                if (data.montant && parseFloat(data.montant) > 0) {
                    montantBadge.textContent = data.montant + ' TND';
                    montantBadge.style.display = '';
                } else {
                    montantBadge.style.display = 'none';
                }

                var descSec = document.getElementById('spD_descSection');
                if (data.description) {
                    descSec.style.display = '';
                    document.getElementById('spD_desc').textContent = data.description;
                } else {
                    descSec.style.display = 'none';
                }

                document.getElementById('spD_email').textContent = data.emailContact || '—';
                document.getElementById('spD_tel').textContent = data.telephone || '—';
                document.getElementById('spD_web').textContent = data.siteWeb || '—';
                document.getElementById('spD_contrib').textContent = (data.montant && parseFloat(data.montant) > 0) ? data.montant + ' TND' : '—';
                document.getElementById('spD_date').textContent = data.dateCreation || '—';

                var webLink = document.getElementById('spD_webLink');
                if (data.siteWeb) { webLink.href = data.siteWeb; webLink.style.display = ''; }
                else { webLink.style.display = 'none'; }

                spDetailModal.style.display = 'flex';
                document.body.style.overflow = 'hidden';
            })
            .catch(function(err) {
                console.error(err);
                firmaToast('Impossible de charger les détails.', 'error');
            });
    }

    function spCloseDetail() {
        spDetailModal.style.display = 'none';
        document.body.style.overflow = '';
    }

    document.querySelectorAll('.js-sp-detail').forEach(function(btn) {
        btn.addEventListener('click', function() { spOpenDetail(this.dataset.id); });
    });
    document.getElementById('spDetailClose').addEventListener('click', spCloseDetail);
    document.getElementById('spDetailClose2').addEventListener('click', spCloseDetail);
    spDetailModal.addEventListener('click', function(e) { if (e.target === spDetailModal) spCloseDetail(); });

    // Sponsor logo browse & upload
    document.querySelectorAll('.js-sp-browse').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.getElementById(this.dataset.file).click();
        });
    });
    var spLogoFile = document.getElementById('spF_logo_file');
    if (spLogoFile) {
        spLogoFile.addEventListener('change', function() {
            if (!this.files || !this.files[0]) return;
            var file = this.files[0];
            if (!file.type.startsWith('image/')) { firmaToast('Veuillez sélectionner une image.', 'error'); return; }
            if (file.size > 5 * 1024 * 1024) { firmaToast('Max 5 Mo.', 'error'); return; }

            var reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('spF_logo_preview_img').src = e.target.result;
                document.getElementById('spF_logo_preview').style.display = '';
            };
            reader.readAsDataURL(file);

            var fd = new FormData();
            fd.append('image', file);
            var browseBtn = spLogoFile.parentElement.querySelector('.js-sp-browse');
            if (browseBtn) { browseBtn.textContent = 'Envoi…'; browseBtn.disabled = true; }

            fetch('{{ path('admin_sponsor_upload_logo') }}', { method: 'POST', body: fd })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.error) firmaToast('Erreur : ' + data.error, 'error');
                    else document.getElementById('spF_logo').value = data.url;
                })
                .catch(function() { firmaToast('Erreur réseau.', 'error'); })
                .finally(function() {
                    if (browseBtn) { browseBtn.textContent = 'Parcourir'; browseBtn.disabled = false; }
                });
        });
    }

    // ═══════════════════════════════
    // "Générer IA" — Hugging Face
    // ═══════════════════════════════
    document.querySelectorAll('.js-gen-ai').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var targetId = this.dataset.target;
            var titleInput = this.closest('form').querySelector('input[name="titre"]');
            var descInput  = this.closest('form').querySelector('textarea[name="description"]');
            var titre = (titleInput ? titleInput.value : '').trim();
            var desc  = (descInput  ? descInput.value  : '').trim();

            if (!titre) {
                firmaToast('Veuillez remplir le titre avant de générer une image.', 'warning');
                return;
            }

            var prompt = 'Professional photo for an agricultural event: ' + titre;
            if (desc) prompt += '. ' + desc.substring(0, 120);
            prompt += '. High quality, vibrant colors, natural lighting, farm landscape.';

            var target = document.getElementById(targetId);
            var originalText = btn.textContent;
            btn.textContent = 'Génération en cours…';
            btn.disabled = true;

            var formData = new FormData();
            formData.append('prompt', prompt);

            fetch('{{ path('admin_evenement_generate_image') }}', {
                method: 'POST',
                body: formData
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.error) {
                    firmaToast('Erreur IA : ' + data.error, 'error');
                } else {
                    target.value = data.url;
                    // Show preview
                    var previewId = targetId.replace('_url', '_preview');
                    var previewDiv = document.getElementById(previewId);
                    if (previewDiv) {
                        var previewImg = previewDiv.querySelector('img');
                        if (previewImg) previewImg.src = '{{ asset("") }}' + data.url;
                        previewDiv.style.display = 'block';
                    }
                    firmaToast('Image générée avec succès !', 'success');
                }
            })
            .catch(function(err) {
                console.error(err);
                firmaToast('Erreur réseau lors de la génération.', 'error');
            })
            .finally(function() {
                btn.textContent = originalText;
                btn.disabled = false;
            });
        });
    });

    // ═══════════════════════════════
    // Form validation handled server-side
    // ═══════════════════════════════
});
</script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>

<script>
(function(){
    /* ═══════════════════════════════════════════
       DASHBOARD — Charts & Tables
       ═══════════════════════════════════════════ */
    const DASH_URL = '{{ path("admin_evenement_dashboard_data") }}';

    /* Color palettes */
    const PALETTE = ['#4aac33','#3b82f6','#f59e0b','#8b5cf6','#14b8a6','#ef4444','#ec4899','#06b6d4'];
    const PALETTE_LIGHT = ['rgba(74,172,51,.15)','rgba(59,130,246,.15)','rgba(245,158,11,.15)','rgba(139,92,246,.15)','rgba(20,184,166,.15)','rgba(239,68,68,.15)','rgba(236,72,153,.15)','rgba(6,182,212,.15)'];

    const chartDefaults = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: { labels: { font: { family: "'Plus Jakarta Sans',sans-serif", size: 12 }, padding: 14, usePointStyle: true, pointStyleWidth: 10 } }
        }
    };

    function rankClass(i) {
        if (i === 0) return 'dash-rank dash-rank--gold';
        if (i === 1) return 'dash-rank dash-rank--silver';
        if (i === 2) return 'dash-rank dash-rank--bronze';
        return 'dash-rank';
    }

    function fillTable(id, rows, labelKey, valueKey) {
        var tb = document.querySelector('#' + id + ' tbody');
        if (!tb) return;
        tb.innerHTML = '';
        rows.forEach(function(r, i) {
            var tr = document.createElement('tr');
            tr.innerHTML = '<td><span class="' + rankClass(i) + '">' + (i + 1) + '</span></td>'
                         + '<td>' + r[labelKey] + '</td>'
                         + '<td><strong>' + r[valueKey] + '</strong></td>';
            tb.appendChild(tr);
        });
        if (!rows.length) {
            tb.innerHTML = '<tr><td colspan="3" style="text-align:center;color:#9ca3af;padding:24px">Aucune donnée</td></tr>';
        }
    }

    /* Only init when dashboard tab is shown or on load if active */
    var dashLoaded = false;
    function initDashboard() {
        if (dashLoaded) return;
        dashLoaded = true;

        fetch(DASH_URL)
            .then(function(r){ return r.json(); })
            .then(function(d){
                /* ── Events par mois (Bar) ── */
                var ctxMois = document.getElementById('chartEvtMois');
                if (ctxMois) {
                    new Chart(ctxMois, {
                        type: 'bar',
                        data: {
                            labels: d.evenementsParMois.map(function(m){ return m.mois; }),
                            datasets: [{
                                label: 'Événements',
                                data: d.evenementsParMois.map(function(m){ return m.count; }),
                                backgroundColor: 'rgba(74,172,51,.25)',
                                borderColor: '#4aac33',
                                borderWidth: 2,
                                borderRadius: 8,
                                barPercentage: 0.6
                            }]
                        },
                        options: Object.assign({}, chartDefaults, {
                            plugins: Object.assign({}, chartDefaults.plugins, { legend: { display: false } }),
                            scales: {
                                y: { beginAtZero: true, ticks: { stepSize: 1, font: { family: "'Plus Jakarta Sans'" } }, grid: { color: '#f0f0f0' } },
                                x: { ticks: { font: { family: "'Plus Jakarta Sans'", size: 11 } }, grid: { display: false } }
                            }
                        })
                    });
                }

                /* ── Participations par mois (Line) ── */
                var ctxPM = document.getElementById('chartParticipMois');
                if (ctxPM) {
                    new Chart(ctxPM, {
                        type: 'line',
                        data: {
                            labels: d.participationsParMois.map(function(m){ return m.mois; }),
                            datasets: [{
                                label: 'Participations',
                                data: d.participationsParMois.map(function(m){ return m.count; }),
                                borderColor: '#3b82f6',
                                backgroundColor: 'rgba(59,130,246,.1)',
                                borderWidth: 2.5,
                                tension: 0.35,
                                fill: true,
                                pointRadius: 4,
                                pointBackgroundColor: '#3b82f6'
                            }]
                        },
                        options: Object.assign({}, chartDefaults, {
                            plugins: Object.assign({}, chartDefaults.plugins, { legend: { display: false } }),
                            scales: {
                                y: { beginAtZero: true, ticks: { stepSize: 1, font: { family: "'Plus Jakarta Sans'" } }, grid: { color: '#f0f0f0' } },
                                x: { ticks: { font: { family: "'Plus Jakarta Sans'", size: 11 } }, grid: { display: false } }
                            }
                        })
                    });
                }

                /* ── Répartition par type (Doughnut) ── */
                var ctxType = document.getElementById('chartType');
                if (ctxType) {
                    new Chart(ctxType, {
                        type: 'doughnut',
                        data: {
                            labels: d.repartitionType.map(function(r){ return r.type; }),
                            datasets: [{
                                data: d.repartitionType.map(function(r){ return r.count; }),
                                backgroundColor: PALETTE.slice(0, d.repartitionType.length),
                                borderWidth: 0,
                                hoverOffset: 6
                            }]
                        },
                        options: Object.assign({}, chartDefaults, {
                            cutout: '62%',
                            plugins: Object.assign({}, chartDefaults.plugins, {
                                legend: { position: 'bottom', labels: Object.assign({}, chartDefaults.plugins.legend.labels, { padding: 10 }) }
                            })
                        })
                    });
                }

                /* ── Répartition par statut (Doughnut) ── */
                var ctxStatut = document.getElementById('chartStatut');
                if (ctxStatut) {
                    var statutColors = { 'actif': '#4aac33', 'termine': '#3b82f6', 'annule': '#ef4444', 'complet': '#f59e0b' };
                    new Chart(ctxStatut, {
                        type: 'doughnut',
                        data: {
                            labels: d.repartitionStatut.map(function(r){ return r.statut; }),
                            datasets: [{
                                data: d.repartitionStatut.map(function(r){ return r.count; }),
                                backgroundColor: d.repartitionStatut.map(function(r){ return statutColors[r.statut] || '#9ca3af'; }),
                                borderWidth: 0,
                                hoverOffset: 6
                            }]
                        },
                        options: Object.assign({}, chartDefaults, {
                            cutout: '62%',
                            plugins: Object.assign({}, chartDefaults.plugins, {
                                legend: { position: 'bottom', labels: Object.assign({}, chartDefaults.plugins.legend.labels, { padding: 10 }) }
                            })
                        })
                    });
                }

                /* ── Statut participations (Doughnut) ── */
                var ctxPS = document.getElementById('chartParticipStatut');
                if (ctxPS) {
                    var psColors = { 'confirmee': '#4aac33', 'en_attente': '#f59e0b', 'annulee': '#ef4444' };
                    new Chart(ctxPS, {
                        type: 'doughnut',
                        data: {
                            labels: d.repartitionParticip.map(function(r){ return r.statut; }),
                            datasets: [{
                                data: d.repartitionParticip.map(function(r){ return r.count; }),
                                backgroundColor: d.repartitionParticip.map(function(r){ return psColors[r.statut] || '#9ca3af'; }),
                                borderWidth: 0,
                                hoverOffset: 6
                            }]
                        },
                        options: Object.assign({}, chartDefaults, {
                            cutout: '62%',
                            plugins: Object.assign({}, chartDefaults.plugins, {
                                legend: { position: 'bottom', labels: Object.assign({}, chartDefaults.plugins.legend.labels, { padding: 10 }) }
                            })
                        })
                    });
                }

                /* ── Sponsors par secteur (Polar Area) ── */
                var ctxSec = document.getElementById('chartSecteur');
                if (ctxSec) {
                    new Chart(ctxSec, {
                        type: 'polarArea',
                        data: {
                            labels: d.repartitionSecteur.map(function(r){ return r.secteur; }),
                            datasets: [{
                                data: d.repartitionSecteur.map(function(r){ return r.count; }),
                                backgroundColor: PALETTE_LIGHT.slice(0, d.repartitionSecteur.length),
                                borderColor: PALETTE.slice(0, d.repartitionSecteur.length),
                                borderWidth: 2
                            }]
                        },
                        options: Object.assign({}, chartDefaults, {
                            plugins: Object.assign({}, chartDefaults.plugins, {
                                legend: { position: 'bottom', labels: Object.assign({}, chartDefaults.plugins.legend.labels, { padding: 10 }) }
                            }),
                            scales: { r: { ticks: { display: false }, grid: { color: '#f0f0f0' } } }
                        })
                    });
                }

                /* ── Tables ── */
                fillTable('dashTopEvents',  d.topEvenements,      'titre', 'count');
                fillTable('dashPlaces',     d.placesDisponibles,  'titre', 'places');
                fillTable('dashTopSponsors', d.topSponsors,       'nom',   'count');
            })
            .catch(function(err){ console.error('Dashboard data error:', err); });
    }

    /* Trigger when dashboard tab is selected */
    var dashPanel = document.getElementById('panel-dashboard');
    if (dashPanel && dashPanel.classList.contains('aevt-panel--active')) {
        initDashboard();
    }

    /* Listen for tab clicks */
    document.querySelectorAll('[data-tab]').forEach(function(btn){
        btn.addEventListener('click', function(){
            if (this.getAttribute('data-tab') === 'dashboard') {
                setTimeout(initDashboard, 50);
            }
        });
    });
})();
</script>
{% endblock %}
