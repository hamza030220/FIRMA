    // ═══════════════════════════════
    // Weather — Open-Meteo (free)
    // ═══════════════════════════════
    var WMO_DESC = {
        0:'Ciel dégagé',1:'Principalement dégagé',2:'Partiellement nuageux',3:'Couvert',
        45:'Brouillard',48:'Brouillard givrant',
        51:'Bruine légère',53:'Bruine modérée',55:'Bruine dense',
        56:'Bruine verglaçante légère',57:'Bruine verglaçante',
        61:'Pluie légère',63:'Pluie modérée',65:'Pluie forte',
        66:'Pluie verglaçante légère',67:'Pluie verglaçante',
        71:'Neige légère',73:'Neige modérée',75:'Neige forte',
        77:'Grains de neige',
        80:'Averses légères',81:'Averses modérées',82:'Averses violentes',
        85:'Averses de neige légères',86:'Averses de neige fortes',
        95:'Orage',96:'Orage avec grêle légère',99:'Orage avec grêle forte'
    };
    var WMO_EMOJI = {
        0:'☀️',1:'🌤️',2:'⛅',3:'☁️',
        45:'🌫️',48:'🌫️',
        51:'🌦️',53:'🌦️',55:'🌧️',56:'🌧️',57:'🌧️',
        61:'🌧️',63:'🌧️',65:'🌧️',66:'🌧️',67:'🌧️',
        71:'🌨️',73:'🌨️',75:'❄️',77:'❄️',
        80:'🌦️',81:'🌧️',82:'⛈️',85:'🌨️',86:'🌨️',
        95:'⛈️',96:'⛈️',99:'⛈️'
    };

    function extractCity(lieu, adresse) {
        // Priority: extract city from adresse (format: "123 Rue X, 75017 Paris")
        if (adresse && adresse.trim()) {
            var parts = adresse.trim().split(',');
            // Take the last segment, e.g. " 75017 Paris"
            var last = parts[parts.length - 1].trim();
            // Strip postal code (digits) to get city name
            var city = last.replace(/^\d{4,5}\s*/, '').trim();
            if (city) return city;
            // If only postal code remained, try second-to-last segment
            if (parts.length >= 2) {
                last = parts[parts.length - 2].trim();
                city = last.replace(/^\d{4,5}\s*/, '').trim();
                if (city) return city;
            }
        }
        // Fallback: lieu (rarely a city, but try)
        if (lieu && lieu.trim()) {
            return lieu.trim();
        }
        return null;
    }

    function getReliabilityText(daysAhead) {
        if (daysAhead <= 0)  return 'Météo actuelle';
        if (daysAhead <= 3)  return 'Prévision fiable (J+' + daysAhead + ')';
        if (daysAhead <= 7)  return 'Prévision modérée (J+' + daysAhead + ')';
        if (daysAhead <= 14) return 'Prévision indicative (J+' + daysAhead + ')';
        return 'Prévision à long terme — peu fiable';
    }

    function loadWeather(lieu, adresse, dateDebutRaw) {
        var weatherEl = document.getElementById('modal-weather');
        weatherEl.innerHTML = '<div class="aevt-weather-loading"><span class="aevt-spinner"></span> Chargement de la météo…</div>';

        var city = extractCity(lieu, adresse);
        if (!city) {
            weatherEl.innerHTML = '<span class="aevt-weather-error">Lieu non défini — impossible de charger la météo.</span>';
            return;
        }

        // Step 1: Geocode city
        fetch('https://geocoding-api.open-meteo.com/v1/search?name=' + encodeURIComponent(city) + '&count=5&language=fr')
            .then(function(r) { return r.json(); })
            .then(function(geo) {
                if (!geo.results || geo.results.length === 0) {
                    weatherEl.innerHTML = '<span class="aevt-weather-error">Ville « ' + city + ' » introuvable pour la météo.</span>';
                    return;
                }

                var lat = geo.results[0].latitude;
                var lon = geo.results[0].longitude;
                var cityName = geo.results[0].name;

                // Step 2: Get forecast
                var forecastUrl = 'https://api.open-meteo.com/v1/forecast?latitude=' + lat
                    + '&longitude=' + lon
                    + '&daily=temperature_2m_max,temperature_2m_min,weather_code'
                    + '&current_weather=true&timezone=auto&forecast_days=16';

                return fetch(forecastUrl)
                    .then(function(r) { return r.json(); })
                    .then(function(wx) {
                        var html = '';
                        var today = new Date().toISOString().slice(0, 10);

                        if (dateDebutRaw && wx.daily && wx.daily.time) {
                            var idx = wx.daily.time.indexOf(dateDebutRaw);
                            if (idx !== -1) {
                                // Forecast for event date
                                var code   = wx.daily.weather_code[idx];
                                var tMax   = wx.daily.temperature_2m_max[idx];
                                var tMin   = wx.daily.temperature_2m_min[idx];
                                var tAvg   = Math.round((tMax + tMin) / 2);
                                var desc   = WMO_DESC[code] || 'Inconnu';
                                var emoji  = WMO_EMOJI[code] || '🌡️';

                                var eventDate = new Date(dateDebutRaw);
                                var nowDate   = new Date(today);
                                var daysAhead = Math.round((eventDate - nowDate) / (1000 * 60 * 60 * 24));
                                var reliability = getReliabilityText(daysAhead);

                                html = '<div class="aevt-weather-card">'
                                    + '<div class="aevt-weather-emoji">' + emoji + '</div>'
                                    + '<div class="aevt-weather-info">'
                                    + '<p class="aevt-weather-temp">' + tAvg + '°C</p>'
                                    + '<p class="aevt-weather-desc">' + desc + '</p>'
                                    + '<p class="aevt-weather-range">↓ ' + Math.round(tMin) + '°C  ↑ ' + Math.round(tMax) + '°C</p>'
                                    + '<p class="aevt-weather-reliability">' + reliability + ' — ' + cityName + '</p>'
                                    + '</div></div>';
                            }
                        }

                        // Fallback to current weather
                        if (!html && wx.current_weather) {
                            var cw     = wx.current_weather;
                            var code2  = cw.weathercode;
                            var desc2  = WMO_DESC[code2] || 'Inconnu';
                            var emoji2 = WMO_EMOJI[code2] || '🌡️';

                            html = '<div class="aevt-weather-card">'
                                + '<div class="aevt-weather-emoji">' + emoji2 + '</div>'
                                + '<div class="aevt-weather-info">'
                                + '<p class="aevt-weather-temp">' + Math.round(cw.temperature) + '°C</p>'
                                + '<p class="aevt-weather-desc">' + desc2 + ' (météo actuelle)</p>'
                                + '<p class="aevt-weather-reliability">L\'événement est trop éloigné pour une prévision fiable — ' + cityName + '</p>'
                                + '</div></div>';
                        }

                        if (!html) {
                            html = '<span class="aevt-weather-error">Prévision non disponible pour cette date.</span>';
                        }

                        weatherEl.innerHTML = html;
                    });
            })
            .catch(function(err) {
                console.error('Weather error:', err);
                weatherEl.innerHTML = '<span class="aevt-weather-error">Impossible de charger la météo.</span>';
            });
    }

