{% extends 'admin/base.html.twig' %}

{% block page_title %}Gérer Forum{% endblock %}
{% block admin_page_title %}Gérer Forum{% endblock %}

{% block admin_content %}
<section class="forum-admin-shell">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            {% set is_action_toast = label == 'success' %}
            <div
                class="forum-flash forum-flash-{{ label == 'error' ? 'error' : 'success' }}{% if is_action_toast %} forum-toast{% endif %}"
                {% if is_action_toast %}data-forum-toast-message="{{ message|e('html_attr') }}" data-forum-toast-type="success" role="status" aria-live="polite"{% endif %}
            >{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <section class="forum-panel forum-insight-minimal">
        <div class="forum-insight-head">
            <h2>Sante du forum</h2>
            <span>Score: <strong>{{ community_pulse.score }}/100</strong> - {{ community_pulse.level }}</span>
        </div>

        <div class="forum-insight-kpis">
            <article>
                <span>Posts avec reponse</span>
                <strong>{{ community_pulse.posts_with_comments_pct }}%</strong>
            </article>
            <article>
                <span>Comptes interactifs</span>
                <strong>{{ community_pulse.interactive_accounts }}</strong>
            </article>
            <article>
                <span>Commentaires / post</span>
                <strong>{{ community_pulse.avg_comments_per_post }}</strong>
            </article>
            <article>
                <span>Commentaires avec image</span>
                <strong>{{ community_pulse.image_comments_pct }}%</strong>
            </article>
            <article>
                <span>Niveau</span>
                <strong>{{ community_pulse.level }}</strong>
            </article>
        </div>

        <div class="forum-insight-trend" role="img" aria-label="Tendance des 7 derniers jours">
            {% for value in community_pulse.trend_values %}
                {% set label = community_pulse.trend_labels[loop.index0] %}
                {% set width = (value / community_pulse.trend_peak) * 100 %}
                <div class="forum-insight-trend-row">
                    <span>{{ label }}</span>
                    <div><i style="width: {{ width }}%;"></i></div>
                    <strong>{{ value }}</strong>
                </div>
            {% endfor %}
        </div>
    </section>

    {% set forum_visual_total = total_posts + total_commentaires + total_categories %}
    {% set pct_posts = forum_visual_total > 0 ? (total_posts * 100 / forum_visual_total)|round(1, 'common') : 0 %}
    {% set pct_commentaires = forum_visual_total > 0 ? (total_commentaires * 100 / forum_visual_total)|round(1, 'common') : 0 %}
    {% set pct_categories = forum_visual_total > 0 ? (100 - pct_posts - pct_commentaires)|round(1, 'common') : 0 %}

    <section class="forum-stats-visual">
        <button
            type="button"
            class="forum-stats-trigger"
            id="forum-stats-trigger"
            aria-expanded="false"
            aria-controls="forum-stats-panel"
        >
            <span class="forum-stats-trigger-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <circle cx="12" cy="12" r="8"></circle>
                    <path d="M12 4v8l5.5 3"></path>
                </svg>
            </span>
            <span>
                <strong>Visualiser les stats</strong>
                <small>Clique pour afficher un cercle colore interactif</small>
            </span>
        </button>

        <div class="forum-stats-panel" id="forum-stats-panel" hidden>
            <div
                class="forum-stats-donut"
                style="--p1: {{ pct_posts }}; --p2: {{ pct_commentaires }}; --p3: {{ pct_categories }};"
                role="img"
                aria-label="Repartition: {{ pct_posts }}% posts, {{ pct_commentaires }}% commentaires, {{ pct_categories }}% categories"
            >
                <div class="forum-stats-donut-inner">
                    <strong>{{ forum_visual_total }}</strong>
                    <small>Elements</small>
                </div>
            </div>

            <div class="forum-stats-legend">
                <p><span class="dot dot-posts"></span>Posts: <strong>{{ total_posts }}</strong> ({{ pct_posts }}%)</p>
                <p><span class="dot dot-comments"></span>Commentaires: <strong>{{ total_commentaires }}</strong> ({{ pct_commentaires }}%)</p>
                <p><span class="dot dot-categories"></span>Categories: <strong>{{ total_categories }}</strong> ({{ pct_categories }}%)</p>
            </div>
        </div>
    </section>

    <div class="forum-admin-grid">
        <div class="forum-admin-column">
            <section class="forum-panel">
                <div class="forum-toolbar">
                    <h2>Categories du forum</h2>
                    <span>{{ categories|length }} disponibles</span>
                </div>

                <form
                    id="admin-forum-category-create-form"
                    method="post"
                    action="{{ path('admin_forum_category_create') }}"
                    class="forum-form"
                    data-forum-confirm="true"
                    data-forum-confirm-title="Ajouter la categorie"
                    data-forum-confirm-message="Voulez-vous vraiment ajouter cette categorie ?"
                    data-forum-confirm-submit="Ajouter"
                    data-forum-confirm-variant="primary"
                    data-forum-required-input="nom"
                    data-forum-required-message="Le nom de la categorie est obligatoire."
                    data-forum-success-toast-message="La categorie a ete ajoutee avec succes."
                    data-forum-success-toast-type="success"
                    data-forum-success-toast-duration="10000"
                >
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_forum_category_create') }}">
                    <label for="forum-category-name">Nouvelle categorie</label>
                    <input id="forum-category-name" type="text" name="nom" maxlength="100" value="{{ editing_category_id ? '' : category_form_data.nom|default('') }}" placeholder="Ex. Irrigation intelligente">
                    {% if category_errors.nom is defined and not editing_category_id %}
                        <div class="forum-flash forum-flash-error">{{ category_errors.nom }}</div>
                    {% endif %}
                    <button type="submit" class="forum-button">Ajouter la categorie</button>
                </form>

                <div class="forum-admin-table" style="margin-top: 0.5rem;">
                    {% for categorie in categories %}
                        <article class="forum-admin-row">
                            <div>
                                {% if editing_category_id == categorie.id %}
                                    <form
                                        id="admin-forum-category-edit-{{ categorie.id }}"
                                        method="post"
                                        action="{{ path('admin_forum_category_edit', {id: categorie.id}) }}"
                                        class="forum-form"
                                        data-forum-confirm="true"
                                        data-forum-confirm-title="Modifier la categorie"
                                        data-forum-confirm-message="Voulez-vous vraiment enregistrer la modification de cette categorie ?"
                                        data-forum-confirm-submit="Enregistrer"
                                        data-forum-confirm-variant="primary"
                                        data-forum-success-toast-message="La categorie a ete modifiee avec succes."
                                        data-forum-success-toast-type="success"
                                        data-forum-success-toast-duration="10000"
                                    >
                                        <input type="hidden" name="_token" value="{{ csrf_token('admin_forum_category_edit_' ~ categorie.id) }}">
                                        <label for="category-edit-{{ categorie.id }}">Modifier la categorie</label>
                                        <input id="category-edit-{{ categorie.id }}" type="text" name="nom" maxlength="100" value="{{ category_form_data.nom|default(categorie.nom) }}">
                                        {% if category_errors.nom is defined %}
                                            <div class="forum-flash forum-flash-error">{{ category_errors.nom }}</div>
                                        {% endif %}
                                        <div class="forum-actions">
                                            <button type="submit" class="forum-button">Enregistrer</button>
                                            <a href="{{ path('admin_forum') }}" class="forum-button forum-button-secondary">Annuler</a>
                                        </div>
                                    </form>
                                {% else %}
                                    <h3>{{ categorie.nom }}</h3>
                                    <small>Utilisable dans les publications du forum</small>
                                {% endif %}
                            </div>

                            {% if editing_category_id != categorie.id %}
                                <div class="forum-actions">
                                    <a
                                        href="{{ path('admin_forum', {editCategory: categorie.id}) }}"
                                        class="forum-icon-action forum-icon-action-only"
                                        title="Modifier la categorie"
                                        aria-label="Modifier la categorie"
                                        data-firma-confirm-link="true"
                                        data-firma-confirm-title="Modifier cette categorie"
                                        data-firma-confirm-message="Voulez-vous vraiment modifier cette categorie ?"
                                        data-firma-confirm-submit="Modifier"
                                        data-firma-confirm-variant="primary"
                                    >
                                        <svg viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M12 20h9"/>
                                            <path d="M16.5 3.5a2.12 2.12 0 1 1 3 3L7 19l-4 1 1-4Z"/>
                                        </svg>
                                    </a>
                                    <form
                                        method="post"
                                        action="{{ path('admin_forum_category_delete', {id: categorie.id}) }}"
                                        data-forum-confirm="true"
                                        data-forum-confirm-title="Supprimer cette categorie"
                                        data-forum-confirm-message="Voulez-vous vraiment supprimer cette categorie ? Cette action est irreversible."
                                        data-forum-confirm-submit="Supprimer"
                                        data-forum-confirm-variant="danger"
                                        data-forum-success-toast-message="La categorie a ete supprimee avec succes."
                                        data-forum-success-toast-type="success"
                                        data-forum-success-toast-duration="10000"
                                    >
                                        <input type="hidden" name="_token" value="{{ csrf_token('admin_forum_category_delete_' ~ categorie.id) }}">
                                        <button type="submit" class="forum-icon-action forum-icon-action-danger forum-icon-action-only" title="Supprimer la categorie" aria-label="Supprimer la categorie">
                                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                                <path d="M3 6h18"/>
                                                <path d="M8 6V4h8v2"/>
                                                <path d="M19 6l-1 14H6L5 6"/>
                                                <path d="M10 11v6"/>
                                                <path d="M14 11v6"/>
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                            {% endif %}
                        </article>
                    {% else %}
                        <div class="forum-empty">
                            <h3>Aucune categorie</h3>
                            <p>Ajoutez une premiere categorie pour organiser les futurs posts.</p>
                        </div>
                    {% endfor %}
                </div>
            </section>

        </div>

        <section class="forum-panel forum-admin-posts">
            <div class="forum-toolbar">
                <h2>Posts publies</h2>
                <span>{{ posts|length }} affiches</span>
            </div>
            <form method="get" action="{{ path('admin_forum') }}" class="forum-search" id="admin-forum-search-form">
                <input type="search" name="q" value="{{ search|default('') }}" placeholder="Rechercher un post par titre" minlength="3" id="admin-forum-search-input" style="min-height:56px;padding:1rem 1.1rem;font-size:1rem;">
                <button type="submit">Chercher</button>
                {% if active_search|default('') is not empty %}
                    <a href="{{ path('admin_forum') }}" class="forum-search-reset">Reinitialiser</a>
                {% endif %}
            </form>
            {% if active_search|default('') is not empty %}
                <p class="forum-search-info">
                    {{ posts|length }} resultat{{ posts|length > 1 ? 's' : '' }} pour "<strong>{{ active_search }}</strong>"
                </p>
            {% endif %}

            <div class="forum-admin-table" style="margin-top:1rem;">
                {% for post in posts %}
                    <article class="forum-admin-row">
                        <div>
                            <h3>
                                {{ post.titre }}
                                {% if post.isPinned %}
                                    <span class="forum-post-badge">Epingle</span>
                                {% endif %}
                            </h3>
                            <p>{{ post.contenu|length > 120 ? post.contenu|slice(0, 120) ~ '...' : post.contenu }}</p>
                            <small>{{ post.utilisateur.fullName }} - {{ post.categorie ?: 'Sans categorie' }} - {{ post.dateCreation|date('d/m/Y H:i', 'Africa/Lagos') }}</small>
                        </div>
                        <div class="forum-actions">
                            <a
                                href="{{ path('admin_forum_post_show', {id: post.id}) }}"
                                class="forum-icon-action forum-icon-action-only"
                                title="Voir le post"
                                aria-label="Voir le post"
                            >
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z"/>
                                    <circle cx="12" cy="12" r="3"/>
                                </svg>
                            </a>
                            <form
                                method="post"
                                action="{{ path('admin_forum_post_toggle_pin', {id: post.id}) }}"
                                data-forum-confirm="false"
                            >
                                <input type="hidden" name="_token" value="{{ csrf_token('toggle_pin_post_' ~ post.id) }}">
                                <input type="hidden" name="return_to" value="{{ path('admin_forum') }}">
                                <button
                                    type="submit"
                                    class="forum-icon-action forum-icon-action-only{% if post.isPinned %} is-active{% endif %}"
                                    title="{{ post.isPinned ? 'Desepingler le post' : 'Epingler le post' }}"
                                    aria-label="{{ post.isPinned ? 'Desepingler le post' : 'Epingler le post' }}"
                                >
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M12 2 8 8l2.5 1.5L8 18l4-3 4 3-2.5-8.5L16 8Z"/>
                                    </svg>
                                </button>
                            </form>
                            <form
                                id="admin-forum-post-delete-{{ post.id }}"
                                method="post"
                                action="{{ path('admin_forum_post_delete', {id: post.id}) }}"
                                data-forum-confirm="true"
                                data-forum-confirm-title="Supprimer ce post"
                                data-forum-confirm-message="Voulez-vous vraiment supprimer ce post ? Cette action est irreversible."
                                data-forum-confirm-submit="Supprimer"
                                data-forum-confirm-variant="danger"
                                data-forum-success-toast-message="Le post a ete supprime avec succes."
                                data-forum-success-toast-type="success"
                                data-forum-success-toast-duration="10000"
                            >
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_post_' ~ post.id) }}">
                                <button type="submit" class="forum-icon-action forum-icon-action-danger forum-icon-action-only" title="Supprimer le post" aria-label="Supprimer le post">
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M3 6h18"/>
                                        <path d="M8 6V4h8v2"/>
                                        <path d="M19 6l-1 14H6L5 6"/>
                                        <path d="M10 11v6"/>
                                        <path d="M14 11v6"/>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    </article>
                {% else %}
                    <div class="forum-empty">
                        <h3>Aucun post</h3>
                        <p>Le forum utilisateur est pret, mais il n'y a pas encore de contenu a moderer.</p>
                    </div>
                {% endfor %}
            </div>
            {% set currentPage = currentPage|default(1) %}
            {% set totalPages = totalPages|default(1) %}
            {% include 'shared/_pagination.html.twig' with {
                currentPage: currentPage,
                totalPages: totalPages,
                route: 'admin_forum',
                routeParams: { q: search }
            } %}
        </section>
    </div>
</section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const actionToast = sessionStorage.getItem('forumActionToast');
            if (actionToast) {
                try {
                    const data = JSON.parse(actionToast);
                    if (typeof window.firmaToast === 'function') {
                        window.firmaToast(data.message || 'Action réalisée avec succès.', data.type || 'success', Number.isFinite(data.duration) ? data.duration : 10000);
                    }
                } catch (e) {
                    if (typeof window.firmaToast === 'function') {
                        window.firmaToast('Action réalisée avec succès.', 'success', 10000);
                    }
                }
                sessionStorage.removeItem('forumActionToast');
            }

            const form = document.getElementById('admin-forum-search-form');
            const input = document.getElementById('admin-forum-search-input');
            const toastNodes = document.querySelectorAll('[data-forum-toast-message]');

            const showFallbackToast = (message, type = 'success', duration = 10000) => {
                if (!message) {
                    return;
                }

                if (!document.getElementById('admin-forum-toast-style')) {
                    const style = document.createElement('style');
                    style.id = 'admin-forum-toast-style';
                    style.textContent = '@keyframes adminForumToastProgress{from{transform:scaleX(1)}to{transform:scaleX(0)}}';
                    document.head.appendChild(style);
                }

                const isDanger = type === 'danger' || type === 'error';
                const toast = document.createElement('div');
                toast.style.cssText =
                    'position:fixed;top:18px;right:18px;z-index:99999;min-width:260px;max-width:420px;padding:12px 14px;border-radius:12px;' +
                    (isDanger
                        ? 'background:#fdeaea;color:#a32d2d;border:1px solid #f5c5c0;'
                        : 'background:#eaf3de;color:#27500a;border:1px solid #c0dd97;') +
                    'box-shadow:0 14px 30px rgba(0,0,0,.14);overflow:hidden;';

                toast.innerHTML =
                    '<div style="position:absolute;top:0;left:0;height:3px;width:100%;background:' +
                    (isDanger ? '#dc2626' : '#2f7d55') +
                    ';transform-origin:left;animation:adminForumToastProgress ' + duration + 'ms linear forwards"></div>' +
                    '<div>' + String(message) + '</div>';

                document.body.appendChild(toast);
                window.setTimeout(() => toast.remove(), duration + 350);
            };

            toastNodes.forEach((node) => {
                const message = node.getAttribute('data-forum-toast-message') || '';
                const type = node.getAttribute('data-forum-toast-type') || 'success';
                if (!message) {
                    return;
                }

                if (typeof window.firmaToast === 'function') {
                    window.firmaToast(message, type, 10000);
                } else {
                    showFallbackToast(message, type, 10000);
                }
                node.remove();
            });

            document.querySelectorAll('form[data-forum-confirm="true"]').forEach((confirmForm) => {
                if (!(confirmForm instanceof HTMLFormElement) || confirmForm.dataset.forumConfirmBound === 'true') {
                    return;
                }

                confirmForm.dataset.forumConfirmBound = 'true';
                if (!confirmForm.id) {
                    confirmForm.id = `admin-forum-confirm-${Math.random().toString(36).slice(2, 10)}`;
                }

                confirmForm.addEventListener('submit', (event) => {
                    event.preventDefault();
                    event.stopPropagation();

                    const requiredInputName = confirmForm.getAttribute('data-forum-required-input') || '';
                    if (requiredInputName) {
                        const requiredField = confirmForm.querySelector(`[name="${requiredInputName}"]`);
                        const requiredMessage = confirmForm.getAttribute('data-forum-required-message') || 'Ce champ est obligatoire.';

                        if (requiredField && typeof requiredField.value === 'string' && requiredField.value.trim() === '') {
                            let errorNode = confirmForm.querySelector('[data-forum-inline-error="required"]');
                            if (!(errorNode instanceof HTMLDivElement)) {
                                errorNode = document.createElement('div');
                                errorNode.className = 'forum-flash forum-flash-error';
                                errorNode.setAttribute('data-forum-inline-error', 'required');
                                const actionRow = confirmForm.querySelector('.forum-actions');
                                if (actionRow) {
                                    actionRow.parentNode.insertBefore(errorNode, actionRow);
                                } else {
                                    confirmForm.appendChild(errorNode);
                                }
                            }
                            errorNode.textContent = requiredMessage;

                            if (typeof window.firmaToast === 'function') {
                                window.firmaToast(requiredMessage, 'danger', 10000);
                            } else {
                                showFallbackToast(requiredMessage, 'danger', 10000);
                            }

                            if (typeof requiredField.focus === 'function') {
                                requiredField.focus();
                            }
                            return;
                        }

                        const existingError = confirmForm.querySelector('[data-forum-inline-error="required"]');
                        if (existingError) {
                            existingError.remove();
                        }
                    }

                    const title = confirmForm.getAttribute('data-forum-confirm-title') || 'Confirmation';
                    const message = confirmForm.getAttribute('data-forum-confirm-message') || 'Voulez-vous confirmer cette action ?';
                    const submitLabel = confirmForm.getAttribute('data-forum-confirm-submit') || 'Confirmer';
                    const submitVariant = confirmForm.getAttribute('data-forum-confirm-variant') || 'danger';

                    if (typeof window.firmaConfirm === 'function') {
                        window.firmaConfirm(title, message, submitLabel, submitVariant).then((ok) => {
                            if (!ok) {
                                return;
                            }

                            const toastMessage = confirmForm.getAttribute('data-forum-success-toast-message');
                            const toastType = confirmForm.getAttribute('data-forum-success-toast-type') || 'success';
                            const toastDuration = Number.parseInt(confirmForm.getAttribute('data-forum-success-toast-duration') || '10000', 10);
                            if (toastMessage) {
                                sessionStorage.setItem('forumActionToast', JSON.stringify({
                                    message: toastMessage,
                                    type: toastType,
                                    duration: Number.isFinite(toastDuration) ? toastDuration : 10000
                                }));
                            }

                            confirmForm.submit();
                        });
                        return;
                    }

                    confirmForm.submit();
                });
            });

            document.querySelectorAll('a[data-firma-confirm-link="true"]').forEach((link) => {
                if (!(link instanceof HTMLAnchorElement) || link.dataset.forumConfirmBound === 'true') {
                    return;
                }

                link.dataset.forumConfirmBound = 'true';
                link.addEventListener('click', (event) => {
                    const href = link.getAttribute('href');
                    if (!href || href === '#') {
                        return;
                    }

                    event.preventDefault();

                    const title = link.getAttribute('data-firma-confirm-title') || 'Modifier';
                    const message = link.getAttribute('data-firma-confirm-message') || 'Voulez-vous confirmer cette action ?';
                    const submitLabel = link.getAttribute('data-firma-confirm-submit') || 'Modifier';

                    if (typeof window.firmaConfirm === 'function') {
                        window.firmaConfirm(title, message, submitLabel, 'primary').then((ok) => {
                            if (!ok) {
                                return;
                            }

                            sessionStorage.setItem('forumActionToast', JSON.stringify({
                                message: 'La categorie peut etre modifiee maintenant.',
                                type: 'success',
                                duration: 10000
                            }));

                            window.location.href = href;
                        });
                        return;
                    }

                    window.location.href = href;
                });
            });

            if (!(form instanceof HTMLFormElement) || !(input instanceof HTMLInputElement)) {
                return;
            }

            const minLength = Number.parseInt(input.getAttribute('minlength') || '3', 10);
            let lastSubmitted = (input.value || '').trim();
            let debounceTimer = null;

            const submitIfNeeded = () => {
                const value = (input.value || '').trim();
                const hasEnoughChars = value.length >= minLength;
                const isReset = value.length === 0;

                if ((!hasEnoughChars && !isReset) || value === lastSubmitted) {
                    return;
                }

                lastSubmitted = value;
                form.submit();
            };

            input.addEventListener('input', () => {
                if (debounceTimer) {
                    window.clearTimeout(debounceTimer);
                }

                debounceTimer = window.setTimeout(submitIfNeeded, 250);
            });

            input.addEventListener('search', submitIfNeeded);

            const visualTrigger = document.getElementById('forum-stats-trigger');
            const visualPanel = document.getElementById('forum-stats-panel');

            if (visualTrigger instanceof HTMLButtonElement && visualPanel instanceof HTMLDivElement) {
                visualTrigger.addEventListener('click', () => {
                    const isExpanded = visualTrigger.getAttribute('aria-expanded') === 'true';
                    const nextExpanded = !isExpanded;

                    visualTrigger.setAttribute('aria-expanded', String(nextExpanded));
                    visualPanel.hidden = !nextExpanded;
                    visualPanel.classList.toggle('is-visible', nextExpanded);
                });
            }
        });
    </script>
{% endblock %}




