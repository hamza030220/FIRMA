<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}FIRMA - Votre Plateforme Agricole{% endblock %}</title>
        <meta name="description" content="{% block meta_description %}FIRMA - Marketplace, événements, maladies, communauté agricole. Tout ce dont vous avez besoin, au même endroit.{% endblock %}">
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>F</text></svg>">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
        {# Microsoft Clarity — user-facing pages only #}
        {% block clarity %}
            {% if app.user and not is_granted('ROLE_ADMIN') %}
            <script type="text/javascript">
                (function(c,l,a,r,i,t,y){
                    c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
                    t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
                    y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
                })(window,document,"clarity","script","wdmtsoch0x");
            </script>
            {% endif %}
        {% endblock %}
    </head>
    <body data-turbo="false">
        {% include 'shared/components/_toast_confirm.html.twig' %}
        {% include 'shared/_flash_toasts.html.twig' %}
        {% block body %}{% endblock %}
        {% block footer %}{% include 'shared/_footer.html.twig' %}{% endblock %}

        <div class="app-confirm-modal" id="appConfirmModal" hidden>
            <div class="app-confirm-backdrop" data-confirm-cancel></div>
            <div class="app-confirm-dialog" role="dialog" aria-modal="true" aria-labelledby="appConfirmTitle" aria-describedby="appConfirmMessage">
                <p class="app-confirm-eyebrow">Confirmation</p>
                <h2 id="appConfirmTitle">Supprimer ce post</h2>
                <p id="appConfirmMessage">Voulez-vous vraiment supprimer ce post ?</p>
                <div class="app-confirm-actions">
                    <button type="button" class="forum-button forum-button-secondary" data-confirm-cancel onclick="window.firmaCloseConfirmModal()">Annuler</button>
                    <button type="button" class="forum-button forum-button-danger" id="appConfirmSubmit">Supprimer</button>
                </div>
            </div>
        </div>

        <script>
            (() => {
                let pendingFormId = null;

                window.firmaOpenConfirmModal = (formId, title, message, submitLabel = 'Supprimer', submitVariant = 'danger') => {
                    const modal = document.getElementById('appConfirmModal');
                    const modalTitle = document.getElementById('appConfirmTitle');
                    const modalMessage = document.getElementById('appConfirmMessage');
                    const modalSubmit = document.getElementById('appConfirmSubmit');

                    if (!modal || !modalTitle || !modalMessage) {
                        return;
                    }

                    pendingFormId = formId;
                    modalTitle.textContent = title || 'Confirmation';
                    modalMessage.textContent = message || 'Voulez-vous confirmer cette action ?';
                    if (modalSubmit) {
                        modalSubmit.textContent = submitLabel || 'Confirmer';
                        modalSubmit.classList.toggle('forum-button-danger', submitVariant === 'danger');
                    }
                    modal.hidden = false;
                };

                window.firmaCloseConfirmModal = () => {
                    const modal = document.getElementById('appConfirmModal');
                    if (!modal) {
                        return;
                    }

                    modal.hidden = true;
                    pendingFormId = null;
                };

                document.addEventListener('DOMContentLoaded', () => {
                    const confirmSubmit = document.getElementById('appConfirmSubmit');
                    const backdrop = document.querySelector('.app-confirm-backdrop');

                    if (backdrop) {
                        backdrop.addEventListener('click', () => window.firmaCloseConfirmModal());
                    }

                    if (confirmSubmit) {
                        confirmSubmit.addEventListener('click', () => {
                            if (!pendingFormId) {
                                return;
                            }

                            const form = document.getElementById(pendingFormId);
                            window.firmaCloseConfirmModal();

                            if (form) {
                                const toastMessage = form.getAttribute('data-forum-success-toast-message');
                                const toastType = form.getAttribute('data-forum-success-toast-type') || 'success';
                                const toastDuration = Number.parseInt(form.getAttribute('data-forum-success-toast-duration') || '10000', 10);
                                if (toastMessage) {
                                    sessionStorage.setItem('forumActionToast', JSON.stringify({
                                        message: toastMessage,
                                        type: toastType,
                                        duration: Number.isFinite(toastDuration) ? toastDuration : 10000
                                    }));
                                }
                                form.submit();
                            }
                        });
                    }

                    document.addEventListener('keydown', (event) => {
                        const modal = document.getElementById('appConfirmModal');
                        if (event.key === 'Escape' && modal && !modal.hidden) {
                            window.firmaCloseConfirmModal();
                        }
                    });
                });
            })();
        </script>
    </body>
</html>

