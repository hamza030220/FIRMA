{# templates/pdf/maladie.html.twig #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{{ maladie.nom }} - Fiche technique</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            line-height: 1.6;
            color: #333;
        }
        
        h1 {
            color: #2c7a4d;
            border-bottom: 3px solid #2c7a4d;
            padding-bottom: 10px;
            text-align: center;
        }
        
        h2 {
            color: #1a5d3c;
            margin-top: 25px;
            font-size: 18px;
            border-left: 4px solid #2c7a4d;
            padding-left: 10px;
        }
        
        h3 {
            color: #0d3b24;
            font-size: 16px;
            margin-top: 15px;
        }
        
        .header {
            text-align: center;
            margin-bottom: 30px;
        }
        
        .logo {
            font-size: 40px;
            margin-bottom: 10px;
        }
        
        .subtitle {
            color: #666;
            font-size: 12px;
        }
        
        .info-card {
            background-color: #f0f8ff;
            padding: 15px;
            border-radius: 8px;
            margin: 15px 0;
            border-left: 4px solid #2196F3;
        }
        
        .symptomes-card {
            background-color: #fff3e0;
            padding: 15px;
            border-radius: 8px;
            margin: 15px 0;
            border-left: 4px solid #ff9800;
        }
        
        .traitement-card {
            background-color: #e8f5e9;
            padding: 15px;
            border-radius: 8px;
            margin: 15px 0;
            border-left: 4px solid #4caf50;
            page-break-inside: avoid;
        }
        
        .badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 15px;
            font-size: 11px;
            font-weight: bold;
            color: white;
            margin-right: 5px;
        }
        
        .badge-danger { background-color: #dc3545; }
        .badge-warning { background-color: #ffc107; color: #333; }
        .badge-info { background-color: #17a2b8; }
        .badge-success { background-color: #28a745; }
        
        .info-row {
            margin: 10px 0;
            padding: 5px 0;
            border-bottom: 1px solid #eee;
        }
        
        .info-label {
            font-weight: bold;
            width: 150px;
            display: inline-block;
        }
        
        .stats {
            background-color: #f5f5f5;
            padding: 10px;
            border-radius: 5px;
            margin-top: 10px;
            text-align: center;
        }
        
        .footer {
            text-align: center;
            font-size: 10px;
            color: #999;
            margin-top: 40px;
            padding-top: 10px;
            border-top: 1px solid #ddd;
        }
        
        .page-break {
            page-break-before: always;
        }
        
        .text-center { text-align: center; }
        .mt-20 { margin-top: 20px; }
        .mb-20 { margin-bottom: 20px; }
        
        ul, ol {
            margin: 5px 0;
            padding-left: 20px;
        }
        
        li {
            margin: 5px 0;
        }
    </style>
</head>
<body>

<div class="header">
    <div class="logo">🌱 FIRMA</div>
    <h1>{{ maladie.nom }}</h1>
    <div class="subtitle">Fiche technique - Diagnostic et Traitement</div>
    <div class="subtitle">Généré le : {{ generated_at }}</div>
</div>

<div class="info-card">
    <h2>📋 Informations générales</h2>
    <div class="info-row">
        <span class="info-label">Nom scientifique :</span>
        {{ maladie.nomScientifique|default('Non spécifié') }}
    </div>
    <div class="info-row">
        <span class="info-label">Niveau de gravité :</span>
        {% if maladie.niveauGravite == 'critique' %}
            <span class="badge badge-danger">Critique</span>
        {% elseif maladie.niveauGravite == 'eleve' %}
            <span class="badge badge-warning">Élevé</span>
        {% elseif maladie.niveauGravite == 'moyen' %}
            <span class="badge badge-info">Moyen</span>
        {% else %}
            <span class="badge badge-success">Faible</span>
        {% endif %}
    </div>
    <div class="info-row">
        <span class="info-label">Saison fréquente :</span>
        {{ maladie.saisonFrequente|default('Toute l\'année') }}
    </div>
</div>

<div class="symptomes-card">
    <h2>⚠️ Symptômes</h2>
    {% if maladie.symptomes %}
        {{ maladie.symptomes|nl2br }}
    {% else %}
        <p class="text-muted">Aucun symptôme renseigné.</p>
    {% endif %}
</div>

<div class="info-card">
    <h2>📝 Description</h2>
    {% if maladie.description %}
        {{ maladie.description|nl2br }}
    {% else %}
        <p class="text-muted">Aucune description renseignée.</p>
    {% endif %}
</div>

{% if traitements|length > 0 %}
    <h2>💊 Traitements recommandés</h2>
    
    {% for traitement in traitements %}
        <div class="traitement-card">
            <h3>{{ traitement.titre }}</h3>
            
            <p><strong>Description :</strong></p>
            <p>{{ traitement.description|nl2br }}</p>
            
            {% if traitement.etapes %}
                <p><strong>📋 Étapes à suivre :</strong></p>
                {{ traitement.etapes|nl2br }}
            {% endif %}
            
            {% if traitement.produits %}
                <p><strong>🛒 Produits recommandés :</strong></p>
                <p>{{ traitement.produits|nl2br }}</p>
            {% endif %}
            
            {% if traitement.prevention %}
                <p><strong>🛡️ Prévention :</strong></p>
                <p>{{ traitement.prevention|nl2br }}</p>
            {% endif %}
            
            {% if traitement.duree %}
                <p><strong>⏱️ Durée du traitement :</strong> {{ traitement.duree }}</p>
            {% endif %}
            
            <div class="stats">
                <strong>📊 Statistiques du traitement :</strong><br>
                Utilisations : {{ traitement.usageCount }} |
                👍 Efficace : {{ traitement.feedbackPositive }} |
                👎 Inefficace : {{ traitement.feedbackNegative }} |
                📈 Taux de réussite : {{ traitement.successRate|default(0) }}%
            </div>
        </div>
    {% endfor %}
{% else %}
    <div class="info-card">
        <p class="text-center">⚠️ Aucun traitement n'est encore enregistré pour cette maladie.</p>
    </div>
{% endif %}

<div class="footer">
    <p>Document généré par FIRMA - Application de diagnostic des maladies des plantes</p>
    <p>Ce document est une fiche d'information. En cas de doute, consultez un expert.</p>
</div>

</body>
</html>