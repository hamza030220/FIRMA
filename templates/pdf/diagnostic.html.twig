{# templates/pdf/diagnostic.html.twig #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Diagnostic - {{ maladie.nom }}</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            line-height: 1.6;
            color: #333;
        }
        
        h1 {
            color: #2c7a4d;
            border-bottom: 3px solid #2c7a4d;
            padding-bottom: 10px;
            text-align: center;
        }
        
        h2 {
            color: #1a5d3c;
            margin-top: 25px;
            font-size: 18px;
            border-left: 4px solid #2c7a4d;
            padding-left: 10px;
        }
        
        .header {
            text-align: center;
            margin-bottom: 30px;
        }
        
        .logo {
            font-size: 40px;
            margin-bottom: 10px;
        }
        
        .subtitle {
            color: #666;
            font-size: 12px;
        }
        
        .diagnostic-box {
            background-color: #e3f2fd;
            padding: 15px;
            border-radius: 8px;
            margin: 15px 0;
            border-left: 4px solid #2196F3;
        }
        
        .result-box {
            background-color: #e8f5e9;
            padding: 15px;
            border-radius: 8px;
            margin: 15px 0;
            border-left: 4px solid #4caf50;
        }
        
        .traitement-box {
            background-color: #fff3e0;
            padding: 15px;
            border-radius: 8px;
            margin: 15px 0;
            border-left: 4px solid #ff9800;
        }
        
        .footer {
            text-align: center;
            font-size: 10px;
            color: #999;
            margin-top: 40px;
            padding-top: 10px;
            border-top: 1px solid #ddd;
        }
        
        .badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 15px;
            font-size: 11px;
            font-weight: bold;
            color: white;
        }
        
        .badge-danger { background-color: #dc3545; }
        .badge-warning { background-color: #ffc107; color: #333; }
        .badge-info { background-color: #17a2b8; }
        .badge-success { background-color: #28a745; }
        
        .info-row {
            margin: 10px 0;
        }
        
        .info-label {
            font-weight: bold;
            width: 150px;
            display: inline-block;
        }
        
        .text-center { text-align: center; }
    </style>
</head>
<body>

<div class="header">
    <div class="logo">🌱 FIRMA</div>
    <h1>Rapport de Diagnostic</h1>
    <div class="subtitle">Généré le : {{ generated_at }}</div>
</div>

<div class="diagnostic-box">
    <h2>🔍 Ce que vous avez décrit</h2>
    <p><strong>Vos symptômes :</strong></p>
    <p>{{ userDescription|nl2br }}</p>
</div>

<div class="result-box">
    <h2>🦠 Diagnostic</h2>
    <div class="info-row">
        <span class="info-label">Maladie détectée :</span>
        <strong>{{ maladie.nom }}</strong>
    </div>
    {% if maladie.nomScientifique %}
    <div class="info-row">
        <span class="info-label">Nom scientifique :</span>
        {{ maladie.nomScientifique }}
    </div>
    {% endif %}
    <div class="info-row">
        <span class="info-label">Niveau de gravité :</span>
        {% if maladie.niveauGravite == 'critique' %}
            <span class="badge badge-danger">Critique</span>
        {% elseif maladie.niveauGravite == 'eleve' %}
            <span class="badge badge-warning">Élevé</span>
        {% elseif maladie.niveauGravite == 'moyen' %}
            <span class="badge badge-info">Moyen</span>
        {% else %}
            <span class="badge badge-success">Faible</span>
        {% endif %}
    </div>
</div>

<div class="traitement-box">
    <h2>💊 Traitement recommandé</h2>
    <h3>{{ traitement.titre }}</h3>
    
    <p><strong>Description :</strong></p>
    <p>{{ traitement.description|nl2br }}</p>
    
    {% if traitement.etapes %}
        <p><strong>📋 Étapes à suivre :</strong></p>
        {{ traitement.etapes|nl2br }}
    {% endif %}
    
    {% if traitement.produits %}
        <p><strong>🛒 Produits recommandés :</strong></p>
        <p>{{ traitement.produits|nl2br }}</p>
    {% endif %}
    
    {% if traitement.duree %}
        <p><strong>⏱️ Durée du traitement :</strong> {{ traitement.duree }}</p>
    {% endif %}
</div>

<div class="footer">
    <p>Document généré par FIRMA - Application de diagnostic des maladies des plantes</p>
    <p>⚠️ Ce diagnostic est basé sur les informations fournies. En cas de doute, consultez un expert.</p>
</div>

</body>
</html>