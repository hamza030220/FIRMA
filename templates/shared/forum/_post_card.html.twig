{% set translatedPost = translatedPost is defined and translatedPost ? translatedPost : null %}
{% set favoriteBookmarked = favorite_bookmarked_ids is defined and favorite_bookmarked_ids[post.id] is defined %}
{% set savedBookmarked = saved_bookmarked_ids is defined and saved_bookmarked_ids[post.id] is defined %}
{% set postIsPinned = post.isPinned ?? false %}
{% set forumReturnTo = forum_return_to is defined ? forum_return_to : '' %}

<article class="forum-card{% if postIsPinned %} is-pinned{% endif %}">
    <a href="{{ path('user_forum_show', {id: post.id}) }}" class="forum-card-link" aria-label="{{ 'forum.index.open_post'|trans({}, 'forum') }} {{ translatedPost.title|default(post.titre) }}">
        <div class="forum-card-meta">
            <span>
                {{ post.categorie ? (translated_categories[post.categorie]|default(post.categorie)) : ('forum.common.no_category'|trans({}, 'forum')) }}
                {% if postIsPinned %}
                    <em class="forum-post-badge">Epingle</em>
                {% endif %}
            </span>
            <span>{{ post.dateCreation|date('H:i', 'Africa/Lagos') }}</span>
        </div>
        <h3>{{ translatedPost.title|default(post.titre) }}</h3>
        <p>
            {% set postPreview = translatedPost.content|default(post.contenu) %}
            {{ postPreview|length > 190 ? postPreview|slice(0, 190) ~ '...' : postPreview }}
        </p>
        <span
            class="forum-card-cta"
            aria-hidden="true"
            data-tooltip="{{ 'forum.index.open_post'|trans({}, 'forum') }}"
        >
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M5 12h14"/>
                <path d="m12 5 7 7-7 7"/>
            </svg>
        </span>
    </a>
    <div class="forum-mood-widget" data-forum-mood-widget data-post-id="{{ post.id }}" data-mood-url="{{ path('user_forum_mood_analyze') }}">
        <span class="forum-mood-result" data-forum-mood-result>{{ 'forum.mood.pending'|trans({}, 'forum') }}</span>
    </div>
    <div class="forum-card-footer">
        <span>{{ 'forum.common.by'|trans({}, 'forum') }} {{ post.utilisateur.fullName }}</span>
        <div class="forum-inline-actions">
            <span>{{ post.commentaires|length }} {{ 'forum.common.comment'|trans({}, 'forum') }}{{ post.commentaires|length > 1 ? 's' : '' }}</span>
            <div class="forum-bookmark-actions">
                <form method="post" action="{{ path('user_forum_bookmark_toggle', {id: post.id, type: 'favorite'}) }}" class="forum-bookmark-form" data-forum-preserve-scroll="true">
                    <input type="hidden" name="_token" value="{{ csrf_token('forum_bookmark_' ~ post.id ~ '_favorite') }}">
                    <input type="hidden" name="return_to" value="{{ forumReturnTo }}">
                    <button
                        type="submit"
                        class="forum-icon-action forum-icon-action-only{% if favoriteBookmarked %} is-active{% endif %}"
                        title="{{ favoriteBookmarked ? 'Retirer des favoris' : 'Ajouter aux favoris' }}"
                        aria-label="{{ favoriteBookmarked ? 'Retirer des favoris' : 'Ajouter aux favoris' }}"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 17.3 6.82 20l.99-5.82L3.6 9.93l5.86-.85L12 3.78l2.54 5.3 5.86.85-4.2 4.25L17.18 20z"/>
                        </svg>
                    </button>
                </form>
                <form method="post" action="{{ path('user_forum_bookmark_toggle', {id: post.id, type: 'saved'}) }}" class="forum-bookmark-form" data-forum-preserve-scroll="true">
                    <input type="hidden" name="_token" value="{{ csrf_token('forum_bookmark_' ~ post.id ~ '_saved') }}">
                    <input type="hidden" name="return_to" value="{{ forumReturnTo }}">
                    <button
                        type="submit"
                        class="forum-icon-action forum-icon-action-only{% if savedBookmarked %} is-active{% endif %}"
                        title="{{ savedBookmarked ? 'Retirer de la sauvegarde' : 'Sauvegarder pour plus tard' }}"
                        aria-label="{{ savedBookmarked ? 'Retirer de la sauvegarde' : 'Sauvegarder pour plus tard' }}"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M6 3h12v18l-6-4-6 4z"/>
                        </svg>
                    </button>
                </form>
            </div>
            {% if app.user and post.utilisateur and app.user.id == post.utilisateur.id %}
                <div class="forum-post-actions">
                    <a
                        href="{{ path('user_forum_edit', {id: post.id}) }}"
                        class="forum-icon-action forum-icon-action-only"
                        title="{{ 'forum.index.edit_post'|trans({}, 'forum') }}"
                        aria-label="{{ 'forum.index.edit_post'|trans({}, 'forum') }}"
                        data-firma-confirm-link="true"
                        data-firma-confirm-title="{{ 'forum.index.edit_title'|trans({}, 'forum') }}"
                        data-firma-confirm-message="{{ 'forum.index.edit_message'|trans({}, 'forum') }}"
                        data-firma-confirm-submit="{{ 'forum.common.save'|trans({}, 'forum') }}"
                        data-firma-confirm-variant="primary"
                    >
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 20h9"/>
                            <path d="M16.5 3.5a2.12 2.12 0 1 1 3 3L7 19l-4 1 1-4Z"/>
                        </svg>
                    </a>
                    <form id="delete-post-{{ post.id }}" method="post" action="{{ path('user_forum_delete', {id: post.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('forum_delete_' ~ post.id) }}">
                        <button type="button" class="forum-icon-action forum-icon-action-danger forum-icon-action-only" title="{{ 'forum.index.delete_post'|trans({}, 'forum') }}" aria-label="{{ 'forum.index.delete_post'|trans({}, 'forum') }}" onclick="window.firmaOpenConfirmModal('delete-post-{{ post.id }}', '{{ 'forum.index.delete_post'|trans({}, 'forum')|e('js') }}', '{{ 'forum.index.delete_message'|trans({}, 'forum')|e('js') }}');">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M3 6h18"/>
                                <path d="M8 6V4h8v2"/>
                                <path d="M19 6l-1 14H6L5 6"/>
                                <path d="M10 11v6"/>
                                <path d="M14 11v6"/>
                            </svg>
                        </button>
                    </form>
                </div>
            {% endif %}
        </div>
    </div>
    {% include 'shared/forum/_reaction_bar.html.twig' with {
        post: post,
        reactionUser: app.user,
        reactionCompact: true,
        reactionEditable: true,
        reactionReturnTo: forumReturnTo
    } only %}
</article>
