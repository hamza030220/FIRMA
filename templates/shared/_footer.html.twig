{# ══════════════════════════════════════════════════════════════
   FIRMA — Global Footer
   Included in base.html.twig so it appears on every page.
   ══════════════════════════════════════════════════════════════ #}
<footer class="firma-footer">
    <div class="firma-footer-inner">

        {# ── Left: Logo + tagline ── #}
        <div class="firma-footer-brand">
            <img src="{{ asset('image/firma.png') }}" alt="FIRMA" class="firma-footer-logo">
            <p class="firma-footer-tagline">Votre plateforme agricole intelligente.<br>Marketplace, événements, communauté — tout au même endroit.</p>
            <div class="firma-footer-social">
                <a href="#" aria-label="Facebook" class="firma-footer-social-link">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                </a>
                <a href="#" aria-label="Instagram" class="firma-footer-social-link">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                </a>
                <a href="#" aria-label="LinkedIn" class="firma-footer-social-link">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                </a>
                <a href="mailto:contact@firma.tn" aria-label="Email" class="firma-footer-social-link">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </a>
            </div>
        </div>

        {# ── Center-left: Navigation ── #}
        <div class="firma-footer-col">
            <h4 class="firma-footer-heading">Navigation</h4>
            <ul class="firma-footer-links">
                <li><a href="{{ path('app_landing') }}">Accueil</a></li>
                {% if app.user %}
                    <li><a href="{{ path('user_marketplace') }}">Marketplace</a></li>
                    <li><a href="{{ path('user_forum') }}">Forum</a></li>
                    <li><a href="{{ path('user_evenements') }}">Événements</a></li>
                    <li><a href="{{ path('user_maladie') }}">Maladies</a></li>
                {% else %}
                    <li><a href="{{ path('app_login') }}">Connexion</a></li>
                {% endif %}
            </ul>
        </div>

        {# ── Center-right: Resources ── #}
        <div class="firma-footer-col">
            <h4 class="firma-footer-heading">Ressources</h4>
            <ul class="firma-footer-links">
                <li><a href="{{ path('app_help_center') }}">Centre d'aide</a></li>
                <li><a href="{{ path('app_terms') }}">Conditions d'utilisation</a></li>
                <li><a href="{{ path('app_privacy') }}">Politique de confidentialité</a></li>
                <li><a href="{{ path('app_faq') }}">FAQ</a></li>
            </ul>
        </div>

        {# ── Right: Contact ── #}
        <div class="firma-footer-col">
            <h4 class="firma-footer-heading">Contact</h4>
            <ul class="firma-footer-contact">
                <li>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    Tunis, Tunisie
                </li>
                <li>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                    +216 XX XXX XXX
                </li>
                <li>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    contact@firma.tn
                </li>
            </ul>
        </div>

    </div>

    {# ── Bottom bar ── #}
    <div class="firma-footer-bottom">
        <p>&copy; {{ "now"|date("Y") }} FIRMA. Tous droits réservés.</p>
    </div>
</footer>
