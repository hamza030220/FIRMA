{% extends 'base.html.twig' %}

{% block title %}Connexion — FIRMA{% endblock %}
{% block meta_description %}Connectez-vous à FIRMA, votre plateforme agricole intelligente.{% endblock %}

{% block body %}
<div class="login-page">
  {# ── BACKGROUND EFFECTS ── #}
  <div class="login-bg-pattern"></div>
  <div class="login-orb login-orb-1"></div>
  <div class="login-orb login-orb-2"></div>
  <div class="login-orb login-orb-3"></div>

  {# ── LEFT PANEL: BRANDING ── #}
  <div class="login-brand-panel">
    <div class="brand-content">
      <a href="{{ path('app_landing') }}" class="brand-logo">
        <img src="{{ asset('image/logofirma.jpg') }}" alt="FIRMA" class="brand-logo-img">
        <span class="brand-logo-text">FIRMA</span>
      </a>

      <div class="brand-hero">
        <div class="brand-circle"></div>
        <div class="brand-circle brand-circle-2"></div>
        <h1 class="brand-title">
          <span class="brand-word bw1">Bienvenue</span>
          <em><span class="brand-word bw2">sur FIRMA</span></em>
        </h1>
        <p class="brand-tagline">Marketplace, événements, maladies, communauté —<br><strong>tout au même endroit.</strong></p>
      </div>

      <div class="brand-images">
        <div class="brand-img-card bic-1">
          <img src="{{ asset('image/firma.png') }}" alt="FIRMA Platform">
        </div>
        <div class="brand-img-card bic-2">
          <img src="{{ asset('image/slogan.png') }}" alt="FIRMA Slogan">
        </div>
      </div>

      <div class="brand-features">
        <div class="brand-feature">
          <div class="bf-icon">🛒</div>
          <span>Marketplace</span>
        </div>
        <div class="brand-feature">
          <div class="bf-icon">📅</div>
          <span>Événements</span>
        </div>
        <div class="brand-feature">
          <div class="bf-icon">🌿</div>
          <span>Maladies</span>
        </div>
        <div class="brand-feature">
          <div class="bf-icon">💬</div>
          <span>Forum</span>
        </div>
      </div>
    </div>
  </div>

  {# ── RIGHT PANEL: LOGIN FORM ── #}
  <div class="login-form-panel">
    <div class="login-form-wrapper">
      <div class="login-mobile-logo">
        <img src="{{ asset('image/logofirma.jpg') }}" alt="FIRMA" class="mobile-logo-img">
      </div>

      <div class="login-header">
        <h2 class="login-title">Connexion</h2>
        <p class="login-subtitle">Entrez vos identifiants pour accéder à votre espace</p>
      </div>

      {% if error %}
        <div class="login-alert">
          <svg viewBox="0 0 20 20" fill="none" class="alert-icon">
            <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.5"/>
            <path d="M10 6v5M10 13.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
        </div>
      {% endif %}

      <form method="post" class="login-form" autocomplete="on" novalidate>
        <div class="form-group">
          <label for="input-email" class="form-label">Adresse email</label>
          <div class="input-wrapper">
            <svg viewBox="0 0 20 20" fill="none" class="input-icon">
              <rect x="2" y="4" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.4"/>
              <path d="M2 6l8 5 8-5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            </svg>
            <input type="email" id="input-email" name="_username" value="{{ last_username }}"
                   class="form-input" placeholder="votre@email.com" required autofocus autocomplete="email">
          </div>
        </div>

        <div class="form-group">
          <div class="form-label-row">
            <label for="input-password" class="form-label">Mot de passe</label>
            <a href="{{ path('app_forgot_password') }}" class="forgot-link">Mot de passe oublié ?</a>
          </div>
          <div class="input-wrapper">
            <svg viewBox="0 0 20 20" fill="none" class="input-icon">
              <rect x="3" y="9" width="14" height="9" rx="2" stroke="currentColor" stroke-width="1.4"/>
              <path d="M6 9V6a4 4 0 118 0v3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              <circle cx="10" cy="13.5" r="1.5" fill="currentColor"/>
            </svg>
            <input type="password" id="input-password" name="_password"
                   class="form-input" placeholder="••••••••" required autocomplete="current-password">
            <button type="button" class="toggle-password" onclick="togglePass()" aria-label="Afficher le mot de passe">
              <svg viewBox="0 0 20 20" fill="none" class="eye-icon" id="eye-icon">
                <path d="M1 10s3.5-6 9-6 9 6 9 6-3.5 6-9 6-9-6-9-6z" stroke="currentColor" stroke-width="1.3"/>
                <circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1.3"/>
              </svg>
            </button>
          </div>
        </div>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button type="submit" class="login-btn">
          <span class="btn-text">Se connecter</span>
          <svg viewBox="0 0 20 20" fill="none" class="btn-arrow">
            <path d="M4 10h12m-4-4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </form>

      <div class="login-footer-text">
        <span>Pas encore de compte ?</span>
        <a href="{{ path('app_inscription') }}">Créer un compte</a>
      </div>

      <a href="{{ path('app_landing') }}" class="back-home">← Retour à l'accueil</a>
    </div>
  </div>
</div>

<script>
document.querySelector('.login-form').addEventListener('submit', function(e) {
    // Validation handled server-side
});
function togglePass() {
  const input = document.getElementById('input-password');
  const icon = document.getElementById('eye-icon');
  if (input.type === 'password') {
    input.type = 'text';
    icon.innerHTML = '<path d="M1 10s3.5-6 9-6 9 6 9 6-3.5 6-9 6-9-6-9-6z" stroke="currentColor" stroke-width="1.3"/><circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1.3"/><line x1="3" y1="3" x2="17" y2="17" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>';
  } else {
    input.type = 'password';
    icon.innerHTML = '<path d="M1 10s3.5-6 9-6 9 6 9 6-3.5 6-9 6-9-6-9-6z" stroke="currentColor" stroke-width="1.3"/><circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1.3"/>';
  }
}

// Animate form elements on load
document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('.form-group, .login-header, .login-btn, .login-footer-text, .back-home').forEach((el, i) => {
    el.style.animationDelay = `${0.15 + i * 0.08}s`;
  });
});
</script>
{% endblock %}




