<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FIRMA — Confirmation</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 50%, #a5d6a7 100%);
            padding: 20px;
        }
        .card {
            background: #fff;
            border-radius: 20px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.12);
            max-width: 480px;
            width: 100%;
            padding: 40px 32px;
            text-align: center;
        }
        .card--error { }
        .icon {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            font-size: 40px;
        }
        .icon--success { background: #e8f5e9; }
        .icon--info    { background: #e3f2fd; }
        .icon--error   { background: #ffebee; }
        h1 {
            font-size: 22px;
            color: #2e7d32;
            margin-bottom: 12px;
            font-weight: 700;
        }
        h1.info  { color: #1565c0; }
        h1.error { color: #c62828; }
        .message {
            font-size: 16px;
            color: #555;
            line-height: 1.6;
            margin-bottom: 28px;
        }
        .steps {
            background: #f5f5f5;
            border-radius: 12px;
            padding: 20px;
            text-align: left;
            margin-bottom: 28px;
        }
        .steps h3 {
            font-size: 14px;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 12px;
        }
        .step {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            margin-bottom: 10px;
        }
        .step:last-child { margin-bottom: 0; }
        .step-num {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: #2e7d32;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 700;
            flex-shrink: 0;
        }
        .step-text {
            font-size: 15px;
            color: #333;
            padding-top: 3px;
        }
        .event-name {
            display: inline-block;
            background: #e8f5e9;
            color: #2e7d32;
            padding: 6px 16px;
            border-radius: 20px;
            font-weight: 600;
            font-size: 14px;
            margin-bottom: 20px;
        }
        .logo {
            font-size: 28px;
            font-weight: 800;
            color: #2e7d32;
            margin-bottom: 8px;
            letter-spacing: -0.5px;
        }
        .footer {
            font-size: 13px;
            color: #aaa;
            margin-top: 20px;
        }
        .icon--pending { background: #fff8e1; }
        h1.pending { color: #e65100; }
        .btn-confirm {
            display: inline-block;
            background: #2e7d32;
            color: #fff;
            border: none;
            border-radius: 12px;
            padding: 14px 36px;
            font-size: 17px;
            font-weight: 700;
            cursor: pointer;
            margin-bottom: 12px;
            letter-spacing: 0.2px;
            transition: background 0.2s;
        }
        .btn-confirm:hover { background: #1b5e20; }
    </style>
</head>
<body>
    <div class="card{% if status == 'error' %} card--error{% endif %}">
        <div class="logo">FIRMA</div>

        {% if status == 'pending' %}
            <div class="icon icon--pending">&#9993;</div>
            <h1 class="pending">Confirmez votre participation</h1>
            {% if eventName %}
                <div class="event-name">{{ eventName }}</div>
            {% endif %}
            <p class="message">
                Cliquez sur le bouton ci-dessous pour confirmer votre inscription.<br>
                Votre ticket vous sera envoyé par email immédiatement après.
            </p>
            <form method="post" action="{{ confirmUrl }}">
                <button type="submit" class="btn-confirm">✅ Confirmer ma participation</button>
            </form>

        {% elseif status == 'success' %}
            <div class="icon icon--success">&#10003;</div>
            <h1>Participation confirmée !</h1>
            {% if eventName %}
                <div class="event-name">{{ eventName }}</div>
            {% endif %}
            <p class="message">
                Votre participation a été confirmée avec succès.<br>
                Un email contenant votre <strong>code de participation</strong> vous a été envoyé.
            </p>
            <div class="steps">
                <h3>Prochaines étapes</h3>
                <div class="step">
                    <span class="step-num">1</span>
                    <span class="step-text">Ouvrez votre boîte mail (vérifiez aussi les spams)</span>
                </div>
                <div class="step">
                    <span class="step-num">2</span>
                    <span class="step-text">Cherchez l'email de <strong>FIRMA</strong> avec votre code</span>
                </div>
                <div class="step">
                    <span class="step-num">3</span>
                    <span class="step-text">Conservez votre code — il sera demandé le jour de l'événement</span>
                </div>
            </div>

        {% elseif status == 'already' %}
            <div class="icon icon--info">&#8505;</div>
            <h1 class="info">Déjà confirmée</h1>
            {% if eventName %}
                <div class="event-name">{{ eventName }}</div>
            {% endif %}
            <p class="message">
                Votre participation a déjà été confirmée.<br>
                Consultez votre boîte mail pour retrouver votre <strong>code de participation</strong>.
            </p>

        {% else %}
            <div class="icon icon--error">&#10007;</div>
            <h1 class="error">{{ title|default('Erreur') }}</h1>
            <p class="message">{{ message|default('Le lien de confirmation est invalide ou a expiré.') }}</p>
        {% endif %}

        <div class="footer">Vous pouvez fermer cette page.</div>
    </div>
</body>
</html>
